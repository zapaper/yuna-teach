# Database (Railway provides this)
DATABASE_URL="postgresql://user:pass@host:port/db"

# Google Cloud Vision API
GOOGLE_CLOUD_API_KEY="your-google-cloud-api-key"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Fish Audio TTS (English only — Chinese uses Google Cloud TTS)
FISH_AUDIO_API_KEY="your-fish-audio-api-key"
FISH_AUDIO_VOICE_EN="english-voice-model-id"

# Google Cloud TTS is used for Chinese (Neural2 zh-CN-Neural2-C)
# Reuses GOOGLE_CLOUD_API_KEY above — ensure Text-to-Speech API is enabled in your GCP project

# Stripe (subscription billing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_ID="price_..."           # S$5/month recurring price ID
STRIPE_WEBHOOK_SECRET="whsec_..."

# Brevo (transactional email for verification codes)
BREVO_API_KEY="xkeysib-..."
BREVO_SENDER_EMAIL="noreply@markforyou.com"

# Auth.js (NextAuth v5) — Google + Apple OAuth
# When AUTH_SECRET is unset the OAuth buttons are dead. The
# username/password login keeps working regardless.
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="https://www.markforyou.com"      # production base URL; locally use http://localhost:3000

# Google OAuth — Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Authorised redirect URI to register:
#   https://www.markforyou.com/api/auth/callback/google
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."

# Apple Sign In — developer.apple.com → Certificates, Identifiers & Profiles
# 1. Create a Service ID for the web flow (returns to /api/auth/callback/apple).
#    APPLE_CLIENT_ID is the Service ID identifier (e.g. com.markforyou.web).
# 2. Create a Sign-In-with-Apple Key (.p8); note the 10-char key id and your
#    10-char team id, paste the .p8 contents into APPLE_PRIVATE_KEY (with
#    BEGIN/END PRIVATE KEY lines).
APPLE_CLIENT_ID="com.markforyou.web"
APPLE_TEAM_ID="ABCD123456"
APPLE_KEY_ID="ABCD123456"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

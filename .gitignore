# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local PDF storage (dev fallback for Railway volume)
/.data

# vendored static assets copied from node_modules at install time
# (see scripts/copy-opencv.mjs). Worker glue (scanner-worker.js etc.)
# IS source code — only the auto-copied runtime gets ignored.
/public/vendor/opencv.js

# Avatar videos/images live on Cloudflare R2 and are served via the
# /avatars/* redirect in next.config.ts. Were previously committed
# (~333 MB) and shipped on every Railway deploy — moved off-host to
# slim the build context.
/public/avatars

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  // `name` is the IMMUTABLE login username — set at signup, never
  // changes. Stays unique. UI displays `displayName` if set, otherwise
  // falls back to `name`. Login lookups go through `name`.
  name        String
  // Mutable display name shown in greetings, headers, etc. NULL means
  // "use the username as the display name". Editable from the rename
  // modal in the parent / student homepage.
  displayName String?
  email     String?  @unique
  password  String   @default("1234")
  role      Role     @default(STUDENT)
  level     Int?     // Primary 1-6, only for students
  settings  Json?    // Student settings: { avatar: boolean, crystalCurrency: boolean }
  createdAt DateTime @default(now())
  // Last successful login timestamp. Set in POST /api/auth on login.
  lastLoginAt DateTime?

  // Email verification & subscription
  emailVerified         Boolean  @default(false)
  stripeCustomerId      String?  @unique
  stripeSubscriptionId  String?
  subscriptionStatus    String?  // "active" | "canceled" | "past_due" | "expired" | "trialing" | "trial_expired" | null (free)
  // Trial: every new account gets 30 days from signup. While
  // (now <= trialEndsAt) AND no active subscription, user is in
  // "trialing" status — full feature access. After expiry without
  // conversion, user is "trial_expired" — keeps progress/data but
  // cannot create new assignments / quizzes (see canAssign in
  // src/lib/subscription.ts).
  trialEndsAt           DateTime?
  // Bumped in /api/users when a trial-extending promo code is
  // redeemed at signup (e.g. "FRIENDS90" = 90 days instead of 30).
  promoCodeId           String?
  redeemedPromoCode     PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  // Apple In-App Purchase identity. All nullable — populated only for
  // users who paid via the iOS app. The reconciler upserts these
  // when /api/iap/verify or /api/iap/asn-webhook fires.
  appleOriginalTransactionId String?  @unique
  appleProductId             String?       // e.g. "com.markforyou.monthly"
  appleEnvironment           String?       // "Production" | "Sandbox"
  appleExpiresAt             DateTime?
  // "stripe" | "apple" — convenience flag (derivable from above but
  // cleaner to query). Drives "manage in App Store" vs "manage on
  // website" copy in the cancel/upgrade UI.
  paymentSource              String?

  // OAuth provider identifiers. Populated when a user signs in via
  // Google or Apple Sign In. Stored alongside (not replacing) the
  // existing username + password — a single User can have any
  // combination of: local password, googleId, appleId. Lookup at
  // sign-in time matches by email first (so an existing local
  // account auto-links on first SSO), falling back to provider id.
  // Both fields are unique-but-nullable.
  googleId String? @unique
  appleId  String? @unique

  tests              SpellingTest[]
  examPapers         ExamPaper[]    @relation("UploadedPapers")
  assignedExamPapers ExamPaper[]    @relation("AssignedPapers")
  parentLinks        ParentStudent[] @relation("ParentLinks")
  studentLinks       ParentStudent[] @relation("StudentLinks")
  inviteCodes        InviteCode[]
  emailCodes         EmailVerification[]

  @@map("users")
}

model SpellingTest {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  language  Language @default(CHINESE)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  words Word[]

  @@map("spelling_tests")
}

model Word {
  id             String  @id @default(cuid())
  text           String
  orderIndex     Int
  enabled        Boolean @default(true)
  spellingTestId String
  // For two-column spelling sheets (e.g. English ↔ Malay or
  // English ↔ Tamil vocab lists), this holds the paired translation
  // from the OTHER column. Used to disambiguate polysemous words
  // when generating meaning + example via the AI.
  pairedText     String?

  spellingTest SpellingTest @relation(fields: [spellingTestId], references: [id], onDelete: Cascade)

  @@map("words")
}

enum Role {
  STUDENT
  PARENT
}

model ExamPaper {
  id        String   @id @default(cuid())
  title     String
  school    String?
  level     String?
  subject   String?
  year      String?
  semester  String?
  totalMarks String?
  metadata   Json?
  pdfPath    String?
  pageCount Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scheduledFor DateTime @default(now())
  userId       String
  assignedToId String?
  score            Float?
  completedAt      DateTime?
  timeSpentSeconds Int       @default(0)
  instantFeedback  Boolean   @default(false)
  markingStatus    String?   // "pending" | "in_progress" | "complete" | "released" | "failed"
  extractionStatus String?   // "processing" | "ready" | "failed"
  feedbackSummary  String?
  sourceExamId     String?
  paperType        String?   // null = regular, "focused" = focused test
  examType         String?   // "Preliminary" | "WA1" | "WA2" | "WA3" | "End of Year"
  visible          Boolean   @default(false)
  // Per-page admin annotations. Object keyed by zero-based page index,
  // each value a PNG data URL produced by the /exam/[id]/annotate page.
  // Null means no annotations yet.
  annotationsByPage Json?
  // Parent's red-pen annotations made on the quiz review page.
  // Object keyed by either "passage:<sectionIdx>" (English passage)
  // or "question:<questionId>" (per-question OEQ canvas), each value a
  // PNG data URL. Cleared by the parent via the Clear button.
  reviewAnnotations Json?

  user       User           @relation("UploadedPapers", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User?          @relation("AssignedPapers", fields: [assignedToId], references: [id], onDelete: SetNull)
  sourceExam ExamPaper?     @relation("ExamClones", fields: [sourceExamId], references: [id], onDelete: SetNull)
  clones     ExamPaper[]    @relation("ExamClones")
  questions  ExamQuestion[]

  @@map("exam_papers")
}

model ExamQuestion {
  id              String  @id @default(cuid())
  questionNum     String
  imageData       String
  answer          String?
  answerImageData String?
  pageIndex       Int
  orderIndex      Int
  yStartPct       Float?
  yEndPct         Float?
  // Printable-PDF writing-area bounds. Populated when a quiz /
  // focused-test paper is rendered to a clean-extract printable
  // PDF — the marker uses these to crop the student's answer
  // region from each scanned page after submission.
  // Shape: { pageIndex, yStartPct, yEndPct, subparts?: {
  //   [label]: { pageIndex, yStartPct, yEndPct }
  // } }
  // Differs from yStartPct / yEndPct above because those track
  // the original paper's coordinates; printableBounds tracks
  // OUR generated PDF's coordinates.
  printableBounds Json?
  examPaperId     String
  marksAwarded    Float?
  marksAvailable  Float?
  markingNotes    String?
  syllabusTopic   String?
  // Master Class sub-topic tag — finer-grained than syllabusTopic.
  // E.g. for syllabusTopic = "Interactions within the environment",
  // subTopic is one of: definitions / causal-chain / mutual-benefits /
  // food-web-explaining / adaptation / decomposer / human-impact.
  // Populated by the per-topic classifier (admin tool); null until then.
  subTopic        String?
  studentAnswer   String?
  elaboration     String?
  flagged         Boolean @default(false)
  flaggedAt       DateTime?
  flaggedByUserId String?
  // Filename of the voice note the user recorded when they flagged the
  // question, saved on disk under VOLUME_PATH/flag-voices/<paperId>/.
  // Null when the flag was raised without a recording.
  flagVoiceNote   String?
  // Optional typed message left when raising a flag — alternative to
  // voice notes for users who'd rather type. Both can coexist.
  flagText        String?
  adminReply      String?
  adminRepliedAt  DateTime?
  adminReplyRead  Boolean  @default(false)

  // Clean question transcription (quiz mode)
  transcribedStem         String?
  transcribedOptions      Json?    // string[4] for MCQ (text options)
  transcribedOptionImages Json?    // string[4] for MCQ (image options, base64)
  transcribedOptionTable  Json?    // table-format MCQ: { columns: string[], rows: string[][] (4 rows, each = one option's values per column) }. Mutually exclusive with the two fields above — if set, the options ARE the rows.
  // Set to TRUE when an admin skips this question in the
  // /admin/convert-mcq-tables tool, so it never reappears in the
  // candidate list. Has no effect outside that tool.
  mcqTableSkipped         Boolean  @default(false)
  transcribedSubparts     Json?    // {label: string, text: string}[]
  diagramBounds           Json?    // {top, left, bottom, right} percentages
  diagramImageData        String?  // base64 cropped diagram

  // Source tracking: for quiz/focused questions copied from master papers
  sourceQuestionId        String?  // ID of the original ExamQuestion this was copied from

  // Synthetic question generation (admin)
  syntheticGenerated      Boolean  @default(false)
  syntheticSkipped        Boolean  @default(false) // admin deferred — push to end of queue
  // For rows on a Synthetic Bank paper: the examType of the ORIGINAL source
  // paper (WA1/WA2/EOY/Prelim). Null on non-synthetic rows.
  syntheticSourceExamType String?
  // 1-5 difficulty rating (1=very easy, 5=very hard). AI-classified for
  // clean-extracted master questions; null for un-classified. When a
  // question has enough student attempts (>= 5 clones with marks), the
  // UI overrides this with an empirical average.
  difficulty              Int?
  syntheticQuestions      SyntheticQuestion[]

  examPaper ExamPaper @relation(fields: [examPaperId], references: [id], onDelete: Cascade)

  @@map("exam_questions")
}

model SyntheticQuestion {
  id               String   @id @default(cuid())
  sourceQuestionId String
  variant          String   // "simple" | "similar"
  stem             String
  options          Json     // MCQ: string[4]. OEQ: [] (use subparts/answerText instead).
  correctAnswer    Int      // MCQ: 1-4. OEQ: 0 (ignored).
  diagramImageData String?  // base64 new diagram (optional)
  createdAt        DateTime @default(now())
  // OEQ fields — null for MCQ rows.
  questionType     String   @default("mcq")  // "mcq" | "oeq"
  subparts         Json?    // OEQ: [{ label: "a", text: "..." }]
  answerText       String?  // OEQ: full answer ("(a) ... | (b) ...")
  marksAvailable   Int?     // OEQ: mark allocation carried from source

  sourceQuestion   ExamQuestion @relation(fields: [sourceQuestionId], references: [id], onDelete: Cascade)

  @@index([sourceQuestionId])
  @@map("synthetic_questions")
}

model ParentStudent {
  id        String   @id @default(cuid())
  parentId  String
  studentId String
  createdAt DateTime @default(now())

  parent  User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  student User @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invite_codes")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  userEmail String?
  message   String
  createdAt DateTime @default(now())

  @@map("feedback")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String   // 4-digit code
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

enum Language {
  CHINESE
  ENGLISH
  JAPANESE
  MALAY
  TAMIL
  KOREAN
}

// Transient store for AI-solver results. Client generates a UUID per solve
// and POSTs it with the image; server saves the result here keyed by the
// UUID. If the client tab backgrounds mid-call and the fetch dies, the
// client polls GET /api/solver?jobId=... on resume to pick up the saved
// result. Rows are auto-deleted after ~15 min (cleanup on new inserts).
model SolverJob {
  id          String    @id
  status      String    // "pending" | "done" | "error"
  result      Json?
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([createdAt])
  @@map("solver_jobs")
}

// Promo codes. Two flavours:
//   - kind="trial_days": redeemed at signup, extends trialEndsAt
//     by `value` days (so value=60 → trial = 30+60 = 90 days total).
//   - kind="stripe_coupon": redeemed at Stripe checkout, the
//     `value` is the Stripe Coupon ID (we forward it on session.create).
//     Apple/IAP doesn't support our promo codes — only web flows.
// Codes are admin-created; no self-serve generation. Each row tracks
// usage counts so single-use codes are enforceable.
model PromoCode {
  id           String   @id @default(cuid())
  code         String   @unique  // user-typed string, case-insensitive
  kind         String                // "trial_days" | "stripe_coupon"
  value        String                // days as a string, OR Stripe coupon id
  description  String?               // admin-only label
  // null = unlimited; otherwise hard cap on total redemptions.
  maxRedemptions Int?
  redeemedCount  Int      @default(0)
  expiresAt    DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  redeemers    User[]

  @@index([code])
  @@map("promo_codes")
}

// Admin-editable per-slide narration scripts for a Master Class.
// The YAML in src/data/master-class/ remains the seed / fallback.
// When an admin saves edits in the workshop UI, the mega-textarea
// strings (one per slide) land here. Read path: load YAML, then
// overlay the parsed DB scripts onto the matching slide indexes.
//
//   keyConceptScripts: string[]      — one per keyConcepts slide
//   commonMistakeScripts: string[]   — one per commonMistakes slide
//
// Inline {…} braces inside a script mark audio-only text. The parser
// extracts them into the slide's `narration` block automatically.
model MasterClass {
  slug                 String   @id
  keyConceptScripts    Json     @default("[]")
  commonMistakeScripts Json     @default("[]")
  // Last prompt used to regenerate the class icon via Gemini image
  // generation. Persisted so the admin workshop's icon editor can
  // show what was used and let the author iterate on it.
  iconPrompt           String?
  updatedAt            DateTime @updatedAt

  @@map("master_classes")
}

// Pre-generated PSLE-style Chinese MCQ drafts seeded from the Tier 1
// wordlist (see scripts/generate-chinese-mcq-drafts.ts). Admin reviews
// each draft and clicks Keep → row's status flips to "kept" and the
// draft is materialised as an ExamQuestion in the Chinese synthetic
// bank. Dropped drafts stay in this table for audit but won't be
// re-shown.
model ChineseMcqDraft {
  id                  String   @id @default(cuid())
  seedWord            String
  seedMeaning         String?
  shape               String   // "Q5-Q6" | "Q7-Q8" | "Q9-Q10"
  stem                String
  options             Json     // string[4]
  correctAnswer       Int      // 1-4 (1-indexed)
  explanation         String
  syllabusTopic       String
  subTopic            String?
  priority            Int      // 0 = PSLE correct-ans history (highest), 3 = lowest
  status              String   @default("pending")  // "pending" | "kept" | "dropped"
  promotedQuestionId  String?  // ExamQuestion.id once the draft is materialised
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, priority])
  @@map("chinese_mcq_drafts")
}

// Holds PSLE Chinese Paper 1 (作文 composition) and Paper 3 (口试 oral /
// 听力 listening) extractions for trend analysis. The combined PSLE
// Chinese PDFs uploaded to /admin/chinese-oral-compo are auto-sectioned
// by Gemini 3.1-pro (which pages are Paper 1 / 3 / answer keys) and
// OCR'd to raw text. Schema starts as raw text per section — once the
// trend-extraction prompts are designed, this gets extended with
// structured topics/phrases columns.
model ChineseSupplementaryPaper {
  id                String   @id @default(cuid())
  year              String   @unique  // "2019" — one entry per year

  pdfPath           String?  // path under VOLUME_PATH/chinese-supplementary/
  pageCount         Int?

  // Auto-detected page ranges (1-indexed page numbers as int arrays).
  paper1Pages       Json?
  paper3Pages       Json?
  paper1AnswerPages Json?
  paper3AnswerPages Json?

  // Raw OCR text per section — kept as ground-truth fallback even
  // when structured extraction below succeeds.
  paper1Text        String?  @db.Text
  paper3Text        String?  @db.Text
  paper1AnswerText  String?  @db.Text
  paper3AnswerText  String?  @db.Text

  // Structured extraction (Phase 2 — populated after raw OCR).
  // Schema reflects the actual PSLE Chinese paper layout:
  //   Paper 1: Option 1 (topic only) + Option 2 (picture + helping words).
  //   Paper 3: 10 MCQs + ~7 listening passages, each passage tagged
  //     with which question numbers it answers.
  //   Answers: model essays for Option 1 / 2; 10 listening answers.
  compoOption1Topic   String?  @db.Text   // e.g. "我最难忘的一天" — used for trend tracking
  compoOption2        Json?               // { instructions, helpingWords: string[], picturePageNum }
  listeningMcqs       Json?               // [{ num, text, options: [{ label, text|imageNote }] }]
  listeningPassages   Json?               // [{ num, text, questionNumbers: [int] }]
  compoOption1Model   String?  @db.Text   // model essay for Option 1
  compoOption2Model   String?  @db.Text   // model essay for Option 2
  listeningAnswers    Json?               // [{ num, answer }] for the 10 MCQs

  status            String   @default("uploaded")  // uploaded | sectioning | ocr | structuring | ready | failed
  errorMessage      String?  @db.Text

  uploadedBy        String?  // User.id
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("chinese_supplementary_papers")
}

// Sibling of ChineseSupplementaryPaper, but for PSLE English. Paper
// layout differs from Chinese — English splits writing into two
// sub-sections (Situational + Continuous), and the oral materials
// (reading passage + stimulus picture) typically live in a separate
// Paper 4 booklet rather than the same PDF as Paper 1/3. Structured
// fields reflect those differences.
model EnglishSupplementaryPaper {
  id   String   @id @default(cuid())
  year String   @unique

  pdfPath   String?
  pageCount Int?

  // Auto-detected page ranges.
  paper1Pages       Json?   // Paper 1 — Writing (Situational + Continuous)
  paper3Pages       Json?   // Paper 3 — Listening Comprehension (MCQs)
  paper4Pages       Json?   // Paper 4 — Oral (reading passage + stimulus picture)
  paper1AnswerPages Json?
  paper3AnswerPages Json?
  paper4AnswerPages Json?

  // Raw OCR.
  paper1Text       String?  @db.Text
  paper3Text       String?  @db.Text
  paper4Text       String?  @db.Text
  paper1AnswerText String?  @db.Text
  paper3AnswerText String?  @db.Text
  paper4AnswerText String?  @db.Text

  // Structured extraction.
  // Section A — Situational Writing
  situationalWriting   Json?  // { picturePageNum, scenario, audience, purpose, requirements: [], wordCount }
  // Section B — Continuous Writing
  continuousTheme      String?  // the bold theme heading shown above the 3 picture options
  continuousPrompts    Json?    // [{ optionNum, picturePageNum, brief }]
  // Paper 3 listening — MCQs tagged to texts + the 7 text passages
  listeningMcqs        Json?  // [{ num, text, options: [{ label, text }], isImageOptions, textNum }]
  listeningTexts       Json?  // [{ textNum: 1-7, content, questionNumbers: [int] }]
  // Paper 4 oral materials — split by Day 1 / Day 2
  oralDays             Json?  // [{ day: 1|2, readingPassage, stimulusPicturePageNum, stimulusDescription, conversationPrompts: [] }]

  // ── Legacy oral fields (kept temporarily for backward-compat with
  // any pre-restructure rows). Once 2016-2025 are re-extracted these
  // can be dropped via a follow-up migration.
  oralReadingPassage   String?  @db.Text
  oralStimulusPicture  Json?    // { picturePageNum, description, conversationPrompts: [] }

  // Model answers
  situationalModel  String?  @db.Text
  continuousModel   String?  @db.Text   // all 3 model essays concatenated with \n\n--- separators
  listeningAnswers  Json?               // [{ num, answer }]
  oralModelAnswers  Json?               // [{ day: 1|2, q: "a"|"b"|"c", answer }]

  status        String   @default("uploaded")
  errorMessage  String?  @db.Text

  uploadedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("english_supplementary_papers")
}

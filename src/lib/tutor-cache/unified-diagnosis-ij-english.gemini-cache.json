{
  "patterns": [
    {
      "name": "Confusing Similar Words",
      "what": "Sometimes picks a vocabulary word that is related to the topic but doesn't quite fit the exact meaning or sentence structure.",
      "specific_examples": [
        {
          "questionRef": "[23]",
          "type": "mcq",
          "whatWentWrong": "IJ picked 'reaps' instead of 'yields', missing that a garden produces crops rather than harvesting them."
        },
        {
          "questionRef": "[30]",
          "type": "mcq",
          "whatWentWrong": "He chose 'celebrate', but the phrase 'revel in' is the correct pairing for enjoying success."
        },
        {
          "questionRef": "[11]",
          "type": "mcq",
          "whatWentWrong": "He selected 'excessive', which has a negative meaning, instead of the positive word 'inexhaustible'."
        }
      ],
      "strategic_advice": "- When you see a blank, **read the words immediately before and after it** to check for clues.\n- **Test each option** in the sentence to see if it makes sense with the surrounding words.\n- If two words seem similar, think about **who or what is doing the action**.",
      "trigger_keywords": [
        "blank",
        "closest in meaning",
        "phrasal verbs"
      ]
    },
    {
      "name": "Linking Words Mix-Up",
      "what": "Occasionally chooses the wrong connector or pronoun to link ideas together in a passage.",
      "specific_examples": [
        {
          "questionRef": "[42]",
          "type": "oeq",
          "whatWentWrong": "IJ used 'between', which is for two things, instead of 'among' for a larger group of students."
        },
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'some', missing the chance to use 'others' to show a clear contrast between the two groups."
        },
        {
          "questionRef": "[34]",
          "type": "mcq",
          "whatWentWrong": "He picked 'Owing to', which shows a cause, instead of 'Despite' to show they pushed through their exhaustion."
        }
      ],
      "strategic_advice": "- When you see a connector blank, **read the sentence before and after** to decide if the ideas are agreeing, contrasting, or showing a result.\n- For pronouns, **draw an arrow back** to the exact noun it replaces to ensure it matches.\n- Remember that **'between' is for two things**, while **'among' is for three or more**.",
      "trigger_keywords": [
        "although",
        "despite",
        "therefore",
        "some",
        "between"
      ]
    },
    {
      "name": "Rushing the Final Answer",
      "what": "Tends to miss small details like spelling, copying all the words, or including the second part of an explanation.",
      "specific_examples": [
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "IJ knew the right word to fix the error but accidentally misspelled 'Occasionally'."
        },
        {
          "questionRef": "[44]",
          "type": "oeq",
          "whatWentWrong": "He combined the sentences well but accidentally left out the phrase 'on television' from the final answer."
        },
        {
          "questionRef": "[48]",
          "type": "oeq",
          "whatWentWrong": "He explained what happened but stopped one step short of showing exactly how the childhood experiences led to those traits."
        }
      ],
      "strategic_advice": "- When you finish writing an answer, **read it backwards or word-by-word** to catch spelling and copying slips.\n- For synthesis questions, **tick off each word** from the original sentence as you write it down.\n- When you see **'explain clearly'** or **'how'**, always include a **'so that...'** or **'which led to...'** clause to show the full connection.",
      "trigger_keywords": [
        "explain clearly",
        "rewrite",
        "edit",
        "how"
      ]
    }
  ],

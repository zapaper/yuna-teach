{
  "patterns": [
    {
      "name": "Question Tag Mix-Up",
      "what": "Sometimes misses hidden negative words like 'rarely' or 'seldom', or uses the wrong helping verb when forming question tags.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "mcq",
          "whatWentWrong": "He missed that 'rarely' is a negative word, which means the question tag needs to be positive."
        },
        {
          "questionRef": "[117]",
          "type": "mcq",
          "whatWentWrong": "He used 'didn't' instead of matching the helping verb 'have' from the contraction 'You've'."
        }
      ],
      "strategic_advice": "When you see a comma followed by a blank at the end of a sentence, it is a question tag. Use these steps:\n- **Check for hidden negatives** like 'rarely', 'seldom', 'hardly', or 'never'. If you see one, the tag must be positive!\n- **Find the helping verb** in the main sentence (like 'is', 'has', 'have', 'does') and reuse it in your tag.",
      "trigger_keywords": [
        "___?",
        ", ___ you?",
        ", ___ she?"
      ]
    },
    {
      "name": "Idiom and Phrase Mix-Up",
      "what": "Occasionally pieces together phrases word-by-word instead of using the exact English idiom or fixed expression expected.",
      "specific_examples": [
        {
          "questionRef": "[26]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'stand on straight' instead of the correct English idiom 'stand on end' to describe hair standing up."
        },
        {
          "questionRef": "[112]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'go down in the knees' instead of the common expression 'go weak in the knees'."
        },
        {
          "questionRef": "[130]",
          "type": "oeq",
          "whatWentWrong": "He used 'in great elaboration' instead of the fixed phrase 'in great detail'."
        }
      ],
      "strategic_advice": "When a blank is part of a common saying or phrase, trust your ear for what sounds like natural English.\n- **Read the whole sentence aloud** in your head. Often, the right word will 'click' because you have heard it before.\n- **Watch out for prepositions** that pair with specific verbs, like 'congratulate on' or 'need for'.",
      "trigger_keywords": [
        "stand on ___",
        "go ___ in the knees",
        "in great ___",
        "removing the need ___"
      ]
    },
    {
      "name": "Grammar Clue Slips",
      "what": "Occasionally misses nearby grammar clues like 'a/an', plural verbs, or helping verbs that require a specific word form, even when he has the right general meaning in mind.",
      "specific_examples": [
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "He chose 'essential', but missed that the blank comes after the article 'a', which requires a word starting with a consonant sound like 'big'."
        },
        {
          "questionRef": "[24]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'wonder', missing that the phrase 'have you ever' requires the past participle 'wondered'."
        },
        {
          "questionRef": "[113]",
          "type": "oeq",
          "whatWentWrong": "He wrote the singular 'stall', missing that the plural verb 'were' right after the blank requires the plural 'stalls'."
        }
      ],
      "strategic_advice": "Before writing your final answer in a cloze passage, look at the words immediately before and after the blank.\n- **Check the articles**: Does it say 'a' or 'an'?\n- **Check the verbs**: Is it a singular or plural action? Does it follow a helping verb like 'have' or 'has'?\n- **Check the time**: Are there clues that show the action happened in the past?",
      "trigger_keywords": [
        "a/an ___",
        "have you ever ___",
        "___ were",
        "___ is"
      ]
    },
    {
      "name": "Visual Text Traps",
      "what": "Sometimes reads posters and flyers quickly and misses small but important condition words like 'not', 'only', or rules for returning customers.",
      "specific_examples": [
        {
          "questionRef": "[37]",
          "type": "mcq",
          "whatWentWrong": "He missed the word 'only' in the first option, which made the statement false because the festival teaches many other things."
        },
        {
          "questionRef": "[85]",
          "type": "mcq",
          "whatWentWrong": "He missed the condition that Mindy was going 'again', which meant she qualified for the special returning customer discount."
        },
        {
          "questionRef": "[104]",
          "type": "mcq",
          "whatWentWrong": "He overlooked the word 'not' in the question stem and picked a true statement instead of the false one."
        }
      ],
      "strategic_advice": "Visual texts are designed to test how carefully you read the fine print. Treat these words as stop signs:\n- **'not true'** or **'false'** → highlight these so you don't accidentally pick a true fact.\n- **'only'**, **'always'**, or **'never'** → these extreme words often make an option false.\n- **Special conditions** → look out for words like 'first-time', 'returning', or 'minimum spend'.",
      "trigger_keywords": [
        "not true",
        "only",
        "again",
        "first order"
      ]
    }
  ],

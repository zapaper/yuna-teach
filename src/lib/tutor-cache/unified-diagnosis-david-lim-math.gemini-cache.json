{
  "patterns": [
    {
      "name": "Ratio Order Mix-Up",
      "what": "Often finds the correct numbers for a ratio but writes them in the reverse order of what the question asked for.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "mcq",
          "whatWentWrong": "David correctly found the number of men and women but picked the option that showed the ratio of women to men instead."
        },
        {
          "questionRef": "[15]",
          "type": "oeq",
          "whatWentWrong": "He successfully found the correct number of units for blue and white ribbons but wrote the final answer backwards."
        }
      ],
      "strategic_advice": "When you see a question asking for a ratio, treat the word **'to'** as a strict order marker.\n- Highlight or underline the specific items in the question (e.g., **'blue to white'**).\n- Write the letters above your final numbers (e.g., **B : W**) before writing the final answer to ensure they match the requested order.",
      "trigger_keywords": [
        "ratio of",
        "to the number of",
        "ratio of the number of"
      ]
    },
    {
      "name": "Overlapping Area Mix-Up",
      "what": "Tends to add the overlapping part instead of subtracting it when finding the total area of overlapping shapes.",
      "specific_examples": [
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "David correctly found the value of one unit but added the overlapping shaded area to the total instead of subtracting it."
        },
        {
          "questionRef": "[28]",
          "type": "oeq",
          "whatWentWrong": "He did a great job making the units the same but missed that the overlapping part shouldn't be counted twice."
        }
      ],
      "strategic_advice": "When you see overlapping shapes, remember that the overlap is shared by both shapes.\n- If you add the area of both shapes together, you have counted the overlap **twice**.\n- Always **subtract the overlap once** to find the true total area of the whole figure.",
      "trigger_keywords": [
        "overlapping",
        "area of the whole figure",
        "shaded area"
      ]
    },
    {
      "name": "Leaving Questions Blank",
      "what": "Occasionally leaves questions completely blank, missing out on the chance to earn partial marks for his working.",
      "specific_examples": [
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "David left this angles question blank instead of writing down the steps or angles he already knew."
        },
        {
          "questionRef": "[73]",
          "type": "mcq",
          "whatWentWrong": "He skipped this fraction question entirely without selecting an option."
        },
        {
          "questionRef": "[83]",
          "type": "oeq",
          "whatWentWrong": "He left this fraction calculation blank instead of trying to work it out step by step."
        }
      ],
      "strategic_advice": "When you feel stuck on a question, don't leave it completely empty.\n- For open-ended questions, write down **any steps or values** you can figure out (like finding one unit or one angle) to earn partial marks.\n- For multiple-choice questions, always **make your best guess** by eliminating the options you know are wrong.",
      "trigger_keywords": [
        "Find",
        "What is",
        "How much"
      ]
    }
  ],

    {
      "name": "Small Number Slips",
      "what": "Occasionally makes a small addition or subtraction mistake along the way, even when the overall method is set up perfectly.",
      "specific_examples": [
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "Added the decimals incorrectly before dividing to find the mass of each bag."
        },
        {
          "questionRef": "[33]",
          "type": "oeq",
          "whatWentWrong": "Made a small subtraction error when finding the final angle, even though the first step was correct."
        },
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "Set up the units perfectly, but made a calculation error when finding the value of one unit."
        }
      ],
      "strategic_advice": "When you see prompts that require multiple steps, treat them as a signal to double-check your working:\n- **'total mass'** or **'altogether'** → quickly re-add your numbers to be sure.\n- **'find angle'** → check your subtraction from 180 or 360 one more time.",
      "trigger_keywords": [
        "altogether",
        "total",
        "find angle"
      ]
    },
    {
      "name": "Combined Shapes Trap",
      "what": "Tends to include hidden inside edges or overlapping parts when finding the perimeter or area of joined figures.",
      "specific_examples": [
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "Counted 14 sides instead of 13, accidentally including an inside edge of the combined squares."
        },
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "Added the overlapping area instead of subtracting it to find the total area of the figure."
        },
        {
          "questionRef": "[11]",
          "type": "oeq",
          "whatWentWrong": "Used the wrong multiplier for the perimeter, likely counting sides hidden inside the shape."
        }
      ],
      "strategic_advice": "When you see questions about joined or overlapping shapes, use your pencil to trace the outside:\n- **'perimeter of the figure'** → highlight only the outside lines you can touch.\n- **'overlapping'** or **'shaded area'** → remember to subtract the shared part so you don't count it twice.",
      "trigger_keywords": [
        "perimeter of the figure",
        "overlapping",
        "shaded area"
      ]
    },
    {
      "name": "Ratio Order Mix-Up",
      "what": "Sometimes reverses the order of items in a ratio or misreads which fraction belongs to which person.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "mcq",
          "whatWentWrong": "Picked the ratio of women to men instead of men to women."
        },
        {
          "questionRef": "[35]",
          "type": "oeq",
          "whatWentWrong": "Misinterpreted the starting fraction, mixing up how many units belonged to Sam and Paul."
        }
      ],
      "strategic_advice": "When you see ratio or fraction questions, always label your numbers:\n- **'ratio of [A] to [B]'** → write A : B above your numbers to keep them in the right order.\n- **'[A] had 2/5 as much as [B]'** → draw a quick box model to show who gets 2 units and who gets 5.",
      "trigger_keywords": [
        "ratio of",
        "as much as",
        "to the number of"
      ]
    }

{
  "patterns": [
    {
      "name": "State Change Mix-Up",
      "what": "Sometimes confuses the processes of heat gain and heat loss during state changes, or forgets that a substance is still gaining heat even when its temperature is rising.",
      "specific_examples": [
        {
          "questionRef": "[62]",
          "type": "mcq",
          "whatWentWrong": "Kaiyangnggg thought water only gained heat while melting, missing the phases where the temperature was rising."
        },
        {
          "questionRef": "[12]",
          "type": "mcq",
          "whatWentWrong": "He confused water changing from gas to liquid as boiling instead of losing heat to condense."
        }
      ],
      "strategic_advice": "When looking at heating curves or state changes, remember that heat is always moving!\n- **'gaining heat'** → happens when temperature goes up OR when melting/boiling.\n- **'gas to liquid'** → this is condensation, which means the water must be losing heat to cool down.",
      "trigger_keywords": [
        "gaining heat",
        "losing heat",
        "changes from gas to liquid",
        "temperature"
      ]
    },
    {
      "name": "Path of Light Mix-Up",
      "what": "Occasionally reverses the direction of light rays, forgetting that light must bounce off an object and travel into our eyes for us to see it.",
      "specific_examples": [
        {
          "questionRef": "[79]",
          "type": "mcq",
          "whatWentWrong": "Kaiyangnggg picked arrows showing light leaving the eye instead of entering it to see the door."
        },
        {
          "questionRef": "[67]",
          "type": "mcq",
          "whatWentWrong": "He chose the wrong light path for seeing a painting through a hole, forgetting light starts at the source."
        }
      ],
      "strategic_advice": "When you see questions about how we see objects, always draw the path starting from the light source!\n- **'enable Peter to see'** → light goes from the lamp, bounces off the object, and goes INTO the eye.\n- **'direction of light rays'** → the final arrow must always point AT the person's eye, never away from it.",
      "trigger_keywords": [
        "enable to see",
        "direction of light rays",
        "path taken by the light"
      ]
    },
    {
      "name": "Shadow Size Confusion",
      "what": "Tends to mix up how distance affects shadows, occasionally forgetting that objects placed closer to a light source will cast a larger shadow.",
      "specific_examples": [
        {
          "questionRef": "[68]",
          "type": "mcq",
          "whatWentWrong": "Kaiyangnggg mismatched the shapes to their positions based on the shadow size on the screen."
        },
        {
          "questionRef": "[76]",
          "type": "mcq",
          "whatWentWrong": "He struggled to identify which shape was closest to the torch to form the largest part of the shadow."
        }
      ],
      "strategic_advice": "When matching objects to their shadows, use the 'closer is bigger' rule!\n- **'cut out some shapes'** → find the largest part of the shadow on the screen; that shape must be the one closest to the torch.\n- **'same height and width'** → the shape that looks the smallest on the screen is the one furthest away.",
      "trigger_keywords": [
        "cut out some shapes",
        "shadow",
        "screen",
        "torch"
      ]
    },
    {
      "name": "One Step Short",
      "what": "Often correctly identifies what happens in an experiment, but occasionally stops one step short of stating the underlying scientific reason or comparing the key variables.",
      "specific_examples": [
        {
          "questionRef": "[66]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg correctly noted the chocolate expanded and burst, but missed stating that it gained heat and expanded more than the bun."
        },
        {
          "questionRef": "[42]",
          "type": "oeq",
          "whatWentWrong": "He knew more heat energy was needed for the fishballs, but forgot to mention this is because there is more mass to heat up."
        },
        {
          "questionRef": "[65]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg defined boiling by its temperature, but missed mentioning the change in state from liquid to gas."
        }
      ],
      "strategic_advice": "When you see **'explain why'**, always check if you have included the scientific 'because'.\n- **'explain why it burst'** → mention the heat gain AND compare the expansion (e.g., 'expanded more than...').\n- **'how will the time change'** → state the change (increase/decrease) AND link it to a property like mass or volume.",
      "trigger_keywords": [
        "explain why",
        "give a reason",
        "how will the time change"
      ]
    }
  ],

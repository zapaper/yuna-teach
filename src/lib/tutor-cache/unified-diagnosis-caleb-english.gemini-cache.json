  "patterns": [
    {
      "name": "Spelling Slips",
      "what": "Caleb occasionally makes small spelling mistakes when writing out his answers, which costs him marks even when his ideas are perfectly correct.",
      "specific_examples": [
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "He correctly explained why Jared was puzzled, but misspelled 'truly' as 'truely'."
        },
        {
          "questionRef": "[54]",
          "type": "oeq",
          "whatWentWrong": "He captured all the key points about how the author's life changed, but misspelled 'extracurricular' and 'neighbourhood'."
        },
        {
          "questionRef": "[56]",
          "type": "oeq",
          "whatWentWrong": "He knew the correct root word but added an extra 'r', spelling it as 'perservering' instead of 'persevering'."
        }
      ],
      "strategic_advice": "When you finish writing a long answer, take a moment to read it backwards word by word. This helps your brain spot spelling mistakes instead of just reading what you meant to write.",
      "trigger_keywords": [
        "Explain clearly",
        "Rewrite",
        "Editing"
      ]
    },
    {
      "name": "Reported Speech Mix-Up",
      "what": "Caleb sometimes forgets to change time words or accidentally leaves out describing words when changing direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[45]",
          "type": "oeq",
          "whatWentWrong": "He correctly changed the sentence structure but forgot to change 'later' to 'later that day'."
        },
        {
          "questionRef": "[65]",
          "type": "oeq",
          "whatWentWrong": "He successfully transformed the speech but accidentally left out the word 'new' when describing the museum."
        }
      ],
      "strategic_advice": "When you see a reported speech question, use your pencil to circle all the time words (like 'yesterday' or 'later') and describing words in the original quote.\n- **Check off each circled word** as you write your final answer to make sure nothing is left behind.",
      "trigger_keywords": [
        "wanted to know",
        "asked",
        "told"
      ]
    },
    {
      "name": "Cloze Passage Clues",
      "what": "Caleb sometimes picks a word that makes sense for the immediate blank, but doesn't quite fit the surrounding idiom or the overall meaning of the sentence.",
      "specific_examples": [
        {
          "questionRef": "[16]",
          "type": "oeq",
          "whatWentWrong": "He picked 'One' instead of 'Each' for the common phrase 'Each and every one of us'."
        },
        {
          "questionRef": "[33]",
          "type": "oeq",
          "whatWentWrong": "He chose 'from' instead of 'back' for the phrase 'dating as far back as'."
        },
        {
          "questionRef": "[35]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'eaten on the streets' instead of the correct idiom 'eaten on the spot'."
        }
      ],
      "strategic_advice": "When you fill in a blank, always read the whole sentence from start to finish with your word in it.\n- **Look out for common idioms** or phrases that usually go together.\n- **Check the sentences before and after** to make sure your word matches the overall story.",
      "trigger_keywords": [
        "Fill in each blank",
        "suitable word"
      ]
    },
    {
      "name": "Visual Text Fine Print",
      "what": "Caleb occasionally misses small but important details in flyers or posters, such as special conditions or tricky words like 'not' and 'only'.",
      "specific_examples": [
        {
          "questionRef": "[63]",
          "type": "mcq",
          "whatWentWrong": "He missed that the first option claimed you will 'only' learn how to design pretty pancakes, making it the false statement."
        },
        {
          "questionRef": "[66]",
          "type": "mcq",
          "whatWentWrong": "He missed the word 'again' in the question, which meant Mindy was a returning customer entitled to a special discount."
        },
        {
          "questionRef": "[67]",
          "type": "mcq",
          "whatWentWrong": "He chose an option that didn't match the specific instructions given in the flyer for the immersive dining experience."
        }
      ],
      "strategic_advice": "When you read a visual text or its questions, treat it like a detective mission.\n- **Highlight tricky words** like 'not', 'only', 'always', or 'never'.\n- **Look for special conditions** like 'returning customer' or 'early bird' that might change the answer.",
      "trigger_keywords": [
        "not true",
        "biggest savings",
        "According to the website"
      ]
    }
  ],

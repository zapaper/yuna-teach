{
  "patterns": [
    {
      "name": "Stopping Short of Final Consequence",
      "what": "The student correctly explains the underlying reason or mechanism but fails to state the final observable outcome or direct consequence required by the question.",
      "specific_examples": [
        {
          "questionRef": "[46]",
          "type": "oeq",
          "whatWentWrong": "Explained that the body needs less energy and oxygen, but failed to state the final consequence that the breathing rate decreases."
        },
        {
          "questionRef": "[11]",
          "type": "oeq",
          "whatWentWrong": "Explained that melting ice results in less area to rest, but stopped short of stating the final consequence that the polar bears would drown."
        },
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "Stated that the amount of digested food decreased, but stopped short of explaining the final consequence that it was absorbed into the bloodstream."
        }
      ],
      "strategic_advice": "When you see **explain what happened** or **explain how**, always ensure you state the final visible result or action. Do not stop at the hidden mechanism. Use a **so that...** or **resulting in...** clause to connect your scientific reasoning directly to the final consequence.",
      "trigger_keywords": [
        "explain what happened",
        "explain how",
        "describe the changes"
      ]
    },
    {
      "name": "Vague Language Instead of Scientific Terms",
      "what": "The student uses general, everyday language instead of the precise scientific concepts, components, or physiological terms expected.",
      "specific_examples": [
        {
          "questionRef": "[56]",
          "type": "oeq",
          "whatWentWrong": "Used the general phrase 'needs less energy' instead of the specific physiological requirement 'less oxygen and digested food is needed'."
        },
        {
          "questionRef": "[143]",
          "type": "oeq",
          "whatWentWrong": "Stated the control is to 'ensure a fair test' instead of providing the specific scientific purpose 'to show that water level does not decrease due to evaporation'."
        },
        {
          "questionRef": "[29]",
          "type": "oeq",
          "whatWentWrong": "Mentioned 'decomposition' generally but failed to use specific terms like 'decomposers' or 'bacteria' that 'respire' and use up oxygen."
        }
      ],
      "strategic_advice": "When a question asks you to **explain why** or **give a reason**, avoid generic phrases like 'needs less energy' or 'to ensure a fair test'. Always ask yourself if there is a specific **scientific term** (like 'oxygen and digested food', 'decomposers', or 'evaporation') that accurately describes the process.",
      "trigger_keywords": [
        "explain why",
        "give a reason",
        "explain the purpose"
      ]
    },
    {
      "name": "Ignoring Specific Context or Provided Data",
      "what": "The student provides a theoretically correct answer but fails to link it to the specific data, graph, or contextual clues provided in the question stem.",
      "specific_examples": [
        {
          "questionRef": "[50]",
          "type": "oeq",
          "whatWentWrong": "Stated that the heart rate decreased but failed to cite specific evidence from the graph, such as 'after point S'."
        },
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "Gave generic advantages of a nest instead of using the provided context that predator G lives on land and food sources B and C live in water."
        },
        {
          "questionRef": "[141]",
          "type": "oeq",
          "whatWentWrong": "Listed general conditions for fungal growth instead of identifying only the condition specifically tested in the provided experiment."
        }
      ],
      "strategic_advice": "When you see trigger phrases like **based on the graph** or **using the information above**, you must explicitly quote or reference the provided data. Do not just state general facts; show exactly **where in the data** your conclusion comes from.",
      "trigger_keywords": [
        "based on the graph",
        "using the information above",
        "based on the experiment"
      ]
    },
    {
      "name": "Skipping Initial States or Intermediate Steps",
      "what": "The student describes a process or sequence but omits crucial initial conditions, intermediate energy conversions, or specific anatomical pathways.",
      "specific_examples": [
        {
          "questionRef": "[47]",
          "type": "oeq",
          "whatWentWrong": "Described the respiratory system supplying blood with oxygen but skipped the intermediate anatomical steps like 'through the nose' and 'travels to the lungs'."
        },
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "Explained that touching the wire forms a closed circuit but skipped mentioning the initial state of there being a 'gap' or 'open circuit'."
        },
        {
          "questionRef": "[7]",
          "type": "oeq",
          "whatWentWrong": "Explained that a heavier block hits with more force but skipped the intermediate energy conversion step from 'gravitational potential energy' to 'kinetic energy'."
        }
      ],
      "strategic_advice": "When asked to **describe how** or **trace the path**, imagine you are telling a story from the very beginning. Always state the **initial condition** (e.g., 'open circuit') and include every **intermediate step** (e.g., 'travels to the lungs') before reaching the end.",
      "trigger_keywords": [
        "describe how",
        "explain how",
        "trace the path"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "One Step Short",
      "what": "Often explains the middle part of a scientific process beautifully, but occasionally stops just before stating the final result or consequence.",
      "specific_examples": [
        {
          "questionRef": "[3]",
          "type": "oeq",
          "whatWentWrong": "David explains that the metal ball is non-magnetic, but stops before stating the final result that it is 'not attracted to the strong magnet'."
        },
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "He explains that global warming melts the ice, but forgets to state the final consequence that the thin ice 'cannot support the weight' of the polar bears."
        },
        {
          "questionRef": "[61]",
          "type": "oeq",
          "whatWentWrong": "David explains that the heart pumps slower when resting, but misses the final detail that 'less oxygen and digested food' is needed by the muscles."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as a reminder to go all the way to the end:\n- **'explain why'** or **'explain what happened'** → always include a **'so that...'** or **'which means...'** clause to show the final consequence.\n- Double-check if you have answered the specific action the question asked about (e.g., did the rate decrease? did the object move?).",
      "trigger_keywords": [
        "explain why",
        "explain what happened",
        "what is the effect",
        "how does"
      ]
    },
    {
      "name": "Skipping Specific Clues",
      "what": "Tends to give good general scientific answers, but occasionally forgets to link them to the specific names, letters, or data points provided in the question.",
      "specific_examples": [
        {
          "questionRef": "[24]",
          "type": "oeq",
          "whatWentWrong": "David gives a general answer about hiding from predators, instead of using the specific clues in the food web to say it hides from 'predator G which lives on land'."
        },
        {
          "questionRef": "[58]",
          "type": "oeq",
          "whatWentWrong": "He explains the general flow of oxygen and carbon dioxide, but misses specific pathway details required by the question, like 'through the nose' or 'travels to the lungs'."
        },
        {
          "questionRef": "[178]",
          "type": "oeq",
          "whatWentWrong": "David suggests that animals dispersed the seeds, but misses the specific visual clues in the diagram, like the river connecting the two islands."
        }
      ],
      "strategic_advice": "When a question gives you a diagram, a graph, or specific letters (like Organism G or Point S), treat them as mandatory puzzle pieces:\n- **'Based on the graph'** → You must quote a specific point or trend from the graph in your answer.\n- **'Using the food web'** → You must name the specific organisms (e.g., **'predator G'**) and their specific traits shown in the diagram.",
      "trigger_keywords": [
        "based on the graph",
        "using the food web",
        "based on the information",
        "in the diagram"
      ]
    },
    {
      "name": "Graph Reading Slips",
      "what": "Sometimes understands the science perfectly, but occasionally misreads a number from a graph, table, or ruler, or uses the wrong unit.",
      "specific_examples": [
        {
          "questionRef": "[60]",
          "type": "oeq",
          "whatWentWrong": "David writes '6 beats per minute' instead of reading the graph correctly to find '15 breaths per minute'."
        },
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "He counts the peaks over four seconds instead of reading the prompt carefully to count only the 'first two seconds'."
        },
        {
          "questionRef": "[6]",
          "type": "mcq",
          "whatWentWrong": "David misreads the starting and ending points on the ruler, leading to an incorrect calculation of the distance moved by the toy car."
        }
      ],
      "strategic_advice": "When reading graphs, tables, or rulers, try these quick checks:\n- Use your pencil to **trace the line exactly to the axis** to get the right number.\n- Always check the **units** on the axis (e.g., is it **'breaths'** or **'beats'**?).\n- Highlight specific timeframes or conditions in the question (like **'first two seconds'**) so you know exactly where to look in the data.",
      "trigger_keywords": [
        "from the graph",
        "state the number",
        "distance moved",
        "based on the results"
      ]
    }
  ],

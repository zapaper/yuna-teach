{
  "patterns": [
    {
      "name": "Stops Short of Final Consequence",
      "what": "The student identifies an intermediate step or observation but fails to state the underlying scientific mechanism or the final resulting consequence.",
      "specific_examples": [
        {
          "questionRef": "[56]",
          "type": "oeq",
          "whatWentWrong": "Correctly noted the body needed less energy and oxygen, but stopped short of stating the final observation that the breathing rate decreases."
        },
        {
          "questionRef": "[15]",
          "type": "oeq",
          "whatWentWrong": "Suggested using a heavier block, but failed to explain the energy conversion from greater gravitational potential energy to kinetic energy."
        },
        {
          "questionRef": "[50]",
          "type": "oeq",
          "whatWentWrong": "Observed that the amount of digested food decreased, but missed the final consequence that it was absorbed into the bloodstream."
        }
      ],
      "strategic_advice": "When you see **explain why** or **explain how**, use a cause-and-effect chain. Always ask yourself 'so what?' until you reach the final consequence. Ensure you link the scientific concept (e.g., **less oxygen needed**) to the final observation (e.g., **breathing rate decreases**).",
      "trigger_keywords": [
        "Explain why",
        "Explain how",
        "Give a reason"
      ]
    },
    {
      "name": "Ignores Specific Question Data",
      "what": "The student gives a generic, memorised answer instead of extracting specific evidence, names, or values from the provided graphs, tables, or diagrams.",
      "specific_examples": [
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "Gave a generic advantage of hiding from predators, ignoring the specific food web data showing predator G lives on land."
        },
        {
          "questionRef": "[146]",
          "type": "oeq",
          "whatWentWrong": "Described the general trend of fungal growth but failed to use the specific time frame (Day 1 to Day 4) provided in the experiment's data table."
        },
        {
          "questionRef": "[5]",
          "type": "oeq",
          "whatWentWrong": "Described a general increase in length but failed to calculate the specific 2 cm increase using the data provided in the table."
        }
      ],
      "strategic_advice": "When a question says **based on the graph** or **using the information**, you must quote specific data points or names. Do not just write 'predator'; write **predator G on land**. Always pair your scientific concept with **evidence from the diagram**.",
      "trigger_keywords": [
        "Based on the graph",
        "Based on the information",
        "Using the food web",
        "From the results"
      ]
    },
    {
      "name": "Missing Scientific Keywords",
      "what": "The student describes processes in everyday language, omitting mandatory scientific vocabulary, anatomical parts, or the initial state of a system.",
      "specific_examples": [
        {
          "questionRef": "[54]",
          "type": "oeq",
          "whatWentWrong": "Described the respiratory process in general terms but omitted mandatory anatomical keywords like 'through the nose' and 'travels to the lungs'."
        },
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "Correctly identified the exchange of oxygen and carbon dioxide but failed to name the specific scientific processes: 'photosynthesis' and 'respiration'."
        },
        {
          "questionRef": "[25]",
          "type": "oeq",
          "whatWentWrong": "Explained that touching the wire forms a closed circuit, but missed stating the crucial initial state of the system: an 'open circuit'."
        }
      ],
      "strategic_advice": "When asked to **describe how** a system works, use precise scientific vocabulary. Name the specific processes like **photosynthesis** or **respiration**, and specific parts like **lungs** or **nose**. For physics questions, always state the initial condition, such as an **open circuit**, before describing the change.",
      "trigger_keywords": [
        "Describe how",
        "State the function",
        "What process"
      ]
    },
    {
      "name": "Confusing Experimental Variables",
      "what": "The student misidentifies the changed, measured, or constant variables, or gives generic reasons for control setups instead of specific ones.",
      "specific_examples": [
        {
          "questionRef": "[4]",
          "type": "oeq",
          "whatWentWrong": "Incorrectly identified the 'weight of the toy car' as the constant variable instead of the 'type of toy car'."
        },
        {
          "questionRef": "[149]",
          "type": "oeq",
          "whatWentWrong": "Gave a generic 'to ensure a fair test' reason for a control setup, instead of specifying that it proves evaporation didn't cause the water loss."
        },
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "Misidentified the changed variable as 'how polluted the water was' instead of 'the different lakes'."
        }
      ],
      "strategic_advice": "For experimental setups, identify the one thing being tested—that is your **changed variable**. Everything else must be a **constant variable**. When asked about a **control setup**, explain exactly what alternative cause it is ruling out, rather than just writing 'to ensure a fair test'.",
      "trigger_keywords": [
        "fair test",
        "reliable",
        "variable",
        "control",
        "aim of the experiment"
      ]
    }
  ],

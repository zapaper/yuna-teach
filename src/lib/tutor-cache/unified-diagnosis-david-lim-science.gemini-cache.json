{
  "patterns": [
    {
      "name": "Stopping One Step Short",
      "what": "David often understands the core concept perfectly, but occasionally stops just before stating the final scientific consequence or the initial state.",
      "specific_examples": [
        {
          "questionRef": "[3]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified that the iron ball is attracted to the magnet, but stopped short of stating the final consequence: that it changes direction."
        },
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "He correctly noted that melting ice leaves less area for polar bears to rest, but missed the final consequence that they might drown."
        },
        {
          "questionRef": "[59]",
          "type": "oeq",
          "whatWentWrong": "He correctly observed that the heart rate decreased, but stopped short of explaining that the heart pumps slower to transport less oxygen."
        }
      ],
      "strategic_advice": "When you see **'explain why'** or **'describe how'**, try to use a 'Cause -> Process -> Effect' chain. Always ask yourself, **'And so what happens next?'** until you reach the final result. Don't assume the marker knows what you mean; write down every step of the story.",
      "trigger_keywords": [
        "explain why",
        "describe how",
        "what happens"
      ]
    },
    {
      "name": "Generalising Instead of Using Data",
      "what": "David sometimes relies on his excellent general Science knowledge instead of extracting specific clues, names, or data points directly from the diagrams or graphs provided.",
      "specific_examples": [
        {
          "questionRef": "[24]",
          "type": "oeq",
          "whatWentWrong": "He gave a general answer about hiding from predators, instead of using the food web to specifically name 'predator G which lives on land'."
        },
        {
          "questionRef": "[151]",
          "type": "oeq",
          "whatWentWrong": "He listed all the general conditions for fungal growth, rather than identifying only the one condition (warmth) that was actually tested in the experiment."
        },
        {
          "questionRef": "[149]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified the fruit type, but didn't use the specific clues from the diagram (like the river) to explain how it travelled between the islands."
        }
      ],
      "strategic_advice": "When a question says **'based on the graph'** or **'using the diagram'**, it is a big hint! Make sure to **quote specific names** (like 'Predator G'), numbers, or trends directly from the picture before explaining the science. Treat the diagram like a treasure map where the clues must be used in your answer.",
      "trigger_keywords": [
        "based on the graph",
        "using the diagram",
        "from the table",
        "based on the experiment"
      ]
    },
    {
      "name": "Imprecise Experimental Terms",
      "what": "When answering questions about experiments, David tends to use everyday words or generic phrases instead of precise scientific terms for variables and fair tests.",
      "specific_examples": [
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "He used the everyday word 'weight' instead of 'type' of toy car, and suggested repeating the experiment without mentioning the need to calculate the average."
        },
        {
          "questionRef": "[143]",
          "type": "oeq",
          "whatWentWrong": "He suggested a practical change (a dark room) instead of the standard scientific method for reliability, which is to repeat the experiment and calculate the average."
        },
        {
          "questionRef": "[153]",
          "type": "oeq",
          "whatWentWrong": "He gave a generic answer about ensuring a 'fair test', rather than explaining the specific purpose of the control setup (to show water isn't lost to evaporation)."
        }
      ],
      "strategic_advice": "For questions asking about a **'fair test'**, **'reliable'**, or **'control'**, avoid generic answers. Always specify exactly **what is being kept the same**, or state that a control proves the result is **only due to the changed variable**. Remember that 'reliable' usually means **'repeat and calculate the average'**.",
      "trigger_keywords": [
        "fair test",
        "reliable",
        "control",
        "variable",
        "improve the accuracy"
      ]
    },
    {
      "name": "Missing the Connecting Science Words",
      "what": "David occasionally describes a situation perfectly but forgets to include the specific scientific keywords or units that link his ideas together.",
      "specific_examples": [
        {
          "questionRef": "[19]",
          "type": "oeq",
          "whatWentWrong": "He correctly understood that a heavier block hits harder, but missed the specific energy keywords: 'gravitational potential energy' converting to 'kinetic energy'."
        },
        {
          "questionRef": "[60]",
          "type": "oeq",
          "whatWentWrong": "He perfectly explained that the body needed less oxygen, but used the wrong unit ('beats' instead of 'breaths') and forgot to explicitly state that the breathing rate decreases."
        },
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified decomposition as the cause, but missed the connecting scientific keywords that 'decomposers respire' and use up the oxygen."
        }
      ],
      "strategic_advice": "Whenever you are asked to **'explain'** a process, do a quick mental check for **Science vocabulary**. If things are moving, mention **'kinetic energy'**. If plants or animals are involved, check if you need words like **'photosynthesis'** or **'respiration'**. Always double-check your units before moving on!",
      "trigger_keywords": [
        "explain",
        "state the",
        "describe the changes",
        "energy conversion"
      ]
    }
  ],

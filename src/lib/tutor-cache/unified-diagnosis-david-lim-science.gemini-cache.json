{
  "patterns": [
    {
      "name": "Stopping Too Early",
      "what": "Tends to correctly identify the first part of a scientific process, but occasionally stops one step short of stating the final consequence or keyword.",
      "specific_examples": [
        {
          "questionRef": "[10]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified that Animal B helps pollinate the plant, but missed the final steps about fertilisation and seed germination."
        },
        {
          "questionRef": "[35]",
          "type": "oeq",
          "whatWentWrong": "He noted that the block had more gravitational potential energy, but stopped short of explaining that it converts to more kinetic energy."
        },
        {
          "questionRef": "[70]",
          "type": "oeq",
          "whatWentWrong": "He observed that the amount of digested food decreased, but missed stating that it was absorbed into the bloodstream."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as a chain of events:\n- **'explain how'** or **'explain why'** → always ask yourself, **'And then what happens?'** until you reach the final result.\n- Use linking words like **'so that'**, **'which causes'**, or **'resulting in'** to connect your ideas and show the full picture.",
      "trigger_keywords": [
        "explain how",
        "explain why",
        "describe the process"
      ]
    },
    {
      "name": "Skipping the Evidence",
      "what": "Sometimes relies on general scientific facts to answer questions, missing the specific clues, graphs, or data provided in the question.",
      "specific_examples": [
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "He gave general advantages of a nest, missing the specific clues in the question that predator G lives on land and organism E eats food in the water."
        },
        {
          "questionRef": "[88]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified the fruit, but didn't use the data from the diagram to explain how it travelled from one island to the other."
        },
        {
          "questionRef": "[90]",
          "type": "oeq",
          "whatWentWrong": "He listed general conditions for fungus to grow instead of focusing on the specific condition tested in the experiment."
        }
      ],
      "strategic_advice": "When a question includes a **graph, table, or diagram**, treat it as a treasure map. The answer is hidden in the details!\n- Look out for phrases like **'Based on the graph'** or **'Using the information above'**. These are stop signs reminding you to quote specific data.\n- Instead of just giving a general science fact, always tie it back to the specific animals, objects, or numbers in the question.",
      "trigger_keywords": [
        "based on the graph",
        "using the information above",
        "from the results"
      ]
    },
    {
      "name": "Series vs Parallel Mix-Up",
      "what": "Occasionally confuses how to draw or explain parallel circuits compared to series circuits.",
      "specific_examples": [
        {
          "questionRef": "[48]",
          "type": "oeq",
          "whatWentWrong": "He drew two bulbs in a series circuit instead of setting them up in parallel."
        },
        {
          "questionRef": "[54]",
          "type": "oeq",
          "whatWentWrong": "He drew a single series circuit instead of the required parallel arrangement for the toy train."
        },
        {
          "questionRef": "[94]",
          "type": "oeq",
          "whatWentWrong": "He missed the primary advantage of a parallel circuit, which is that if one bulb fuses, the others remain lit."
        }
      ],
      "strategic_advice": "Remember that in a **parallel circuit**, electricity has multiple paths to travel. If one path is broken, the others still work!\n- When drawing a parallel circuit, make sure each bulb has its own direct connection to the battery.\n- Practice tracing the path of electricity with your finger to ensure there are no dead ends.",
      "trigger_keywords": [
        "draw a circuit",
        "advantage of arranging",
        "without dimming"
      ]
    },
    {
      "name": "Heat Transfer Mix-Up",
      "what": "Sometimes mixes up which object is gaining or losing heat, or how heat causes different materials to expand.",
      "specific_examples": [
        {
          "questionRef": "[32]",
          "type": "oeq",
          "whatWentWrong": "He stated that the glass jar expanded more than the plastic lid, instead of the other way around."
        },
        {
          "questionRef": "[97]",
          "type": "oeq",
          "whatWentWrong": "He missed that the uneven expansion between the hot inner wall and cold outer wall is what causes the glass to crack."
        },
        {
          "questionRef": "[101]",
          "type": "oeq",
          "whatWentWrong": "He stated that the cup prevents the cold drink from 'losing heat' instead of 'gaining heat' from the warmer surroundings."
        }
      ],
      "strategic_advice": "Always ask yourself: **'Which object is hotter?'** Heat always travels from the hotter object to the colder one.\n- For cold drinks, remember they don't 'lose coldness'—they **gain heat** from the warmer room!\n- When materials gain heat, they **expand**. When they lose heat, they **contract**. Different materials expand at different rates.",
      "trigger_keywords": [
        "keep it cold",
        "explain why the glass cracked",
        "gained heat"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "One Step Short",
      "what": "David often states the initial cause or the final observation, but occasionally misses the middle steps or the final scientific consequence that links them together.",
      "specific_examples": [
        {
          "questionRef": "[35]",
          "type": "oeq",
          "whatWentWrong": "He correctly suggested using a heavier block, but missed explaining that it has more gravitational potential energy which converts to more kinetic energy."
        },
        {
          "questionRef": "[74]",
          "type": "oeq",
          "whatWentWrong": "He correctly stated that the respiratory system takes in oxygen and releases carbon dioxide, but missed stating that this is 'for survival' and the specific pathway through the nose to the lungs."
        },
        {
          "questionRef": "[225]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified the relationship between the lamp's distance and the cloth's mass, but missed explaining the middle steps about temperature and evaporation rate."
        }
      ],
      "strategic_advice": "When you see **'explain why'** or **'explain how'**, treat it as a chain reaction. Use words like **'which causes...'** or **'resulting in...'** to connect your ideas until you reach the final result.",
      "trigger_keywords": [
        "Explain why",
        "Explain how",
        "Describe how"
      ]
    },
    {
      "name": "Ignoring Given Clues",
      "what": "David sometimes relies on his general knowledge to answer questions, occasionally forgetting to use the specific clues, graphs, or tables provided in the question.",
      "specific_examples": [
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "He gave a general reason about hiding from predators, instead of using the provided food web to specify that predator G lives on land."
        },
        {
          "questionRef": "[75]",
          "type": "oeq",
          "whatWentWrong": "He correctly noted that Mirabel's heart rate decreased, but missed using the specific evidence from the graph, such as 'after point S'."
        },
        {
          "questionRef": "[215]",
          "type": "oeq",
          "whatWentWrong": "He listed general conditions for fungus to grow (moisture, oxygen, warmth) instead of only stating the one condition (warmth) tested in that specific experiment."
        }
      ],
      "strategic_advice": "When a question says **'Based on the graph'** or **'Using the information above'**, treat it as a treasure hunt. You must include specific details from the picture or table in your answer, not just what you already know.",
      "trigger_keywords": [
        "Based on the graph",
        "Using the information above",
        "Based on the experiment",
        "From the graph"
      ]
    },
    {
      "name": "Breaths vs Beats Mix-Up",
      "what": "David occasionally confuses the respiratory system (breathing) with the circulatory system (heartbeat), mixing up their units and functions.",
      "specific_examples": [
        {
          "questionRef": "[76]",
          "type": "oeq",
          "whatWentWrong": "When asked for Linda's normal breathing rate, he wrote '6 beats per minute' instead of calculating the breaths per minute."
        },
        {
          "questionRef": "[146]",
          "type": "oeq",
          "whatWentWrong": "He again used 'beats per minute' for a breathing rate question and referred to the 'pump' (heart) instead of the lungs."
        }
      ],
      "strategic_advice": "When you see questions about exercise, pause and check which system is being asked about:\n- **'Breathing rate'** → lungs, oxygen, and **'breaths per minute'**\n- **'Heart rate'** → heart, pumping blood, and **'beats per minute'**",
      "trigger_keywords": [
        "breathing rate",
        "heart rate",
        "beats per minute",
        "breaths per minute"
      ]
    },
    {
      "name": "Everyday Words Trap",
      "what": "David tends to describe his answers using everyday words, occasionally missing the specific scientific terms or variables required for full marks.",
      "specific_examples": [
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "He identified the 'width' of the metal strip as the changed variable instead of the 'surface area'."
        },
        {
          "questionRef": "[24]",
          "type": "oeq",
          "whatWentWrong": "He suggested keeping the 'weight' of the toy car constant instead of the 'type' of toy car."
        },
        {
          "questionRef": "[60]",
          "type": "oeq",
          "whatWentWrong": "He stated the changed variable was 'how polluted the water was' instead of 'the different lakes'."
        }
      ],
      "strategic_advice": "When asked to name a variable, try to use precise Science words. Instead of 'weight' or 'width', think if words like **'mass'**, **'surface area'**, or **'type of material'** fit better.",
      "trigger_keywords": [
        "variable",
        "kept constant",
        "changed variable"
      ]
    }
  ],

  "patterns": [
    {
      "name": "Ratio Order Mix-Up",
      "what": "Sometimes works out the correct numbers for a ratio but writes them down in the reverse order.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "mcq",
          "whatWentWrong": "David correctly found the number of men and women, but picked the option for women to men instead of men to women."
        },
        {
          "questionRef": "[15]",
          "type": "oeq",
          "whatWentWrong": "He successfully found the number of blue and white ribbons, but wrote the final ratio as white to blue."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "David did all the hard work to find the parts for each colour, but swapped the final two numbers around."
        }
      ],
      "strategic_advice": "When you see a question asking for a ratio, treat the word **'to'** as a strict matching rule:\n- Highlight the two items asked for in the final question (e.g., **'blue to white'**).\n- Write the letters above your final numbers to check they match the exact order requested before moving on.",
      "trigger_keywords": [
        "ratio of the number of",
        "to the number of",
        "What is the ratio"
      ]
    },
    {
      "name": "Double Counting Overlaps",
      "what": "Occasionally adds the overlapping shaded area when finding the total size of combined shapes, instead of subtracting it.",
      "specific_examples": [
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "David correctly found the value of one unit, but added the overlapping area to the total instead of subtracting it."
        },
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "He adjusted the ratios perfectly to match the shaded area, but then added all the parts together, counting the overlap twice."
        },
        {
          "questionRef": "[50]",
          "type": "oeq",
          "whatWentWrong": "David showed great understanding to find the common unit, but missed that the overlapping part needs to be taken away from the total."
        }
      ],
      "strategic_advice": "When shapes overlap, remember that the shared area is counted once in Shape A and once in Shape B.\n- When finding the **'whole figure'**, always add the two shapes together and then **subtract the overlap** once so it isn't counted twice.\n- Try shading the overlap in a different colour to remind yourself it's a shared space.",
      "trigger_keywords": [
        "overlapping",
        "whole figure",
        "shaded area"
      ]
    },
    {
      "name": "Small Calculation Slips",
      "what": "Occasionally makes small addition or subtraction slips in the middle of a problem, even when the overall method is completely correct.",
      "specific_examples": [
        {
          "questionRef": "[66]",
          "type": "oeq",
          "whatWentWrong": "David knew exactly how to add the weights and divide by four, but made a small slip when adding the decimals together."
        },
        {
          "questionRef": "[67]",
          "type": "oeq",
          "whatWentWrong": "He correctly found the first hidden angle, but made a small subtraction error when finding the final angle."
        },
        {
          "questionRef": "[77]",
          "type": "oeq",
          "whatWentWrong": "David showed the right steps to find the mass of each bag, but a tiny addition slip at the start threw off the final answer."
        }
      ],
      "strategic_advice": "When working with decimals or multiple steps, a small slip can hide in the middle of great working.\n- **Line up your decimal dots** neatly when adding numbers like 2.7, 3.4, and 5.02.\n- Do a quick **reverse check** (like adding your answer back up) to catch any small subtraction slips before moving to the next step.",
      "trigger_keywords": [
        "weighing",
        "Find ∠",
        "repacked them equally"
      ]
    }

{
  "patterns": [
    {
      "name": "Question Tag Mix-Ups",
      "what": "Sometimes picks the wrong helping verb or forgets to switch between positive and negative when forming question tags.",
      "specific_examples": [
        {
          "questionRef": "[90]",
          "type": "mcq",
          "whatWentWrong": "David picked 'doesn't she' instead of 'hasn't she', missing that 'She's set' is short for 'She has set'."
        },
        {
          "questionRef": "[104]",
          "type": "mcq",
          "whatWentWrong": "David chose 'did he' instead of 'has he', forgetting to match the helping verb 'has' from the main sentence."
        },
        {
          "questionRef": "[129]",
          "type": "mcq",
          "whatWentWrong": "David selected the negative tag 'doesn't' even though the sentence already contained the negative word 'never'."
        }
      ],
      "strategic_advice": "When you see a comma followed by a short question at the end of a sentence, it's a question tag.\n- **Check the main verb**: If the sentence uses 'has', the tag must use 'has' (not 'does' or 'did').\n- **Flip the positive/negative**: If the sentence is positive ('He has'), the tag must be negative ('hasn't he?'). If the sentence has a negative word like 'never', the tag must be positive!\n- **Watch out for contractions**: 'She's set' means 'She has set', so the tag should be 'hasn't she?'.",
      "trigger_keywords": [
        "?,",
        "never",
        "hasn't",
        "doesn't",
        "did he"
      ]
    },
    {
      "name": "Singular and Plural Matches",
      "what": "Occasionally mixes up singular and plural forms when matching a verb to its subject or choosing the right noun.",
      "specific_examples": [
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "David wrote 'has' instead of 'have', missing that the subject 'all the students' is plural."
        },
        {
          "questionRef": "[135]",
          "type": "mcq",
          "whatWentWrong": "David picked the singular verb 'signs', but the phrase 'students who' requires the plural verb 'sign'."
        },
        {
          "questionRef": "[160]",
          "type": "oeq",
          "whatWentWrong": "David wrote the singular noun 'enthusiast' even though the word 'fellow' and the context point to a plural group."
        }
      ],
      "strategic_advice": "When you are filling in a verb or a noun, always check how many people or things are involved.\n- **Find the true subject**: In phrases like 'one of the students', the subject is 'one' (singular), so the verb must be singular (e.g., 'signs', not 'sign').\n- **Check for plural clues**: Words like 'both', 'all', or 'fellow' mean you need a plural noun (e.g., 'enthusiasts', not 'enthusiast').\n- **Match the pronouns**: If the subject is plural like 'the children', the reflexive pronoun must be plural too ('themselves', not 'herself').",
      "trigger_keywords": [
        "one of the",
        "both",
        "neither",
        "fellow",
        "all"
      ]
    },
    {
      "name": "Keeping the Exact Meaning",
      "what": "Tends to accidentally change the original meaning in transformation questions by swapping words, altering the time, or replacing specific words.",
      "specific_examples": [
        {
          "questionRef": "[48]",
          "type": "oeq",
          "whatWentWrong": "David wrote 'had wanted to go' instead of 'had gone', which changes the meaning from an action that happened to just a desire."
        },
        {
          "questionRef": "[53]",
          "type": "oeq",
          "whatWentWrong": "David accidentally reversed the order of the activities, making it sound like his mother prefers public transport over driving."
        },
        {
          "questionRef": "[185]",
          "type": "oeq",
          "whatWentWrong": "David misread 'farmer' as 'father', which completely changes who grew the plot of corn."
        }
      ],
      "strategic_advice": "When rewriting sentences, your goal is to keep the exact same message as the original without adding or losing details.\n- **Check the time and pronouns**: If the original says 'last weekend', use 'the previous weekend', not 'the previous week'. Make sure 'he' and 'she' match the right people!\n- **Don't swap preferences**: If the original says 'likes to drive more', make sure your new sentence shows a preference for driving, not public transport.\n- **Copy carefully**: Double-check that you haven't accidentally changed words like 'farmer' to 'father' or 'completing' to 'finishing'.",
      "trigger_keywords": [
        "prefers",
        "told",
        "asked",
        "Instead of",
        "No matter"
      ]
    },
    {
      "name": "Idioms and Context Clues",
      "what": "Sometimes chooses a word that makes basic sense but misses the specific idiom or the deeper context of the sentence.",
      "specific_examples": [
        {
          "questionRef": "[46]",
          "type": "oeq",
          "whatWentWrong": "David wrote 'join suit' instead of the correct English idiom 'follow suit'."
        },
        {
          "questionRef": "[83]",
          "type": "oeq",
          "whatWentWrong": "David used the phrase 'in great description' rather than the natural expression 'in great detail'."
        },
        {
          "questionRef": "[214]",
          "type": "oeq",
          "whatWentWrong": "David wrote 'go down in the knees', missing the common idiom 'go weak in the knees' to show overwhelming emotion."
        }
      ],
      "strategic_advice": "When you are choosing a word for a blank, look closely at the words right before and after it.\n- **Watch for idioms**: Phrases like 'follow suit', 'in great detail', or 'weak in the knees' have fixed words that cannot be swapped.\n- **Read the whole sentence for clues**: If the passage talks about a 'sweet fragrance', you need a word like 'give off' (produce a smell) rather than 'give away' (give a gift).\n- **Check the exact meaning**: Even if a word sounds okay, make sure it fits the specific situation perfectly.",
      "trigger_keywords": [
        "suit",
        "detail",
        "knees",
        "fragrance",
        "word of"
      ]
    }
  ],

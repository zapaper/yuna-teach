{
  "patterns": [
    {
      "name": "Reported Speech Mix-Up",
      "what": "Sometimes forgets to shift pronouns, time words, or tenses correctly when changing direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[65]",
          "type": "oeq",
          "whatWentWrong": "David forgot to change the pronoun to match the speaker, writing 'he' instead of 'she'."
        },
        {
          "questionRef": "[118]",
          "type": "oeq",
          "whatWentWrong": "He changed 'last weekend' to 'the previous week' instead of 'the previous weekend'."
        }
      ],
      "strategic_advice": "When you see prompts like **'asked'** or **'wanted to know'**, treat them as a checklist:\n- **Pronouns** → check who is talking to whom (e.g., change 'I' to 'he' or 'she')\n- **Time words** → shift words like 'yesterday' to **'the previous day'**\n- **Tense** → take one step back in time (e.g., 'is' becomes 'was')",
      "trigger_keywords": [
        "asked",
        "wanted to know",
        "told"
      ]
    },
    {
      "name": "Question Tag Confusion",
      "what": "Occasionally uses the wrong helping verb or forgets to swap positive for negative when forming question tags.",
      "specific_examples": [
        {
          "questionRef": "[119]",
          "type": "mcq",
          "whatWentWrong": "David used 'doesn't she' instead of matching the helping verb 'has' to make 'hasn't she'."
        },
        {
          "questionRef": "[124]",
          "type": "mcq",
          "whatWentWrong": "He missed the hidden negative word 'never', which means the question tag should be positive ('does she')."
        }
      ],
      "strategic_advice": "When you need to add a question tag at the end of a sentence, follow these two steps:\n- **Find the helping verb** → if the sentence uses 'has', the tag must use 'has'\n- **Flip the positive/negative** → if the sentence is positive, the tag must be negative (and vice versa)\n- Watch out for hidden negative words like **'never'** or **'rarely'** — they make the sentence negative!",
      "trigger_keywords": [
        "isn't it",
        "hasn't she",
        "does he",
        "didn't they"
      ]
    },
    {
      "name": "Changing the Meaning",
      "what": "Tends to accidentally change the original meaning of a sentence by leaving out small details, swapping words, or reversing preferences.",
      "specific_examples": [
        {
          "questionRef": "[2]",
          "type": "oeq",
          "whatWentWrong": "David accidentally reversed the preference, saying Mr Tan preferred teh over kopi instead of the other way around."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "He left out the phrase 'in the class', which slightly changed the meaning of the original sentence."
        },
        {
          "questionRef": "[214]",
          "type": "oeq",
          "whatWentWrong": "He accidentally wrote 'father' instead of 'farmer', which changed who grew the corn."
        }
      ],
      "strategic_advice": "When rewriting a sentence, your goal is to keep the exact same message as the original.\n- **Double-check preferences** → make sure you don't accidentally swap what the person likes more\n- **Keep all the details** → don't drop small phrases like 'in the class' or 'daily'\n- **Read both sentences back-to-back** to make sure they tell the exact same story.",
      "trigger_keywords": [
        "preference",
        "except",
        "due to",
        "both"
      ]
    },
    {
      "name": "Spelling by Ear",
      "what": "Sometimes spells tricky words exactly how they sound, which leads to creative but incorrect spellings.",
      "specific_examples": [
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "David spelled 'required' as 'rekwired', writing it exactly as it sounds."
        },
        {
          "questionRef": "[189]",
          "type": "oeq",
          "whatWentWrong": "He spelled 'enthusiasts' as 'enthoosyasts', sounding out each syllable."
        },
        {
          "questionRef": "[240]",
          "type": "oeq",
          "whatWentWrong": "He spelled 'restaurant' as 'restrawnt', matching the way it is spoken."
        }
      ],
      "strategic_advice": "Sounding out words is a great first step, but English spelling can be tricky!\n- When you learn a new word, try to **break it into syllables** and memorise the tricky parts.\n- If a word looks a bit strange after you write it, try writing it a few different ways on scrap paper to see which one looks right.\n- Read widely to help your brain take a 'mental photograph' of how words are spelled.",
      "trigger_keywords": [
        "spelling",
        "editing",
        "passage"
      ]
    }
  ],

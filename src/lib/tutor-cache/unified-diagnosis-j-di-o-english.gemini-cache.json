  "patterns": [
    {
      "name": "Singular or Plural Mix-Up",
      "what": "J=di sometimes gets tricked by special phrases like 'One of', 'Neither of', or 'Either... or', choosing a plural verb when a singular one is needed.",
      "specific_examples": [
        {
          "questionRef": "[46]",
          "type": "mcq",
          "whatWentWrong": "He saw 'boys' and picked the plural 'have', forgetting that 'One of' makes the subject singular."
        },
        {
          "questionRef": "[54]",
          "type": "mcq",
          "whatWentWrong": "He picked the plural 'were', but uncountable nouns like 'furniture' always take a singular verb."
        },
        {
          "questionRef": "[1]",
          "type": "mcq",
          "whatWentWrong": "He picked the singular 'is', but for 'Either... or', the verb must match the noun closest to it (parents)."
        }
      ],
      "strategic_advice": "When you see these tricky subjects, pause and check the rules:\n- **'One of'** or **'Neither of'** → the subject is singular (just one!), so use 'has' or 'is'.\n- **'Either A or B'** → look at the noun closest to the blank to decide.\n- Uncountable nouns like **'furniture'** and **'luggage'** are always treated as singular.",
      "trigger_keywords": [
        "One of",
        "Neither of",
        "Either",
        "furniture",
        "luggage"
      ]
    },
    {
      "name": "Past vs Present Mix-Up",
      "what": "J=di occasionally misses time clues in the sentence, mixing up past and present tenses, especially when describing actions that have been happening for a while.",
      "specific_examples": [
        {
          "questionRef": "[60]",
          "type": "mcq",
          "whatWentWrong": "He picked 'had been practising' (past), but clues like 'am sure' and 'upcoming' show the action is still happening in the present."
        },
        {
          "questionRef": "[59]",
          "type": "mcq",
          "whatWentWrong": "He picked 'have played' (present), but the clue 'were exhausted' means the playing happened even earlier in the past."
        }
      ],
      "strategic_advice": "Always hunt for **time clues** before choosing a tense:\n- If the sentence has present-tense clues like 'am sure' or 'can', use **'have been'**.\n- If the sentence is already in the past (like 'were exhausted'), use **'had been'** to show an action that happened even earlier.",
      "trigger_keywords": [
        "every day",
        "before",
        "upcoming",
        "were",
        "am"
      ]
    },
    {
      "name": "Spelling Slips",
      "what": "J=di occasionally misspells longer words by swapping vowels or getting confused by double letters.",
      "specific_examples": [
        {
          "questionRef": "[6]",
          "type": "oeq",
          "whatWentWrong": "He spelled it 'emergancies' instead of 'emergencies'."
        },
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "He swapped a vowel, writing 'benifit' instead of 'benefit'."
        },
        {
          "questionRef": "[27]",
          "type": "oeq",
          "whatWentWrong": "He added an extra 'h', writing 'strenghthens' instead of 'strengthens'."
        }
      ],
      "strategic_advice": "When writing longer words, break them into **smaller syllables** (e.g., e-mer-gen-cies, ben-e-fit) to hear the vowels clearly. When checking your work, try reading the word backwards letter by letter to spot mistakes!",
      "trigger_keywords": []
    },
    {
      "name": "Phrasal Verb Mix-Up",
      "what": "J=di sometimes confuses phrasal verbs that look similar but have very different meanings.",
      "specific_examples": [
        {
          "questionRef": "[12]",
          "type": "mcq",
          "whatWentWrong": "He picked 'fell apart' instead of 'fell out' to describe friends having a misunderstanding."
        },
        {
          "questionRef": "[22]",
          "type": "mcq",
          "whatWentWrong": "He picked 'blew up' instead of 'fell through' to describe plans that were cancelled."
        }
      ],
      "strategic_advice": "When learning new vocabulary, try to learn the **phrasal verb as a whole chunk** rather than just the first word. Create a mini-dictionary of common phrasal verbs (like 'fall out' vs 'fall through') and draw a quick picture next to each to remember the difference.",
      "trigger_keywords": [
        "fell",
        "call",
        "blew"
      ]
    }

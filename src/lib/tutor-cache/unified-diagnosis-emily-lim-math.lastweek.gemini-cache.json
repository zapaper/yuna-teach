  "patterns": [
    {
      "name": "Turning Direction Mix-Up",
      "what": "Sometimes calculates the turn in the opposite direction, mixing up clockwise and anti-clockwise.",
      "specific_examples": [
        {
          "questionRef": "[19]",
          "type": "mcq",
          "whatWentWrong": "Emily needed to find the anti-clockwise turn from south-west to east, but she picked the clockwise angle instead."
        },
        {
          "questionRef": "[22]",
          "type": "mcq",
          "whatWentWrong": "She faced a similar compass question and again picked 225°, showing a small mix-up with the turning direction."
        }
      ],
      "strategic_advice": "When you see **'anti-clockwise'** or **'clockwise'**, draw a quick clock face on the page.\n- **'clockwise'** → draw an arrow the way the hands move\n- **'anti-clockwise'** → draw an arrow backwards\nAlways trace the path with your pencil before counting the angles.",
      "trigger_keywords": [
        "anti-clockwise",
        "clockwise",
        "turns through an angle",
        "facing"
      ]
    },
    {
      "name": "Line Naming Slips",
      "what": "Tends to add an extra letter like 'L' when naming lines, which makes the final answer incorrect.",
      "specific_examples": [
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "Emily correctly spotted the perpendicular lines but wrote 'LWX' instead of just 'WX', which cost her the mark."
        },
        {
          "questionRef": "[65]",
          "type": "oeq",
          "whatWentWrong": "She wrote 'ABLAE' instead of clearly naming the two lines, which made it hard for the marker to see her great thinking."
        }
      ],
      "strategic_advice": "When you see **'name a pair'** of lines, remember that a straight line is named using exactly two letters.\n- Double-check that you haven't accidentally added an extra letter or symbol.\n- For example, write **'WX'** instead of **'LWX'**.",
      "trigger_keywords": [
        "perpendicular lines",
        "parallel lines",
        "name a pair"
      ]
    },
    {
      "name": "Copying Numbers Wrong",
      "what": "Tends to accidentally drop a digit when copying numbers from the question text into the working steps.",
      "specific_examples": [
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "Emily set up the time addition perfectly, but accidentally wrote down '2 h 4 min' instead of the '2 h 24 min' given in the question."
        },
        {
          "questionRef": "[36]",
          "type": "oeq",
          "whatWentWrong": "She knew exactly how to solve the problem, but a small slip in copying the movie's duration led to the wrong final time."
        }
      ],
      "strategic_advice": "When a question gives you several numbers, treat them as precious cargo.\n- **Underline or circle** the numbers in the question first.\n- After writing down your first step, look back at the question to **double-check** you copied the exact same numbers.",
      "trigger_keywords": [
        "started at",
        "watched the movie for",
        "arrived at"
      ]
    },
    {
      "name": "Unit Mix-Up",
      "what": "Occasionally leaves out the degree symbol for angles or confuses the units for area and volume.",
      "specific_examples": [
        {
          "questionRef": "[61]",
          "type": "oeq",
          "whatWentWrong": "Emily did all the angle calculations beautifully but forgot to add the little degree symbol at the end."
        },
        {
          "questionRef": "[62]",
          "type": "oeq",
          "whatWentWrong": "She correctly found the area of the square but accidentally wrote 'cm³' (which is for volume) instead of 'cm²'."
        }
      ],
      "strategic_advice": "When you reach your final answer, always do a quick 'unit check'.\n- If you found an angle, make sure you include the **degree symbol (°)**.\n- If you found an area, remember to use **square units (like cm²)** instead of volume units (like cm³).",
      "trigger_keywords": [
        "find ∠",
        "area of the square",
        "perimeter"
      ]
    }

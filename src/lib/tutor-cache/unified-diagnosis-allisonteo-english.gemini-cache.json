  "patterns": [
    {
      "name": "Singular Plural Mix-Up",
      "what": "Occasionally confuses whether a subject is singular or plural, especially with tricky words like 'Neither' or activities ending in '-ing'.",
      "specific_examples": [
        {
          "questionRef": "[31]",
          "type": "mcq",
          "whatWentWrong": "Chose the plural verb 'attend' instead of the singular 'attends' for the pronoun 'Neither'."
        },
        {
          "questionRef": "[41]",
          "type": "mcq",
          "whatWentWrong": "Chose the plural verb 'help' instead of the singular 'helps' for the activity 'reading'."
        },
        {
          "questionRef": "[28]",
          "type": "oeq",
          "whatWentWrong": "Wrote the singular 'enthusiast' instead of the plural 'enthusiasts' when referring to a group of people."
        }
      ],
      "strategic_advice": "When you see tricky subjects, take a moment to check if they are singular or plural:\n- **'Neither' or 'Either'** → always treat these as singular subjects.\n- **Activities ending in '-ing'** (like 'reading') → treat the activity as a single thing, so use a singular verb.\n- **'Fellow' or 'group' words** → check if the sentence is talking about one person or many people.",
      "trigger_keywords": [
        "Neither",
        "Either",
        "-ing",
        "fellow"
      ]
    },
    {
      "name": "Verb Form Mix-Up",
      "what": "Tends to mix up past, present, and perfect verb forms, or occasionally uses incorrect forms of irregular verbs.",
      "specific_examples": [
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "Used 'begun' instead of the simple past tense 'began'."
        },
        {
          "questionRef": "[13]",
          "type": "oeq",
          "whatWentWrong": "Wrote 'becomed' instead of the correct irregular past participle 'become'."
        },
        {
          "questionRef": "[38]",
          "type": "oeq",
          "whatWentWrong": "Wrote 'had underwent' instead of the correct past perfect form 'had undergone'."
        }
      ],
      "strategic_advice": "When you need to fill in or change a verb, look for clues about the timeline:\n- **'had' or 'have'** → this is a signal to use the past participle form (like 'undergone' instead of 'underwent').\n- **Irregular verbs** → remember that some verbs don't follow the '-ed' rule (like 'become' instead of 'becomed').\n- **Read the whole sentence** → check if the action happened in the past, is happening now, or is a completed action.",
      "trigger_keywords": [
        "had",
        "have",
        "yesterday",
        "since"
      ]
    },
    {
      "name": "One Step Short",
      "what": "Sometimes captures the first part of a comprehension answer but stops before including the second required point or consequence.",
      "specific_examples": [
        {
          "questionRef": "[7]",
          "type": "oeq",
          "whatWentWrong": "Mentioned being reminded of the advice, but missed explaining how the writer actually applied it to her job."
        },
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "Correctly identified that the writer felt she didn't guide Timmy well, but missed the second point about feeling burdened by expectations."
        },
        {
          "questionRef": "[24]",
          "type": "oeq",
          "whatWentWrong": "Stated that the writer wanted to make amends, but missed the core reason that she felt guilty for failing her parents."
        }
      ],
      "strategic_advice": "When you see prompts that ask for an explanation or multiple points, treat them as stop signs:\n- **'Explain fully' or 'Explain clearly'** → always check if there is a cause and an effect, or a 'so that...' consequence.\n- **'In what ways'** → the plural 'ways' is a big hint that you need to find more than one point in the passage.\n- **Double-check the marks** → a 2-mark question usually needs two distinct pieces of information.",
      "trigger_keywords": [
        "Explain fully",
        "Explain clearly",
        "In what ways",
        "Why"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "Volume vs Level Mix-Up",
      "what": "Sometimes confuses the water level rising with the actual volume of the water increasing when an object is placed in it.",
      "specific_examples": [
        {
          "questionRef": "[9]",
          "type": "oeq",
          "whatWentWrong": "Emily thought the volume of the water itself would increase when a cup was pushed in, confusing it with the water level rising."
        },
        {
          "questionRef": "[22]",
          "type": "oeq",
          "whatWentWrong": "She stated the water level would increase, but the question specifically asked about the volume of the water, which remains the same."
        },
        {
          "questionRef": "[49]",
          "type": "oeq",
          "whatWentWrong": "Emily explained that the plastic cup occupies space, but missed the key concept that water has a definite volume."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs:\n- **'volume of water'** → remember that the actual amount of water **remains the same** because water has a definite volume.\n- **'water level'** → this is what increases when an object is pushed in, because the object takes up space.",
      "trigger_keywords": [
        "volume of water",
        "water level",
        "pushed into a basin",
        "decrease, increase or remain the same"
      ]
    },
    {
      "name": "Forgetting Hidden Air",
      "what": "Tends to identify the obvious solid objects in a container but occasionally forgets that air (a gas) is also present in the empty spaces.",
      "specific_examples": [
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "Emily correctly identified that the pebbles are solid, but forgot that air (a gas) fills the empty spaces between them."
        },
        {
          "questionRef": "[28]",
          "type": "oeq",
          "whatWentWrong": "She spotted the solid state of matter but missed the invisible gas hiding in the gaps of the container."
        },
        {
          "questionRef": "[51]",
          "type": "oeq",
          "whatWentWrong": "Emily named 'solid' for the pebbles but didn't mention the 'gas' that takes up the remaining space."
        }
      ],
      "strategic_advice": "When you see a container filled with solid objects like pebbles, marbles, or coins, remember that they don't fit together perfectly! There are always gaps between them. Ask yourself: **'What is filling the empty spaces?'** The answer is usually **air (a gas)**.",
      "trigger_keywords": [
        "filled a container",
        "pebbles",
        "state(s) of matter",
        "inside the container"
      ]
    },
    {
      "name": "Intestine Jobs Mix-Up",
      "what": "Occasionally mixes up the jobs of the small and large intestines, such as thinking the small intestine absorbs water from undigested food.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "oeq",
          "whatWentWrong": "Emily wrote that the small intestine absorbs water from undigested food, which is actually the large intestine's job."
        },
        {
          "questionRef": "[30]",
          "type": "oeq",
          "whatWentWrong": "She mixed up the order of the intestines and assigned the large intestine's water-absorbing role to the small intestine."
        }
      ],
      "strategic_advice": "When you see questions about the digestive system, remember the special jobs of these two organs:\n- **'small intestine'** → this is where digestion finishes and where **digested food is absorbed** into the blood.\n- **'large intestine'** → no digestion happens here! Its only job is to **absorb water** from the leftover waste.",
      "trigger_keywords": [
        "function of part",
        "absorb water",
        "undigested food",
        "digestive system"
      ]
    },
    {
      "name": "Stopping Too Early",
      "what": "Often starts explanations beautifully but sometimes stops one step short of stating the final result or giving the required number of examples.",
      "specific_examples": [
        {
          "questionRef": "[6]",
          "type": "oeq",
          "whatWentWrong": "Emily correctly noted that iron and steel are magnetic, but stopped one step short of explaining that they would both be attracted and fall into the same container."
        },
        {
          "questionRef": "[57]",
          "type": "oeq",
          "whatWentWrong": "She provided one great difference between the butterfly stages, but the question asked for two."
        },
        {
          "questionRef": "[73]",
          "type": "oeq",
          "whatWentWrong": "Emily beautifully explained that chewing creates a greater surface area, but forgot to add the final result: that the food gets digested faster."
        }
      ],
      "strategic_advice": "When you see these prompts, make sure to complete the journey:\n- **'explain why'** or **'explain how'** → after writing your first thought, add a **'so that...'** or **'which means...'** to show the final result (like 'so digestion is faster').\n- **'state two differences'** → double-check your answer to ensure you have written both points!",
      "trigger_keywords": [
        "explain why",
        "explain how",
        "state two differences"
      ]
    }
  ],

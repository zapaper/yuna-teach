{
  "patterns": [
    {
      "name": "Spelling by Sound",
      "what": "Sometimes spells tricky words exactly how they sound instead of using their proper spelling rules.",
      "specific_examples": [
        {
          "questionRef": "[42]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 spelled 'restaurant' as 'restrawnt' by sounding it out."
        },
        {
          "questionRef": "[71]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 wrote 'deckaide' instead of 'decade' based on how the vowels sound."
        },
        {
          "questionRef": "[89]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 spelled 'squeal' as 'skweel' by following the phonetic sounds."
        }
      ],
      "strategic_advice": "When you encounter a tricky word, try to break it down into its **syllables** or look for **root words** you already know.\n- **Read more widely** to expose yourself to the correct spelling of complex words.\n- Keep a **personal spelling list** of words you often misspell and practice them.",
      "trigger_keywords": [
        "spelling",
        "editing",
        "correct word"
      ]
    },
    {
      "name": "Missing the Bigger Picture",
      "what": "Tends to fill in blanks with words that make sense for that specific line, but occasionally contradict the sentences that come right before or after.",
      "specific_examples": [
        {
          "questionRef": "[115]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 chose 'shortest' for the queue, missing the next sentence's clue that a long queue means good quality."
        },
        {
          "questionRef": "[66]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 wrote 'money' instead of 'earlier', missing the time contrast with 'remaining days' later in the sentence."
        },
        {
          "questionRef": "[45]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 guessed 'reduced' for delays, missing the author's overall point that great things take a long time."
        }
      ],
      "strategic_advice": "When you see a blank, treat the **whole paragraph** as a clue, not just the sentence it is in.\n- **Read past the blank** to the end of the paragraph before deciding on your answer.\n- Look out for **transition words** like 'However', 'Since', or 'Because' that tell you how the ideas connect.",
      "trigger_keywords": [
        "fill in each blank",
        "comprehension cloze",
        "passage"
      ]
    },
    {
      "name": "Verb Form Mix-Ups",
      "what": "Occasionally uses the wrong verb tense or forgets to match the verb to a singular or plural subject.",
      "specific_examples": [
        {
          "questionRef": "[98]",
          "type": "mcq",
          "whatWentWrong": "LohXY2014 picked the past tense 'took' instead of the base form 'take' after the sensory verb 'saw'."
        },
        {
          "questionRef": "[118]",
          "type": "mcq",
          "whatWentWrong": "LohXY2014 chose the plural 'are organising' instead of 'is organising', forgetting that 'as well as' does not make the subject plural."
        },
        {
          "questionRef": "[29]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 wrote 'result' instead of 'results', missing that the singular subject 'This' needs a singular verb."
        }
      ],
      "strategic_advice": "When you see a verb question, always play detective and look for the **subject** and the **time clues**.\n- **Highlight the subject** and ask yourself: is it singular or plural?\n- Watch out for **special rules**, like sensory verbs ('saw', 'heard') which need the base form, or uncountable nouns ('luggage') which are always singular.",
      "trigger_keywords": [
        "grammar",
        "editing",
        "tense",
        "verb"
      ]
    },
    {
      "name": "Hidden Poster Details",
      "what": "Sometimes overlooks small but important conditions or keywords in posters and advertisements.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "mcq",
          "whatWentWrong": "LohXY2014 missed that the 15% discount was specifically for the 'first order online'."
        },
        {
          "questionRef": "[37]",
          "type": "mcq",
          "whatWentWrong": "LohXY2014 overlooked the word 'only' in the option, which made the statement false."
        },
        {
          "questionRef": "[85]",
          "type": "mcq",
          "whatWentWrong": "LohXY2014 missed that the biggest savings were for returning customers who book 'after 1 December'."
        }
      ],
      "strategic_advice": "When reading posters or flyers, treat every small condition as a **stop sign**.\n- Pay close attention to **absolute words** like 'only', 'all', or 'never'.\n- Look out for **special conditions** like 'first order', 'returning customers', or specific dates.",
      "trigger_keywords": [
        "according to the poster",
        "which statement is true",
        "visual text",
        "advertisement"
      ]
    }
  ],

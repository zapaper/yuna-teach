{
  "patterns": [
    {
      "name": "Spelling words exactly as they sound",
      "what": "LohXY2014 occasionally spells tricky words exactly as they sound, which sometimes leads to missing double letters or silent vowels.",
      "specific_examples": [
        {
          "questionRef": "[30]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 spelled the word exactly as it sounds, missing the silent 'r' in 'surprisingly'."
        },
        {
          "questionRef": "[80]",
          "type": "oeq",
          "whatWentWrong": "He/she missed the double 'm' in 'commotion', spelling it phonetically."
        },
        {
          "questionRef": "[114]",
          "type": "oeq",
          "whatWentWrong": "He/she added an extra 'is' sound, writing 'envisious' instead of 'envious'."
        }
      ],
      "strategic_advice": "When you see the instruction to write the **correct word in each of the boxes**, always double-check your spelling. Try to break the word into its root and suffixes, and look out for **double letters** and **silent vowels** that might be hidden when we speak.",
      "trigger_keywords": [
        "correct word in each of the boxes",
        "spelling or grammatical error"
      ]
    },
    {
      "name": "Overlooking fixed word partnerships",
      "what": "LohXY2014 tends to choose words that make sense on their own but do not form the correct fixed phrase, idiom, or phrasal verb.",
      "specific_examples": [
        {
          "questionRef": "[15]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 chose 'straight', missing the fixed idiom 'stand on end'."
        },
        {
          "questionRef": "[101]",
          "type": "oeq",
          "whatWentWrong": "He/she chose 'down', missing the common phrase 'weak in the knees'."
        },
        {
          "questionRef": "[125]",
          "type": "mcq",
          "whatWentWrong": "He/she picked 'of', but the word 'congratulated' always pairs with the preposition 'on'."
        }
      ],
      "strategic_advice": "When you are asked to **Fill in each blank**, pay close attention to the prepositions right next to the blank. Ask yourself if the words form a **fixed idiom** or **phrasal verb** that always goes together, rather than just picking a word that makes sense on its own.",
      "trigger_keywords": [
        "Fill in each blank",
        "choose the most suitable word"
      ]
    },
    {
      "name": "Stopping at the immediate sentence",
      "what": "LohXY2014 sometimes fills in a blank or answers a question based only on the immediate sentence, occasionally missing clues hidden in the sentences before or after.",
      "specific_examples": [
        {
          "questionRef": "[104]",
          "type": "oeq",
          "whatWentWrong": "LohXY2014 wrote 'shortest', missing the clue in the very next sentence that a long queue means good food."
        },
        {
          "questionRef": "[55]",
          "type": "oeq",
          "whatWentWrong": "He/she wrote 'money', missing the time context 'in the week' that required the word 'earlier'."
        },
        {
          "questionRef": "[26]",
          "type": "mcq",
          "whatWentWrong": "He/she missed the broader context of the poster, overlooking that the word 'only' made the statement false."
        }
      ],
      "strategic_advice": "When a question asks **Which statement is true** or requires you to **Fill in each blank**, avoid rushing to answer based on just one sentence. Always read the **sentence before** and the **sentence after** to catch **connecting ideas** or hidden conditions that change the meaning.",
      "trigger_keywords": [
        "Based on Text",
        "Which statement is true",
        "Fill in each blank"
      ]
    },
    {
      "name": "Overlooking hidden grammar rules",
      "what": "LohXY2014 occasionally misses structural grammar clues like question tags, uncountable nouns, or parallel structures that dictate the exact form of the verb.",
      "specific_examples": [
        {
          "questionRef": "[41]",
          "type": "mcq",
          "whatWentWrong": "LohXY2014 missed that the word 'seldom' makes the sentence negative, which requires a positive question tag."
        },
        {
          "questionRef": "[56]",
          "type": "mcq",
          "whatWentWrong": "He/she missed that 'luggage' is an uncountable noun and must be treated as singular."
        },
        {
          "questionRef": "[87]",
          "type": "mcq",
          "whatWentWrong": "He/she missed that the sensory verb 'saw' requires the next action to be in its base form."
        }
      ],
      "strategic_advice": "When tackling a **Grammar MCQ** or an **Editing** passage, actively scan for **trigger words** like 'seldom', uncountable nouns, or sensory verbs like 'saw'. These specific words carry **special grammar rules** that dictate whether your answer should be singular, plural, or in a specific tense.",
      "trigger_keywords": [
        "Choose the correct answer",
        "Grammar MCQ",
        "Editing"
      ]
    }
  ],

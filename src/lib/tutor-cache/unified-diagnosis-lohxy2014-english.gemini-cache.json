{
  "patterns": [
    {
      "name": "Question Tag Mix-Up",
      "what": "Sometimes misses hidden negative words like 'seldom' or 'rarely', or uses the wrong helping verb when forming question tags.",
      "specific_examples": [
        {
          "questionRef": "[75]",
          "type": "mcq",
          "whatWentWrong": "He picked 'doesn't she' instead of 'does she', missing that 'rarely' makes the sentence negative."
        },
        {
          "questionRef": "[126]",
          "type": "mcq",
          "whatWentWrong": "He picked 'doesn't' instead of 'does', missing the negative word 'seldom'."
        },
        {
          "questionRef": "[191]",
          "type": "mcq",
          "whatWentWrong": "He picked 'didn't' instead of 'haven't', using the wrong helping verb for 'You've'."
        }
      ],
      "strategic_advice": "When you see a question tag prompt, circle the main verb and look out for hidden negative words like **'seldom'**, **'rarely'**, or **'barely'**. If the sentence is negative, the tag must be positive!",
      "trigger_keywords": [
        "seldom",
        "rarely",
        "barely",
        "didn't",
        "hasn't"
      ]
    },
    {
      "name": "Reported Speech Tenses",
      "what": "Occasionally forgets to shift the tense backwards or change time words when converting direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'if I saw' instead of 'if I had seen', forgetting to shift the past tense to past perfect."
        },
        {
          "questionRef": "[54]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'must submit' instead of 'had to submit', forgetting to change the modal verb."
        },
        {
          "questionRef": "[74]",
          "type": "oeq",
          "whatWentWrong": "He missed out the time reference 'later that day' in the reported speech."
        }
      ],
      "strategic_advice": "When you see speech marks being removed, remember to take one step back in time. Change present tense to past tense, and past tense to past perfect. Also, don't forget to change time words like **'tomorrow'** to **'the next day'**!",
      "trigger_keywords": [
        "asked",
        "told",
        "wanted to know",
        "said to"
      ]
    },
    {
      "name": "Spelling Slips",
      "what": "Tends to misspell longer words, especially those with double letters or tricky vowel combinations.",
      "specific_examples": [
        {
          "questionRef": "[10]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'eatting' instead of 'eating', adding an extra 't'."
        },
        {
          "questionRef": "[90]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'hankerchief' instead of 'handkerchief', missing the silent 'd'."
        },
        {
          "questionRef": "[165]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'Comotion' instead of 'Commotion', missing the double 'm'."
        }
      ],
      "strategic_advice": "When editing a spelling mistake, sound the word out syllable by syllable. Watch out for tricky double letters and silent vowels. If you are unsure, try writing the word a few different ways on rough paper to see which one looks right.",
      "trigger_keywords": [
        "spelling error",
        "underlined words"
      ]
    },
    {
      "name": "Missing the Clue Words",
      "what": "Sometimes fills in a blank with a word that makes sense on its own, but misses the specific preposition or idiom that comes right after it.",
      "specific_examples": [
        {
          "questionRef": "[28]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'keen' instead of 'interested', missing that the blank is followed by the preposition 'in'."
        },
        {
          "questionRef": "[67]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'to' instead of 'with' for the phrase 'familiar with technology'."
        },
        {
          "questionRef": "[186]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'down' instead of 'weak' for the idiom 'go weak in the knees'."
        }
      ],
      "strategic_advice": "When filling in a blank, always read the words immediately before and after it. Look out for prepositions like **'in'**, **'with'**, or **'for'**, and choose a word that pairs perfectly with them to form a correct phrase.",
      "trigger_keywords": [
        "Fill in each blank",
        "suitable word"
      ]
    }
  ],

    {
      "name": "Who vs Whom Mix-Up",
      "what": "Sometimes confuses when to use 'who' for the person doing the action, and 'whom' for the person receiving it.",
      "specific_examples": [
        {
          "questionRef": "[2]",
          "type": "mcq",
          "whatWentWrong": "Chose 'whom' instead of 'who' for the man doing the action of helping."
        },
        {
          "questionRef": "[3]",
          "type": "mcq",
          "whatWentWrong": "Chose 'who' instead of 'whom' after the preposition 'to'."
        }
      ],
      "strategic_advice": "Try the **'he/him' trick**! If you can replace the word with 'he', use **'who'**. If you can replace it with 'him', use **'whom'**. Also, if there is a preposition right before the blank (like 'to', 'for', or 'with'), always choose **'whom'**.",
      "trigger_keywords": [
        "who",
        "whom",
        "whose",
        "which"
      ]
    }

{
  "patterns": [
    {
      "name": "Spelling Slips",
      "what": "Occasionally loses half a mark due to minor spelling mistakes in words she likely knows, both in editing passages and comprehension answers.",
      "specific_examples": [
        {
          "questionRef": "[49]",
          "type": "oeq",
          "whatWentWrong": "Spelled 'disappointed' as 'disappinted' in the editing passage."
        },
        {
          "questionRef": "[3]",
          "type": "oeq",
          "whatWentWrong": "Wrote 'eariler' instead of 'earlier' in a comprehension answer."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "Accidentally wrote 'witn' instead of 'with' when copying from the text."
        }
      ],
      "strategic_advice": "When checking your work, try reading your written answers backwards word by word. This forces your brain to look at the spelling of each word rather than just reading the sentence.",
      "trigger_keywords": [
        "editing",
        "comprehension",
        "spelling"
      ]
    },
    {
      "name": "Subject-Verb Agreement Mix-Up",
      "what": "Sometimes gets tricked by sentences where the subject is a special word like 'Neither' or an action word, mistakenly choosing a plural verb.",
      "specific_examples": [
        {
          "questionRef": "[31]",
          "type": "mcq",
          "whatWentWrong": "Chose the plural verb 'attend' for the singular subject 'Neither'."
        },
        {
          "questionRef": "[41]",
          "type": "mcq",
          "whatWentWrong": "Picked the plural verb 'help' instead of 'helps' for the singular subject 'reading'."
        }
      ],
      "strategic_advice": "When you see words like **'Neither'**, **'Each'**, or an action ending in **'-ing'** acting as the subject, treat them as singular. Try crossing out the extra descriptive words (like 'of the siblings') to find the true subject.",
      "trigger_keywords": [
        "neither",
        "each",
        "reading",
        "verb"
      ]
    },
    {
      "name": "Stopping One Step Short",
      "what": "Tends to capture the main idea in comprehension answers but occasionally misses the second required point or the specific format requested.",
      "specific_examples": [
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "Identified that the writer felt she didn't guide Timmy well, but missed the second point about feeling burdened by expectations."
        },
        {
          "questionRef": "[26]",
          "type": "oeq",
          "whatWentWrong": "Wrote full sentences instead of picking exactly two words as requested by the question."
        },
        {
          "questionRef": "[7]",
          "type": "oeq",
          "whatWentWrong": "Stated that the writer is reminded of the advice, but stopped short of explaining how she actually applied it to her job."
        }
      ],
      "strategic_advice": "When a question is worth 2 marks or asks you to **'explain fully'**, always look for two distinct points in the passage. If the prompt says **'pick out two words'**, double-check that your final answer is exactly two words.",
      "trigger_keywords": [
        "explain fully",
        "explain clearly",
        "in what ways",
        "pick out"
      ]
    },
    {
      "name": "Missing Clue Words",
      "what": "Occasionally selects a vocabulary word that seems related but doesn't quite fit the surrounding words or the exact meaning of the sentence.",
      "specific_examples": [
        {
          "questionRef": "[43]",
          "type": "mcq",
          "whatWentWrong": "Chose 'frolic' instead of 'revel', missing the clue word 'in' that follows the blank."
        },
        {
          "questionRef": "[54]",
          "type": "mcq",
          "whatWentWrong": "Picked 'aggravate' (which means to make worse) instead of 'alleviate' (to make better) when the sentence talked about easing a problem."
        }
      ],
      "strategic_advice": "Look closely at the words immediately before and after the blank, especially prepositions like **'in'** or **'to'**. Try plugging your chosen word into the sentence to see if it makes logical sense with the overall message.",
      "trigger_keywords": [
        "blank",
        "closest in meaning",
        "vocabulary"
      ]
    }
  ],

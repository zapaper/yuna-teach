{
  "patterns": [
    {
      "name": "Hidden Air Trap",
      "what": "Sometimes misses that air is a gas that occupies the empty spaces between solid objects like pebbles or coins.",
      "specific_examples": [
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "Emily correctly identified that the pebbles are solid, but she missed that the empty spaces between them are filled with gas."
        },
        {
          "questionRef": "[2]",
          "type": "oeq",
          "whatWentWrong": "She suggested that coins could measure the space inside a bank, forgetting that solid coins leave air gaps that cannot be filled."
        },
        {
          "questionRef": "[54]",
          "type": "oeq",
          "whatWentWrong": "Emily named solid as a state of matter in the container of pebbles, but forgot to include the gas hiding in the gaps."
        }
      ],
      "strategic_advice": "When you see questions about containers filled with solid objects, treat them as a trick!\n- **'filled to its brim with pebbles'** → Remember that solid objects don't fit together perfectly. The gaps are always filled with **gas (air)**!\n- **'explain why'** → Mention that solids have a **definite shape** and cannot fill the air gaps completely.",
      "trigger_keywords": [
        "pebbles",
        "filled to its brim",
        "coin bank",
        "space inside"
      ]
    },
    {
      "name": "Volume vs Level Mix-Up",
      "what": "Tends to confuse the water level rising with the actual volume of water increasing when an object is pushed into a container.",
      "specific_examples": [
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "Emily stated that the volume of water would increase when a cup is pushed in, confusing the rising water level with the actual amount of water."
        },
        {
          "questionRef": "[49]",
          "type": "oeq",
          "whatWentWrong": "She explained that the plastic cup occupies space, but missed the key idea that the water itself has a definite volume that remains the same."
        },
        {
          "questionRef": "[65]",
          "type": "mcq",
          "whatWentWrong": "Emily thought the volume of the water increased when a cube was dropped in, rather than just the water level."
        }
      ],
      "strategic_advice": "When an object is pushed into water, remember the difference between the water level and the water volume:\n- **'volume of water'** → This is the actual amount of water. It **remains the same** because no water was added or poured out.\n- **'water level'** → This goes up because the object takes up space and pushes the water out of the way.\n- **'explain your answer'** → Always state that **water has a definite volume**.",
      "trigger_keywords": [
        "volume of water",
        "water level",
        "pushed into a basin",
        "remain the same"
      ]
    },
    {
      "name": "Digestive System Mix-Up",
      "what": "Occasionally swaps the roles and order of the small intestine and the large intestine when tracing the path of food.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "oeq",
          "whatWentWrong": "Emily wrote that the small intestine absorbs water, which is actually the special job of the large intestine."
        },
        {
          "questionRef": "[30]",
          "type": "oeq",
          "whatWentWrong": "She mixed up the order of the organs, placing the large intestine before the small intestine in the digestive journey."
        },
        {
          "questionRef": "[84]",
          "type": "mcq",
          "whatWentWrong": "Emily had a little trouble comparing the amount of digested food in the stomach versus the large intestine."
        }
      ],
      "strategic_advice": "When you see diagrams of the digestive system, label the organs before reading the questions. Keep these special jobs in mind:\n- **'small intestine'** → This is where digestion **ends** and where digested food is **absorbed into the blood**.\n- **'large intestine'** → Digestion is already finished here! Its only job is to **absorb water** from the leftover waste.",
      "trigger_keywords": [
        "absorb water",
        "undigested food",
        "part S",
        "part T",
        "digestion ends"
      ]
    }
  ],

  "patterns": [
    {
      "name": "Forgotten Units",
      "what": "Sometimes forgets to write the final unit (like $ or %), or misses a required conversion (like cents to dollars) before finishing the problem.",
      "specific_examples": [
        {
          "questionRef": "[11]",
          "type": "mcq",
          "whatWentWrong": "He correctly set up the algebra but forgot to convert the cents into dollars to match the options."
        },
        {
          "questionRef": "[34]",
          "type": "oeq",
          "whatWentWrong": "He did a great job finding the area but accidentally wrote the final unit as volume (cm³) instead of area (cm²)."
        },
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "He calculated the correct number but forgot to write the percentage symbol at the end."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs:\n- **'Give your answer in terms of'** → check if you need to convert cents to dollars or cm to m.\n- **'How much'** or **'What percentage'** → always write the $ or % symbol on your final answer line.",
      "trigger_keywords": [
        "Give your answer in terms of",
        "How much",
        "What percentage",
        "litres"
      ]
    },
    {
      "name": "One Step Short",
      "what": "Often does the hard work to find an important middle value, but occasionally stops before answering the final question asked.",
      "specific_examples": [
        {
          "questionRef": "[19]",
          "type": "mcq",
          "whatWentWrong": "He correctly found the curved length of the semicircle but forgot to add the straight line to find the full perimeter."
        },
        {
          "questionRef": "[21]",
          "type": "mcq",
          "whatWentWrong": "He successfully calculated the amount of paint used, but the question asked for the amount of paint left."
        },
        {
          "questionRef": "[39]",
          "type": "oeq",
          "whatWentWrong": "He did the heavy lifting to find the original savings, but stopped before adding the spending to find the total allowance."
        }
      ],
      "strategic_advice": "When you reach your final number, re-read the last sentence of the question.\n- **'left with'** or **'remaining'** → subtract your answer from the total.\n- **'perimeter'** → check if you need to add any straight lines to your curved shape.\n- **'total'** → make sure you have added all the parts together.",
      "trigger_keywords": [
        "left with",
        "perimeter",
        "total allowance",
        "new ratio"
      ]
    },
    {
      "name": "Wrong Total Used",
      "what": "Sometimes uses the wrong starting number when building a fraction, such as using the leftover amount instead of the original total as the bottom number.",
      "specific_examples": [
        {
          "questionRef": "[26]",
          "type": "mcq",
          "whatWentWrong": "He was asked for the fraction of expenditure, but he used the total money as the bottom number instead of the money spent."
        },
        {
          "questionRef": "[36]",
          "type": "oeq",
          "whatWentWrong": "He correctly found the number of red pens left, but used that as the bottom of his fraction instead of the original number of red pens."
        }
      ],
      "strategic_advice": "When a question asks for a **'fraction of'** something, the word right after 'of' tells you what the bottom number (the whole) should be.\n- **'fraction of his expenditure'** → the bottom number must be the money spent.\n- **'fraction of the red pens'** → the bottom number must be the starting number of red pens.",
      "trigger_keywords": [
        "fraction of",
        "percentage of",
        "of the remaining"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "Leaving Questions Blank",
      "what": "Sometimes leaves the written parts of questions completely blank, especially when asked to explain or state an aim.",
      "specific_examples": [
        {
          "questionRef": "[35]",
          "type": "oeq",
          "whatWentWrong": "Caleb left the parts asking for the aim of the experiment and the explanation completely blank."
        },
        {
          "questionRef": "[38]",
          "type": "oeq",
          "whatWentWrong": "He skipped identifying the plant parts and describing how the substances move."
        },
        {
          "questionRef": "[39]",
          "type": "oeq",
          "whatWentWrong": "He left all three parts of this experimental design question blank."
        }
      ],
      "strategic_advice": "When you see a written question, always write down your best guess. \n- **'State the aim'** → look at what is changing and what is being measured.\n- **'Explain why'** → write down the science keywords you know about the topic, even if you aren't sure of the full answer.",
      "trigger_keywords": [
        "explain",
        "state the aim",
        "describe",
        "list down"
      ]
    },
    {
      "name": "Kinetic vs Potential Energy",
      "what": "Occasionally mixes up kinetic energy (energy of movement) with potential energy (stored energy).",
      "specific_examples": [
        {
          "questionRef": "[4]",
          "type": "mcq",
          "whatWentWrong": "Caleb thought the moving plastic tube had potential energy instead of kinetic energy."
        },
        {
          "questionRef": "[47]",
          "type": "mcq",
          "whatWentWrong": "He picked water stored behind a dam as not having potential energy, but stored water is a classic example of potential energy."
        },
        {
          "questionRef": "[52]",
          "type": "mcq",
          "whatWentWrong": "He missed that a fully charged battery holds potential energy, choosing heat energy instead."
        }
      ],
      "strategic_advice": "When you see energy questions, ask yourself if the object is moving or storing energy for later.\n- **'moving'**, **'rolling'**, or **'falling'** → kinetic energy\n- **'stretched'**, **'battery'**, or **'high up'** → potential energy",
      "trigger_keywords": [
        "energy conversion",
        "potential energy",
        "kinetic energy"
      ]
    },
    {
      "name": "Finding the Experiment Aim",
      "what": "Sometimes picks the wrong aim for an experiment by focusing on things that were kept the same instead of what was changed.",
      "specific_examples": [
        {
          "questionRef": "[17]",
          "type": "mcq",
          "whatWentWrong": "Caleb thought the aim was about the number of ice cubes, but the number of ice cubes was kept the same in all setups."
        },
        {
          "questionRef": "[54]",
          "type": "mcq",
          "whatWentWrong": "He picked the rate of evaporation, but the experiment was measuring temperature changes to find the rate of heat transfer."
        }
      ],
      "strategic_advice": "When you see **'aim of the experiment'**, look for the one thing the person changed on purpose.\n- The aim is always to find out how the **changed thing** affects the **measured thing**.\n- Ignore the things that were kept the same to make it a fair test!",
      "trigger_keywords": [
        "aim of the experiment",
        "to find out"
      ]
    },
    {
      "name": "Food Web Chain Reactions",
      "what": "Occasionally misses how a change in one animal's population affects the other plants and animals in a food web.",
      "specific_examples": [
        {
          "questionRef": "[20]",
          "type": "mcq",
          "whatWentWrong": "Caleb didn't correctly trace how getting rid of the caterpillars would affect the chicken population."
        },
        {
          "questionRef": "[53]",
          "type": "mcq",
          "whatWentWrong": "He picked a graph that didn't correctly show how fewer birds would lead to more prey and fewer plants."
        }
      ],
      "strategic_advice": "When you see a food web and one animal increases or decreases, draw up and down arrows next to the other organisms to show what happens next.\n- **'more predators'** → the prey population goes down\n- **'less predators'** → the prey population goes up",
      "trigger_keywords": [
        "population",
        "food web",
        "introduced",
        "food chain"
      ]
    }
  ],

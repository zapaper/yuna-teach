{
  "patterns": [
    {
      "name": "Reported Speech Mix-Up",
      "what": "Mark occasionally forgets to change the tense, pronouns, or time words when converting direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "oeq",
          "whatWentWrong": "He used 'should have revised' instead of 'should revise', and forgot to change 'this' to 'that'."
        },
        {
          "questionRef": "[38]",
          "type": "oeq",
          "whatWentWrong": "He forgot to step the tense back into the past, writing 'like' instead of 'liked'."
        },
        {
          "questionRef": "[59]",
          "type": "oeq",
          "whatWentWrong": "He left the sentence in direct speech instead of changing it to reported speech."
        }
      ],
      "strategic_advice": "When you see prompts like **'asked'** or **'told'**, treat them as a checklist:\n- **Check the tense**: Step the verb back one step into the past (e.g., 'is' becomes 'was').\n- **Check the pronouns**: Change words like 'I' to 'he/she' and 'this' to 'that'.\n- **Check the time words**: Change 'today' to 'that day'.",
      "trigger_keywords": [
        "asked",
        "wanted to know",
        "told"
      ]
    },
    {
      "name": "Word Form Mix-Up",
      "what": "Mark sometimes uses a verb when the sentence needs a noun or an adverb, especially in editing passages.",
      "specific_examples": [
        {
          "questionRef": "[204]",
          "type": "oeq",
          "whatWentWrong": "He used the past tense verb 'joked' instead of the adverb 'jokingly' to describe how the doctor spoke."
        },
        {
          "questionRef": "[205]",
          "type": "oeq",
          "whatWentWrong": "He used the verb 'reassured' instead of the noun 'reassurance'."
        },
        {
          "questionRef": "[134]",
          "type": "oeq",
          "whatWentWrong": "He used the past tense 'became' instead of the past participle 'become' after the word 'had'."
        }
      ],
      "strategic_advice": "When you are editing a word, ask yourself what **job** the word is doing in the sentence:\n- If it describes an action, you usually need an **adverb** ending in '-ly' (e.g., 'jokingly').\n- If it comes after words like 'the' or 'an', you likely need a **noun** (e.g., 'reassurance').\n- If it follows 'has' or 'had', make sure you use the **past participle** form of the verb.",
      "trigger_keywords": [
        "Editing",
        "Spelling & Grammar"
      ]
    },
    {
      "name": "One Step Short",
      "what": "Mark often finds the right part of the passage but sometimes stops writing before including all the necessary details for full marks.",
      "specific_examples": [
        {
          "questionRef": "[6]",
          "type": "oeq",
          "whatWentWrong": "He correctly noted that Dragon Master was the winner, but stopped short of stating that it was Rachel."
        },
        {
          "questionRef": "[74]",
          "type": "oeq",
          "whatWentWrong": "He provided Rachel's reaction perfectly, but missed including Charlotte's reaction."
        },
        {
          "questionRef": "[76]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified that Charlotte was happy, but missed the detail that she was also shocked."
        }
      ],
      "strategic_advice": "When you find the answer in the passage, read **one sentence before and one sentence after** to make sure you haven't missed a second detail. If a question asks about two people or two feelings, make sure your answer includes **both parts**.",
      "trigger_keywords": [
        "how can you tell",
        "what do you think",
        "support each statement"
      ]
    },
    {
      "name": "Subject-Verb Mix-Up",
      "what": "Mark sometimes gets tricked by tricky subjects like 'Both', uncountable nouns, or relative clauses, matching them with the wrong verb.",
      "specific_examples": [
        {
          "questionRef": "[25]",
          "type": "oeq",
          "whatWentWrong": "He used the singular verb 'likes' for the plural subject 'Ali and Lily'."
        },
        {
          "questionRef": "[41]",
          "type": "mcq",
          "whatWentWrong": "He used the plural 'have been' for the uncountable noun 'luggage', which needs the singular 'has been'."
        },
        {
          "questionRef": "[155]",
          "type": "mcq",
          "whatWentWrong": "He used the singular 'signs' instead of 'sign' for the plural relative pronoun 'who' referring to 'students'."
        }
      ],
      "strategic_advice": "When you see these tricky subjects, take a moment to check if they are singular or plural:\n- **'Both'** or names joined by **'and'** → treat as a plural group.\n- **Uncountable nouns** (like luggage or furniture) → treat as singular.\n- **'who'** or **'which'** → look at the word right before it to decide if it's singular or plural.",
      "trigger_keywords": [
        "Both",
        "Neither",
        "who",
        "has/have"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "Reported Speech Tenses",
      "what": "Mark sometimes forgets to shift the tense backwards or update time words when changing direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[102]",
          "type": "oeq",
          "whatWentWrong": "He kept the present tense 'like' instead of shifting it back to the past tense 'liked'."
        },
        {
          "questionRef": "[251]",
          "type": "oeq",
          "whatWentWrong": "He forgot to change the present tense 'is' to 'was' and left the time word 'today' instead of changing it to 'that day'."
        },
        {
          "questionRef": "[287]",
          "type": "oeq",
          "whatWentWrong": "He used the past simple 'underwent' instead of stepping further back in time to the past perfect 'had undergone'."
        }
      ],
      "strategic_advice": "When you see speech marks being removed, remember to step back in time!\n- **Change the tense**: present becomes past, and past becomes past perfect (e.g., 'wrote' becomes 'had written').\n- **Update time words**: 'yesterday' becomes 'the previous day', and 'now' becomes 'then'.",
      "trigger_keywords": [
        "asked",
        "told",
        "wanted to know"
      ]
    },
    {
      "name": "Question Tag Mix-Up",
      "what": "Mark occasionally struggles to match the helping verb in the question tag to the main sentence, especially when the main sentence uses a contraction.",
      "specific_examples": [
        {
          "questionRef": "[118]",
          "type": "mcq",
          "whatWentWrong": "He picked 'didn't' instead of expanding 'You've' to 'You have' and using 'haven't'."
        },
        {
          "questionRef": "[174]",
          "type": "mcq",
          "whatWentWrong": "He missed that 'rarely' makes the statement negative, so the tag should be the positive 'does she' instead of 'doesn't she'."
        },
        {
          "questionRef": "[180]",
          "type": "mcq",
          "whatWentWrong": "He picked 'didn't he' instead of recognizing that 'Ahmad's cleaned' means 'Ahmad has cleaned', which needs the tag 'hasn't he'."
        }
      ],
      "strategic_advice": "When you see a comma followed by a blank at the end of a sentence, it's a question tag!\n- **Expand the contraction**: 'You've' means 'You have', and 'Ahmad's cleaned' means 'Ahmad has cleaned'.\n- **Match the helping verb**: Use that exact helping verb (like 'have' or 'has') in the opposite form for your tag. If the sentence has a negative word like 'rarely' or 'seldom', the tag must be positive!",
      "trigger_keywords": [
        "___, you?",
        "___, he?",
        "___, she?"
      ]
    },
    {
      "name": "Who and Whom Confusion",
      "what": "Mark tends to mix up 'who' and 'whom', especially when the pronoun is the object of the sentence or follows a preposition.",
      "specific_examples": [
        {
          "questionRef": "[3]",
          "type": "mcq",
          "whatWentWrong": "He picked 'who' instead of 'whom' after the preposition 'to'."
        },
        {
          "questionRef": "[247]",
          "type": "oeq",
          "whatWentWrong": "He used 'whom' as the subject of the verb 'is' ('whom is an excellent teacher') instead of 'who'."
        },
        {
          "questionRef": "[258]",
          "type": "mcq",
          "whatWentWrong": "He picked 'whom' to act as the subject of the verb 'was', but it should be 'who'."
        }
      ],
      "strategic_advice": "When deciding between 'who' and 'whom', try the 'he/him' trick!\n- If you can replace the word with **'he'**, use **'who'** (e.g., 'who is a teacher').\n- If you can replace it with **'him'**, use **'whom'** (e.g., 'to whom you were speaking').",
      "trigger_keywords": [
        "who",
        "whom"
      ]
    },
    {
      "name": "Subject-Verb Agreement",
      "what": "Mark sometimes misses the true subject of the sentence, especially with tricky phrases like 'Neither of' or 'one of the students who'.",
      "specific_examples": [
        {
          "questionRef": "[54]",
          "type": "mcq",
          "whatWentWrong": "He picked the singular verb 'signs' instead of matching the plural noun 'students' with the plural verb 'sign'."
        },
        {
          "questionRef": "[154]",
          "type": "mcq",
          "whatWentWrong": "He picked the plural verb 'attend' instead of recognizing that 'Neither of' is a singular subject requiring 'attends'."
        },
        {
          "questionRef": "[303]",
          "type": "oeq",
          "whatWentWrong": "He used the plural verb 'are' instead of the singular verb 'is' to match the singular subject 'Each'."
        }
      ],
      "strategic_advice": "When you see tricky subject phrases, take a moment to find the true doer of the action.\n- **'Neither of'** and **'Each of'** are always treated as singular subjects.\n- For **'one of the students who'**, the word 'who' refers to the plural 'students', so the verb must be plural.",
      "trigger_keywords": [
        "Neither of",
        "one of the",
        "who",
        "Each of"
      ]
    }
  ],

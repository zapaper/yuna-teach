{
  "patterns": [
    {
      "name": "Leaving Out Crucial Details",
      "what": "Mark sometimes drops specific pronouns, adjectives, or key actions in his answers, which can slightly change the meaning or leave the answer incomplete.",
      "specific_examples": [
        {
          "questionRef": "[35]",
          "type": "oeq",
          "whatWentWrong": "Mark omitted the word 'new' when referring to the museum, which slightly changed the exact meaning of his sentence."
        },
        {
          "questionRef": "[56]",
          "type": "oeq",
          "whatWentWrong": "Mark correctly found one piece of evidence for Charlotte's nervousness but missed the second action of her tightening her fingers."
        },
        {
          "questionRef": "[84]",
          "type": "oeq",
          "whatWentWrong": "Mark missed the crucial detail that the father could only take one child with him, making his answer incomplete."
        }
      ],
      "strategic_advice": "When you see **'based on lines'** or **'rewrite the sentence'**, always do a quick double-check of the original text. Ask yourself, **'Did I include every single adjective and pronoun?'** For comprehension questions, check if the question asks for multiple pieces of evidence or a specific consequence, and ensure you write down the **complete action**.",
      "trigger_keywords": [
        "based on lines",
        "rewrite the sentence",
        "support each statement",
        "how can you tell"
      ]
    },
    {
      "name": "Losing Track of Subject-Verb Agreement",
      "what": "Mark occasionally gets distracted by extra words between the subject and the verb, leading to a mismatch in singular and plural forms or forgetting to shift tenses.",
      "specific_examples": [
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "Mark used the singular verb 'likes' for the plural subject 'Both Ali and Lily'."
        },
        {
          "questionRef": "[30]",
          "type": "mcq",
          "whatWentWrong": "Mark chose the plural 'have been' for 'luggage', which is an uncountable noun and requires the singular 'has been'."
        },
        {
          "questionRef": "[88]",
          "type": "mcq",
          "whatWentWrong": "Mark matched the verb to the singular 'Weiling' instead of the plural 'students' in the phrase 'one of the numerous students who'."
        }
      ],
      "strategic_advice": "When you see **'choose the correct word'** or are asked to **'rewrite the sentence'**, pause and identify the true subject. Use your pencil to **bracket the extra descriptive words** so you can clearly see the main subject and match it to the correct verb. Also, remember to **shift your tenses backwards** when changing direct speech to reported speech.",
      "trigger_keywords": [
        "choose the correct word",
        "rewrite the sentence",
        "underlined words contains either a spelling or grammatical error"
      ]
    },
    {
      "name": "Missing Contextual Contrasts and Negatives",
      "what": "Mark tends to overlook hidden negative words or contrast clues, which leads to incorrect question tags or missing the shift in a passage's tone.",
      "specific_examples": [
        {
          "questionRef": "[36]",
          "type": "mcq",
          "whatWentWrong": "Mark missed that 'seldom' is a hidden negative word, so the question tag should be positive."
        },
        {
          "questionRef": "[115]",
          "type": "oeq",
          "whatWentWrong": "Mark chose 'useful' instead of 'hard', missing the contrast clue 'Although it sounds simple' earlier in the sentence."
        },
        {
          "questionRef": "[136]",
          "type": "oeq",
          "whatWentWrong": "Mark used 'Although' instead of 'Even', missing the emphasis that her eyesight was poor despite wearing glasses."
        }
      ],
      "strategic_advice": "When you see **'fill in each blank'** or question tags, go on high alert for hidden negatives like **'seldom'**, **'never'**, or **'hardly'**. Always **highlight contrast words** in the passage to remind yourself that the sentence is about to flip its meaning.",
      "trigger_keywords": [
        "choose the correct word",
        "fill in each blank",
        "asked"
      ]
    },
    {
      "name": "Using the Wrong Word Form",
      "what": "Mark often identifies the correct root word but occasionally writes it in the wrong form, such as using a verb when an adverb or noun is needed.",
      "specific_examples": [
        {
          "questionRef": "[15]",
          "type": "oeq",
          "whatWentWrong": "Mark used the adjective 'diligent' instead of the noun 'diligence' to describe the student's quality."
        },
        {
          "questionRef": "[137]",
          "type": "oeq",
          "whatWentWrong": "Mark used the verb 'joked' instead of the adverb 'jokingly' to describe how the doctor spoke."
        },
        {
          "questionRef": "[138]",
          "type": "oeq",
          "whatWentWrong": "Mark used the verb 'reassured' instead of the noun 'reassurance' after the article 'the'."
        }
      ],
      "strategic_advice": "When you see **'correct word in each of the boxes'** or **'rewrite the sentence'**, look closely at the words immediately before the blank. If you see an article like **'the'** or **'a'**, you need a **noun**. If you are describing an action, you need an **adverb** ending in '-ly'.",
      "trigger_keywords": [
        "correct word in each of the boxes",
        "rewrite the sentence",
        "fill in each blank"
      ]
    }
  ],

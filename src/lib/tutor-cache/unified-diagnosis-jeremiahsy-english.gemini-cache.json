    {
      "name": "Spelling and Punctuation Slips",
      "what": "JeremiahSy sometimes misses small details like capital letters at the start of a sentence or the exact spelling of tricky words.",
      "specific_examples": [
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'despite' with a lowercase letter, forgetting that it was the first word of the sentence."
        },
        {
          "questionRef": "[25]",
          "type": "oeq",
          "whatWentWrong": "He spelled 'received' as 'recieved', mixing up the 'e' and 'i'."
        },
        {
          "questionRef": "[4]",
          "type": "oeq",
          "whatWentWrong": "He spelled 'insincerity' as 'incinscerity'."
        }
      ],
      "strategic_advice": "When checking your work, look out for these common traps:\n- **'i before e except after c'** → double-check words like 'received'.\n- **Start of a sentence** → always ensure the first letter is capitalised, even if it's a fill-in-the-blank question.",
      "trigger_keywords": [
        "Editing",
        "Spelling",
        "Punctuation",
        "Capitalisation"
      ]
    },
    {
      "name": "Phrasal Verb Mix-Up",
      "what": "JeremiahSy occasionally confuses phrasal verbs that share the same first word but end differently.",
      "specific_examples": [
        {
          "questionRef": "[26]",
          "type": "mcq",
          "whatWentWrong": "He chose 'set in' instead of 'set off' to describe starting a sudden action."
        },
        {
          "questionRef": "[1]",
          "type": "mcq",
          "whatWentWrong": "He picked 'creep along' instead of 'creep in' to describe a feeling slowly developing."
        }
      ],
      "strategic_advice": "When you see a verb followed by different prepositions (like 'set in' vs 'set off'):\n- **Read the whole sentence** to understand the exact action happening.\n- **Substitute** each option into the sentence and ask yourself if it matches the context (e.g., starting a journey vs weather continuing).",
      "trigger_keywords": [
        "set in",
        "set off",
        "creep in",
        "creep along"
      ]
    },
    {
      "name": "Link Word Mix-Up",
      "what": "JeremiahSy tends to mix up conjunctions and pronouns that connect two parts of a sentence together.",
      "specific_examples": [
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "He used 'It' instead of 'which' to link a descriptive clause to the main sentence."
        },
        {
          "questionRef": "[37]",
          "type": "mcq",
          "whatWentWrong": "He chose 'if' instead of 'or' to show the consequence of not doing something."
        }
      ],
      "strategic_advice": "When you need to connect two ideas:\n- **Check for commas** → if there's a comma joining two clauses, you often need a relative pronoun like **'which'** or **'who'**, not 'It'.\n- **Look at the relationship** → ask yourself if the second part is an addition, a contrast, or a consequence, and pick the matching word.",
      "trigger_keywords": [
        "In ________",
        "________ has had",
        "form ________ you cannot"
      ]
    },
    {
      "name": "Similar Word Mix-Up",
      "what": "JeremiahSy sometimes chooses a vocabulary word that is related to the topic but doesn't perfectly fit the specific context.",
      "specific_examples": [
        {
          "questionRef": "[19]",
          "type": "oeq",
          "whatWentWrong": "He used 'viewers' (which usually means watching TV/movies) instead of 'audience' (which covers both books and movies)."
        },
        {
          "questionRef": "[27]",
          "type": "mcq",
          "whatWentWrong": "He confused 'appeasing' (calming someone down) with 'appealing' (attractive and likable)."
        }
      ],
      "strategic_advice": "When choosing between words with similar meanings:\n- **Look for specific clues** in the sentence (e.g., 'books and movies' points to 'audience' rather than just 'viewers').\n- **Check the exact definition** in your head to see if it fits the tone and context perfectly.",
      "trigger_keywords": [
        "Fill in each blank",
        "Choose the most suitable word",
        "Vocabulary"
      ]
    }

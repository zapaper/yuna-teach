  "patterns": [
    {
      "name": "Tricky Word Choices",
      "what": "JeremiahSy tends to pick words or phrasal verbs that look familiar but do not perfectly match the specific context of the sentence.",
      "specific_examples": [
        {
          "questionRef": "[26]",
          "type": "mcq",
          "whatWentWrong": "He chose 'set in' instead of 'set off' to describe starting a sudden rescue mission."
        },
        {
          "questionRef": "[27]",
          "type": "mcq",
          "whatWentWrong": "He confused 'appeasing' with 'appealing' when describing a likable and charming personality."
        },
        {
          "questionRef": "[19]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'viewers' which only applies to movies, instead of 'audience' which covers both books and movies."
        }
      ],
      "strategic_advice": "When you see phrasal verbs or similar-looking words, read the whole sentence to find the context clues. Try plugging each option into the sentence to see which one makes the most sense with the surrounding actions.",
      "trigger_keywords": [
        "fill in each blank",
        "choose the most suitable word",
        "phrasal verb"
      ]
    },
    {
      "name": "Spelling and Word Forms",
      "what": "JeremiahSy occasionally misspells tricky words or writes the wrong form of a word, such as using a verb when a noun is needed.",
      "specific_examples": [
        {
          "questionRef": "[25]",
          "type": "oeq",
          "whatWentWrong": "He misspelled 'received' as 'recieved'."
        },
        {
          "questionRef": "[28]",
          "type": "oeq",
          "whatWentWrong": "He wrote the verb 'included' instead of the noun 'inclusion'."
        },
        {
          "questionRef": "[4]",
          "type": "oeq",
          "whatWentWrong": "He misspelled 'insincerity' as 'incinscerity'."
        }
      ],
      "strategic_advice": "When editing a passage, check if the blank needs a noun, verb, or adjective. For spelling, remember the classic rule **'i before e except after c'** for words like 'received'.",
      "trigger_keywords": [
        "correct the spelling",
        "editing",
        "rewrite"
      ]
    },
    {
      "name": "Reading the Fine Print",
      "what": "JeremiahSy sometimes chooses an answer in visual texts that sounds believable but is not directly supported by the poster's specific details.",
      "specific_examples": [
        {
          "questionRef": "[11]",
          "type": "mcq",
          "whatWentWrong": "He chose an option about electricity use instead of matching the customer reviews to the fact that the company served customers well."
        },
        {
          "questionRef": "[12]",
          "type": "mcq",
          "whatWentWrong": "He missed the detail in Text 2 that the impact on carbon footprint is actually limited."
        },
        {
          "questionRef": "[24]",
          "type": "mcq",
          "whatWentWrong": "He chose an option that didn't match the text's realistic fact that 'many' (not all) children find chocolate irresistible."
        }
      ],
      "strategic_advice": "When you see questions about posters or advertisements, treat them like a matching game. Find the exact words in the text that prove your answer. Watch out for absolute words like **'all'** or **'every'** compared to **'many'** or **'some'**.",
      "trigger_keywords": [
        "according to the poster",
        "not supported",
        "best describes"
      ]
    }

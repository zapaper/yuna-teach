  "patterns": [
    {
      "name": "Turning the Wrong Way",
      "what": "Sometimes calculates the turn in a clockwise direction instead of anti-clockwise, leading to the wrong final facing direction.",
      "specific_examples": [
        {
          "questionRef": "[19]",
          "type": "mcq",
          "whatWentWrong": "Emily calculated the angle for a clockwise turn to face East, rather than the requested anti-clockwise turn."
        },
        {
          "questionRef": "[37]",
          "type": "mcq",
          "whatWentWrong": "She found the correct angle for turning clockwise, but the question asked for an anti-clockwise turn."
        },
        {
          "questionRef": "[49]",
          "type": "mcq",
          "whatWentWrong": "Emily mixed up the turning direction, selecting the angle that represents a clockwise turn instead."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs:\n- **'anti-clockwise'** → draw a quick arrow pointing to the left (opposite of a clock) before counting the angles\n- **'clockwise'** → draw an arrow pointing to the right\nAlways double-check your drawn arrow matches the word in the question before you start calculating.",
      "trigger_keywords": [
        "anti-clockwise",
        "clockwise",
        "facing",
        "turns through an angle"
      ]
    },
    {
      "name": "Copying Numbers Wrong",
      "what": "Occasionally copies a number incorrectly from the question into the working steps, which changes the final answer despite using the perfect math method.",
      "specific_examples": [
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "Emily used 2 hours and 4 minutes for the movie duration instead of the 2 hours and 24 minutes stated in the question."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "She wrote down the movie length as 2 hours and 4 minutes, which led to an incorrect end time despite a perfect addition method."
        },
        {
          "questionRef": "[24]",
          "type": "oeq",
          "whatWentWrong": "Emily missed the '20' in 24 minutes when copying the movie duration, changing the final calculated time."
        }
      ],
      "strategic_advice": "When you see numbers in the question, try this quick habit:\n- **Underline or highlight** the numbers as you read them.\n- After writing down your math steps, do a **one-second check** to make sure the numbers in your working exactly match the numbers you underlined.",
      "trigger_keywords": [
        "started at",
        "watched the movie for",
        "after the movie"
      ]
    },
    {
      "name": "Line Naming Slips",
      "what": "Tends to add extra letters or symbols when naming lines, which causes marks to be lost even when the correct lines are spotted.",
      "specific_examples": [
        {
          "questionRef": "[17]",
          "type": "oeq",
          "whatWentWrong": "Emily included an extra 'L' when naming line WX, writing 'LWX' instead."
        },
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "She spotted the correct perpendicular lines but added an extra letter to the line's name."
        },
        {
          "questionRef": "[29]",
          "type": "oeq",
          "whatWentWrong": "Emily wrote 'LWX' instead of 'WX', which made the line name incorrect."
        }
      ],
      "strategic_advice": "When you see **'name a pair'** or **'identify a line'**, remember that a straight line is always named with exactly **two letters** (like WX). If you find yourself writing three letters, stop and cross out the extra one!",
      "trigger_keywords": [
        "name a pair",
        "perpendicular lines",
        "parallel lines",
        "identify"
      ]
    },
    {
      "name": "Missed Key Words",
      "what": "Sometimes reads past important condition words like 'not', 'left', or 'greatest value', leading to an answer for a slightly different question.",
      "specific_examples": [
        {
          "questionRef": "[4]",
          "type": "mcq",
          "whatWentWrong": "Emily missed the word 'not' and picked a property that is true for both shapes instead of one that is false."
        },
        {
          "questionRef": "[64]",
          "type": "mcq",
          "whatWentWrong": "She looked for the greatest overall number instead of checking which number gave the digit 3 the greatest value."
        },
        {
          "questionRef": "[70]",
          "type": "oeq",
          "whatWentWrong": "Emily calculated the total number of shaded squares needed, but forgot to subtract the squares that were already shaded."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs:\n- **'not true'** or **'except'** → circle the word so you remember to look for the false option\n- **'left'** or **'remaining'** → double-check if you need to subtract from the total\n- **'greatest value'** → underline the specific digit you need to focus on",
      "trigger_keywords": [
        "not true",
        "left",
        "greatest value",
        "must be shaded"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "Compass Turn Directions",
      "what": "Tends to calculate the angle for the opposite direction of rotation, such as finding the clockwise angle when the question asks for anti-clockwise.",
      "specific_examples": [
        {
          "questionRef": "[10]",
          "type": "mcq",
          "whatWentWrong": "Calculated the clockwise turn (225°) instead of the requested anti-clockwise turn (135°)."
        },
        {
          "questionRef": "[19]",
          "type": "mcq",
          "whatWentWrong": "Found the angle for turning the wrong way around the compass."
        },
        {
          "questionRef": "[37]",
          "type": "mcq",
          "whatWentWrong": "Missed the 'anti-clockwise' instruction and selected the angle for a clockwise turn."
        }
      ],
      "strategic_advice": "When you see **'anti-clockwise'** or **'clockwise'**, treat it as a stop sign. Draw a quick circle and an arrow showing the direction of the turn before you start counting the angles. If you are turning anti-clockwise, imagine the hands of a clock going backwards!",
      "trigger_keywords": [
        "anti-clockwise",
        "clockwise",
        "turns through an angle",
        "facing"
      ]
    },
    {
      "name": "Number Transcription Slips",
      "what": "Occasionally drops a digit when copying numbers from the question into her working, which changes the final calculation.",
      "specific_examples": [
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "Copied the movie duration as 2 hours 4 minutes instead of 2 hours 24 minutes."
        },
        {
          "questionRef": "[30]",
          "type": "oeq",
          "whatWentWrong": "Missed the '2' in 24 minutes when setting up the time addition."
        },
        {
          "questionRef": "[45]",
          "type": "oeq",
          "whatWentWrong": "Used 2 h 4 min for the calculation, which led to an incorrect final time despite using the right method."
        }
      ],
      "strategic_advice": "When a question has multiple numbers or units, underline them as you read. After writing down your equation, do a quick **'copy check'** to make sure the numbers in your working exactly match the numbers in the question.",
      "trigger_keywords": [
        "h",
        "min",
        "started at",
        "watched the movie for"
      ]
    },
    {
      "name": "Geometry Line Notation",
      "what": "Sometimes includes extra letters or symbols when naming a straight line, rather than using exactly two letters for the endpoints.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "oeq",
          "whatWentWrong": "Named the line 'LWX' instead of just using the two endpoints 'WX'."
        },
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "Used three letters to name a line, which is how we name angles, not straight lines."
        },
        {
          "questionRef": "[65]",
          "type": "oeq",
          "whatWentWrong": "Combined multiple letters into 'ABLAE' instead of naming two distinct lines with two letters each."
        }
      ],
      "strategic_advice": "When you see **'name a pair of lines'**, remember that a straight line is always named using exactly **two letters** (its endpoints). If you use three letters, it looks like you are naming an angle!",
      "trigger_keywords": [
        "name a pair",
        "perpendicular lines",
        "parallel lines",
        "identify a pair"
      ]
    },
    {
      "name": "Measurement Unit Details",
      "what": "Occasionally forgets to include the unit of measurement in the final answer or writes the wrong type of unit.",
      "specific_examples": [
        {
          "questionRef": "[2]",
          "type": "oeq",
          "whatWentWrong": "Found the correct angle but forgot to include the degree (°) symbol."
        },
        {
          "questionRef": "[61]",
          "type": "oeq",
          "whatWentWrong": "Calculated the angle perfectly but left out the degree symbol in the final answer."
        },
        {
          "questionRef": "[62]",
          "type": "oeq",
          "whatWentWrong": "Found the correct area but wrote the unit for volume (cm³) instead of area (cm²)."
        }
      ],
      "strategic_advice": "When you finish a calculation, always check what the question is asking for. If it's an angle, add your **degree symbol (°)**. If it's area, make sure your unit has a **little 2 (cm²)**, not a 3!",
      "trigger_keywords": [
        "find ∠",
        "area of the square",
        "perimeter"
      ]
    }
  ],

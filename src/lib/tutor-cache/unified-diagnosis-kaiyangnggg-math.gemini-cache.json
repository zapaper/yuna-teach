{
  "patterns": [
    {
      "name": "One Step Short",
      "what": "Kaiyangnggg sometimes does the hard work to find an intermediate value, but occasionally stops before answering the final question asked.",
      "specific_examples": [
        {
          "questionRef": "[34]",
          "type": "mcq",
          "whatWentWrong": "He correctly calculated the fraction of paint used (1/12) but forgot to subtract it from the total to find the amount left."
        },
        {
          "questionRef": "[51]",
          "type": "oeq",
          "whatWentWrong": "He successfully found the total difference in stickers (42) but stopped one step short of dividing by 2 to find the amount given."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs to double-check your final step:\n- **'left with'** or **'in the end'** → check if you need to subtract your answer from the total.\n- **'how many did [Name] give'** → remember that giving items changes both people's amounts, so you often need to divide the difference by 2.",
      "trigger_keywords": [
        "left with",
        "in the end",
        "give to"
      ]
    },
    {
      "name": "Division Order Mix-Up",
      "what": "Kaiyangnggg occasionally mixes up which number should be divided by which, especially when dealing with fractions or rates.",
      "specific_examples": [
        {
          "questionRef": "[47]",
          "type": "oeq",
          "whatWentWrong": "He calculated 3/7 ÷ 8 instead of the requested 8 ÷ 3/7."
        },
        {
          "questionRef": "[78]",
          "type": "mcq",
          "whatWentWrong": "He divided the number of planes by the time, instead of dividing the time by the number of planes to find the time per plane."
        },
        {
          "questionRef": "[75]",
          "type": "mcq",
          "whatWentWrong": "He mixed up the division order when trying to find the printing rate per minute."
        }
      ],
      "strategic_advice": "When setting up a division problem, always ask yourself **'What is being shared or split up?'** The item being split up always comes **first** in the equation. For rates (like time per plane), put the word that comes after 'per' or 'each' at the end of your division.",
      "trigger_keywords": [
        "how long does he take",
        "in 1 minute",
        "find the value of"
      ]
    },
    {
      "name": "Base Value Mix-Up",
      "what": "Kaiyangnggg tends to use the wrong starting number (or 'whole') when calculating percentages or fractions of a group.",
      "specific_examples": [
        {
          "questionRef": "[92]",
          "type": "mcq",
          "whatWentWrong": "He calculated the percentage decrease using the final number of marbles (280) instead of the starting number (350)."
        },
        {
          "questionRef": "[84]",
          "type": "mcq",
          "whatWentWrong": "He likely calculated 60% of the total stamps instead of 60% of the 'remainder'."
        }
      ],
      "strategic_advice": "When you see percentage or fraction questions, always highlight the **reference word**:\n- **'percentage decrease/increase'** → always divide by the **original** starting amount.\n- **'of the remainder'** → calculate the leftover first, and use that as your new total.",
      "trigger_keywords": [
        "percentage decrease",
        "percentage increase",
        "of the remainder"
      ]
    },
    {
      "name": "Forgotten Units",
      "what": "Kaiyangnggg sometimes forgets to include the final units in his answers, or misses a step to convert them.",
      "specific_examples": [
        {
          "questionRef": "[43]",
          "type": "mcq",
          "whatWentWrong": "He found the correct algebra expression in cents, but forgot to divide by 100 to convert it to dollars as requested."
        },
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "He calculated the correct angle but forgot to write the degree symbol (°), which cost him a mark."
        },
        {
          "questionRef": "[54]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'cm' instead of 'cm²' for an area question."
        }
      ],
      "strategic_advice": "Make it a habit to circle the **requested unit** in the question before you start calculating. When you write your final answer, look back at your circle to make sure your units match perfectly.",
      "trigger_keywords": [
        "in terms of $",
        "find the area",
        "find ∠"
      ]
    }
  ],

  "patterns": [
    {
      "name": "Stopping One Step Short",
      "what": "Sometimes calculates an intermediate value or a different part of the problem, but stops one step short of answering the final question.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "mcq",
          "whatWentWrong": "He correctly found the amount of paint used, but forgot that the question asked for the amount left."
        },
        {
          "questionRef": "[4]",
          "type": "mcq",
          "whatWentWrong": "He found the number of coins, but stopped before calculating how many more postcards there were."
        },
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "He found the total difference in stickers, but missed the final step of dividing by 2 to find the amount given."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs to double-check your final step:\n- **'left with'** → subtract the amount used from the total\n- **'how many more'** → remember to do the final subtraction between the two items\n- Always underline the **final question word** before you start calculating.",
      "trigger_keywords": [
        "left with",
        "how many more",
        "altogether"
      ]
    },
    {
      "name": "Leaving Questions Blank",
      "what": "Occasionally skips questions entirely, especially when they involve algebra, multiple steps, or patterns.",
      "specific_examples": [
        {
          "questionRef": "[30]",
          "type": "oeq",
          "whatWentWrong": "He left this question about average savings completely blank."
        },
        {
          "questionRef": "[36]",
          "type": "oeq",
          "whatWentWrong": "He skipped this multi-step word problem about pencils and erasers."
        },
        {
          "questionRef": "[63]",
          "type": "mcq",
          "whatWentWrong": "He left this number pattern sequence blank instead of taking a guess."
        }
      ],
      "strategic_advice": "When you feel stuck on a question, try these steps instead of leaving it blank:\n- **Write down what you know** → even just writing the first step or drawing a model can earn you method marks.\n- For **MCQs**, always make your best guess by eliminating the answers you know are wrong.\n- For **patterns**, write the difference between each number to see if a rule appears.",
      "trigger_keywords": [
        "average",
        "in terms of",
        "pattern"
      ]
    },
    {
      "name": "Missing Units or Conversions",
      "what": "Tends to leave out the final units (like degrees or million dollars) or forgets to convert between units (like cents to dollars).",
      "specific_examples": [
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "He read the graph correctly to get 56, but lost marks for forgetting to write 'million dollars'."
        },
        {
          "questionRef": "[10]",
          "type": "mcq",
          "whatWentWrong": "He set up the algebra correctly but forgot to convert the cents into dollars."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'cm' instead of 'cm²' for his final answer in this area question."
        }
      ],
      "strategic_advice": "When you finish a calculation, do a quick check for units:\n- **Money** → check if the question mixes **cents and dollars**, and divide by 100 if needed.\n- **Area** → always use **square units** like cm² or m².\n- **Graphs** → look at the axis labels to see if the numbers represent **thousands or millions**.",
      "trigger_keywords": [
        "in terms of $",
        "value of",
        "area"
      ]
    },
    {
      "name": "Wrong Total Mix-Up",
      "what": "Sometimes uses the leftover amount or the grand total as the base for a fraction or percentage, instead of the specific group asked for.",
      "specific_examples": [
        {
          "questionRef": "[59]",
          "type": "mcq",
          "whatWentWrong": "He calculated the percentage decrease using the leftover marbles instead of the original total."
        },
        {
          "questionRef": "[61]",
          "type": "mcq",
          "whatWentWrong": "He found the fraction of savings out of the total money, rather than comparing spending to savings as asked."
        }
      ],
      "strategic_advice": "When a question asks for a fraction or percentage, be careful about which number goes on the bottom:\n- **'percentage decrease'** → always divide by the **original starting amount**, not the leftover.\n- **'fraction of [A] is [B]'** → the number for **[A]** is your total (the denominator), and **[B]** is the part (the numerator).",
      "trigger_keywords": [
        "percentage decrease",
        "fraction of",
        "remainder"
      ]
    }
  ],

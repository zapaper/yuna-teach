{
  "patterns": [
    {
      "name": "Stopping Too Early",
      "what": "Kaiyangnggg often does the hard work to find an intermediate value, but occasionally forgets to complete the final step requested by the question.",
      "specific_examples": [
        {
          "questionRef": "[34]",
          "type": "mcq",
          "whatWentWrong": "He correctly calculated the fraction of paint used (1/12), but the question asked for the fraction of paint left (1/6)."
        },
        {
          "questionRef": "[51]",
          "type": "oeq",
          "whatWentWrong": "He correctly found the total number of stickers needed to balance the amounts (42), but stopped before dividing by 2 to find how many Jamie actually gave."
        }
      ],
      "strategic_advice": "When you finish your calculation, make it a habit to re-read the last sentence of the question. Ask yourself: **'Did I answer what they are asking for?'**\n- If the question asks for **'left with'** or **'remaining'**, subtract your used amount from the total.\n- If the question asks for a **'difference'**, make sure you have done the final subtraction step.",
      "trigger_keywords": [
        "left with",
        "remaining",
        "difference",
        "in the end"
      ]
    },
    {
      "name": "Order of Operations",
      "what": "Kaiyangnggg sometimes calculates number sentences from left to right instead of following the correct order of operations (multiplication and division before addition and subtraction).",
      "specific_examples": [
        {
          "questionRef": "[3]",
          "type": "mcq",
          "whatWentWrong": "He added 30 and 60 first, then multiplied by 10, instead of doing the multiplication (60 × 10) before the addition."
        },
        {
          "questionRef": "[101]",
          "type": "mcq",
          "whatWentWrong": "He likely added numbers out of order instead of strictly following the rule to multiply and divide before adding."
        }
      ],
      "strategic_advice": "Always remember the **BODMAS** rule when you see a mix of plus, minus, times, and divide signs.\n- **Bracket** first, then **Multiply/Divide**, and finally **Add/Subtract**.\n- Use your pencil to **underline the multiplication or division parts** first so you remember to do them before adding or subtracting.",
      "trigger_keywords": [
        "estimate the value of",
        "find the value of",
        "+",
        "×",
        "÷"
      ]
    },
    {
      "name": "Percentage Base Mix-Up",
      "what": "Kaiyangnggg occasionally calculates percentage changes using the leftover amount as the base, rather than the original starting amount.",
      "specific_examples": [
        {
          "questionRef": "[92]",
          "type": "mcq",
          "whatWentWrong": "He calculated the percentage decrease using the leftover marbles (280) instead of the original total (350), resulting in 25% instead of 20%."
        },
        {
          "questionRef": "[102]",
          "type": "mcq",
          "whatWentWrong": "He made the same slip here, dividing the decrease by the final amount rather than the starting amount."
        }
      ],
      "strategic_advice": "When finding a percentage increase or decrease, the bottom number of your fraction must always be the **original amount** (what you started with).\n- Formula to remember: **(Change ÷ Original) × 100**.\n- Look for the words **'at first'** or the starting number in the story, and circle it so you know what to divide by.",
      "trigger_keywords": [
        "percentage decrease",
        "percentage increase",
        "at first",
        "left"
      ]
    },
    {
      "name": "Place Value Slips",
      "what": "Kaiyangnggg tends to misalign digits when converting fractions to decimals or when reading and writing large numbers.",
      "specific_examples": [
        {
          "questionRef": "[12]",
          "type": "mcq",
          "whatWentWrong": "He added 3/100 and 30/1000 incorrectly, missing that 30/1000 is the same as 3/100, which should add up to 0.06."
        },
        {
          "questionRef": "[17]",
          "type": "mcq",
          "whatWentWrong": "He chose 4086 for 'Forty thousand and eighty-six', missing the zero in the hundreds place (40 086)."
        },
        {
          "questionRef": "[97]",
          "type": "mcq",
          "whatWentWrong": "He picked 40 160 for 502 × 800, missing a zero at the end of the large number."
        }
      ],
      "strategic_advice": "When dealing with large numbers or decimals, draw out **place value blanks** (___ ___ , ___ ___ ___) before filling in the digits.\n- For decimals, write them out vertically and **line up the decimal points** before adding.\n- For words to numbers, write the thousands first, put a comma, and then make sure you have three digits after the comma.",
      "trigger_keywords": [
        "in numerals",
        "find the value",
        "100",
        "1000"
      ]
    }
  ],

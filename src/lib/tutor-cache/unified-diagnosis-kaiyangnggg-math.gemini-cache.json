    {
      "name": "One Step Short",
      "what": "Sometimes calculates a correct middle step, like the amount used or the number of coins, but stops before answering the final question.",
      "specific_examples": [
        {
          "questionRef": "[49]",
          "type": "mcq",
          "whatWentWrong": "Kaiyangnggg correctly found the amount of paint used, but forgot to subtract it from the total to find the amount left."
        },
        {
          "questionRef": "[4]",
          "type": "mcq",
          "whatWentWrong": "He successfully calculated the number of coins, but stopped there instead of finding how many more postcards there were."
        },
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg found the total difference in stickers perfectly, but missed the final step of dividing by 2."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs:\n- **'left with'** or **'remaining'** → subtract the amount used from the total\n- **'how many more'** → find both values first, then subtract them\n- Always re-read the **last sentence** of the question before writing your final answer.",
      "trigger_keywords": [
        "left with",
        "how many more",
        "in the end",
        "altogether"
      ]
    },
    {
      "name": "Skipping Small Words",
      "what": "Occasionally reads past crucial condition words like 'even' or 'without', or misses the specific reference group in a fraction or percentage.",
      "specific_examples": [
        {
          "questionRef": "[6]",
          "type": "oeq",
          "whatWentWrong": "He found consecutive numbers, but missed the word 'even' and used odd numbers instead."
        },
        {
          "questionRef": "[13]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg wrote a great 4-digit even number, but accidentally used digits that the question said 'without using'."
        },
        {
          "questionRef": "[51]",
          "type": "mcq",
          "whatWentWrong": "He subtracted the percentages directly instead of calculating 60% 'of the remainder'."
        }
      ],
      "strategic_advice": "Small words can completely change the math! Try this:\n- **Circle condition words** like 'even', 'odd', or 'without' so they stand out.\n- When you see **'of the remainder'**, calculate the leftover amount first before multiplying.\n- For **'fraction of [A] is [B]'**, make sure [A] is your base (denominator).",
      "trigger_keywords": [
        "even",
        "without",
        "of the remainder",
        "fraction of"
      ]
    },
    {
      "name": "Forgotten Units",
      "what": "Sometimes leaves out or mixes up the final unit of measurement, like degrees, millions, or squared centimeters, which leads to dropped marks.",
      "specific_examples": [
        {
          "questionRef": "[7]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg calculated the correct angle of 43, but forgot to write the degree symbol (°)."
        },
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "He found the number 56 on the graph, but left out the words 'million dollars'."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "He wrote the final area in 'cm' instead of the correct square units 'cm²'."
        }
      ],
      "strategic_advice": "Units are just as important as the numbers!\n- When finding an angle, always add the **degree symbol (°)**.\n- For area, remember to use **square units (cm² or m²)**.\n- Check the graph or table axes to see if the numbers are in **thousands or millions**.",
      "trigger_keywords": [
        "find ∠",
        "value of",
        "area of",
        "in terms of"
      ]
    },
    {

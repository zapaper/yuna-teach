{
  "patterns": [
    {
      "name": "Subject-Verb Agreement Mix-Up",
      "what": "Tylerng occasionally matches the verb to the noun closest to it, rather than the main subject, especially when extra phrases are in the middle.",
      "specific_examples": [
        {
          "questionRef": "[32]",
          "type": "mcq",
          "whatWentWrong": "He saw 'brothers' right before the blank and chose the plural 'are', missing that the main subject is the singular 'Emily'."
        },
        {
          "questionRef": "[40]",
          "type": "mcq",
          "whatWentWrong": "He chose 'is' by looking at 'my cousin', forgetting that the main subject at the start of the sentence is 'I', which pairs with 'am'."
        }
      ],
      "strategic_advice": "When you see phrases like **'together with'**, **'as well as'**, or **'along with'**, try crossing them out lightly with your pencil. This helps you spot the true main subject so you can choose the correct singular or plural verb.",
      "trigger_keywords": [
        "together with",
        "as well as",
        "along with",
        "either",
        "neither"
      ]
    },
    {
      "name": "Hidden Negatives in Tags",
      "what": "Tylerng sometimes misses words that make a sentence negative, leading him to choose a negative question tag instead of a positive one.",
      "specific_examples": [
        {
          "questionRef": "[19]",
          "type": "mcq",
          "whatWentWrong": "He chose 'doesn't he', missing that the word 'seldom' already makes the sentence negative."
        },
        {
          "questionRef": "[33]",
          "type": "mcq",
          "whatWentWrong": "He made the same slip here, forgetting that a negative sentence needs a positive question tag like 'does he'."
        }
      ],
      "strategic_advice": "When you see words like **'seldom'**, **'rarely'**, **'barely'**, or **'never'**, treat the sentence as negative. This means the question tag at the end must be positive!",
      "trigger_keywords": [
        "seldom",
        "rarely",
        "barely",
        "never",
        "scarcely"
      ]
    },
    {
      "name": "Phrasal Verbs and Idioms",
      "what": "Tylerng tends to mix up idioms or phrasal verbs that look similar, sometimes picking an option that doesn't quite fit the sentence's meaning.",
      "specific_examples": [
        {
          "questionRef": "[37]",
          "type": "mcq",
          "whatWentWrong": "He chose 'taken up' instead of 'taken in', which is the correct phrase for being tricked or fooled."
        },
        {
          "questionRef": "[45]",
          "type": "mcq",
          "whatWentWrong": "He picked 'the apple of my eye' (which refers to a cherished person) instead of 'the cherry on top' (which means a great finishing touch)."
        }
      ],
      "strategic_advice": "When tested on phrasal verbs or idioms, try to read the whole sentence and guess the meaning before looking at the options. If you're unsure, eliminate the ones that definitely don't make sense in context.",
      "trigger_keywords": [
        "taken in",
        "taken up",
        "cherry on top",
        "apple of my eye",
        "pain in the neck"
      ]
    },
    {
      "name": "Who vs Whose Mix-Up",
      "what": "Tylerng occasionally confuses relative pronouns, sometimes missing when to use 'whose' to show that something belongs to someone.",
      "specific_examples": [
        {
          "questionRef": "[22]",
          "type": "mcq",
          "whatWentWrong": "He missed that the wallet belongs to the owner, which requires the possessive pronoun 'whose'."
        },
        {
          "questionRef": "[51]",
          "type": "mcq",
          "whatWentWrong": "He chose 'whom' instead of 'whose', not noticing that the mother belongs to the man being talked about."
        }
      ],
      "strategic_advice": "When deciding between **'who'**, **'whom'**, and **'whose'**, check the word right after the blank. If it's a noun that belongs to the person (like 'mother' or 'owner'), **'whose'** is the right choice!",
      "trigger_keywords": [
        "who",
        "whom",
        "whose",
        "which"
      ]
    }
  ],

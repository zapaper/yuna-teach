{
  "patterns": [
    {
      "name": "Subject-Verb Agreement Traps",
      "what": "Tylerng sometimes gets tricked by extra phrases like 'together with' or 'as well as' that separate the main subject from the action.",
      "specific_examples": [
        {
          "questionRef": "[32]",
          "type": "mcq",
          "whatWentWrong": "Tylerng saw 'her brothers' right before the blank and chose the plural 'are', forgetting that the main subject 'Emily' is singular."
        },
        {
          "questionRef": "[40]",
          "type": "mcq",
          "whatWentWrong": "He chose 'is' by looking at 'my cousin', missing that the main subject is 'I', which pairs with 'am'."
        },
        {
          "questionRef": "[52]",
          "type": "mcq",
          "whatWentWrong": "He picked the plural 'were' because of 'her cousins', overlooking that the sentence is actually about 'Jane'."
        }
      ],
      "strategic_advice": "When you see phrases like 'together with', 'as well as', or 'along with', **cross them out lightly** with your pencil. This helps you spot the true main subject at the start of the sentence. Then, match your verb to that main subject!",
      "trigger_keywords": [
        "together with",
        "as well as",
        "along with",
        "either",
        "neither"
      ]
    },
    {
      "name": "Spotting Hidden Negatives and Contrasts",
      "what": "Tylerng occasionally misses 'hidden' negative words or contrast clues that completely flip the meaning of the sentence.",
      "specific_examples": [
        {
          "questionRef": "[33]",
          "type": "mcq",
          "whatWentWrong": "Tylerng missed the negative meaning of 'seldom' and chose 'doesn't he' instead of the correct positive tag 'does he'."
        },
        {
          "questionRef": "[47]",
          "type": "mcq",
          "whatWentWrong": "He overlooked the bolded word 'not' in the question, leading him to pick a statement that was actually true."
        },
        {
          "questionRef": "[41]",
          "type": "mcq",
          "whatWentWrong": "He chose 'Although' instead of 'Except for', missing the contrast clue that Jane was in London while the rest attended the party."
        }
      ],
      "strategic_advice": "When you read a question, always **circle negative words** like 'not', 'seldom', 'rarely', or 'never'. If the sentence has a contrast word like 'but', 'although', or 'despite', **draw an arrow** to remind yourself that the second half of the sentence will be the opposite of the first half.",
      "trigger_keywords": [
        "seldom",
        "not",
        "but",
        "although",
        "despite",
        "except",
        "however"
      ]
    },
    {
      "name": "Decoding Phrasal Verbs and Idioms",
      "what": "Tylerng tends to find phrasal verbs and idioms a bit tricky, sometimes picking options that sound literal rather than their special figurative meaning.",
      "specific_examples": [
        {
          "questionRef": "[45]",
          "type": "mcq",
          "whatWentWrong": "Tylerng picked 'the apple of my eye' instead of 'the cherry on top' to describe a final, wonderful addition to a great camp."
        },
        {
          "questionRef": "[43]",
          "type": "mcq",
          "whatWentWrong": "He chose 'taken off' instead of 'taken in', not realising that 'taken in' is the specific phrasal verb for being tricked or fooled."
        },
        {
          "questionRef": "[36]",
          "type": "mcq",
          "whatWentWrong": "He selected 'bitter pill to swallow' rather than 'pain in the neck' to describe an annoying younger brother."
        }
      ],
      "strategic_advice": "When faced with idioms or phrasal verbs, try to **visualise the situation** rather than just reading the words literally. If you are unsure, **use the elimination method** to cross out the ones you know definitely don't fit the context of the sentence.",
      "trigger_keywords": [
        "told",
        "set",
        "taken",
        "cherry",
        "pain",
        "apple"
      ]
    },
    {
      "name": "Checking Immediate Grammatical Fit",
      "what": "In cloze passages and relative clauses, Tylerng sometimes fills in a word without checking if it matches the grammar of the words immediately before and after it.",
      "specific_examples": [
        {
          "questionRef": "[64]",
          "type": "oeq",
          "whatWentWrong": "Tylerng wrote 'line' after the word 'an', missing the grammatical rule that 'an' must be followed by a word starting with a vowel sound, like 'attempt'."
        },
        {
          "questionRef": "[63]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'variety' in the phrase 'include a ___ workers', missing that 'variety' would need the word 'of' right after it to be grammatically correct."
        },
        {
          "questionRef": "[51]",
          "type": "mcq",
          "whatWentWrong": "He chose 'whom' instead of 'whose', not noticing that the immediate next word 'mother' requires a possessive word to show it is the man's mother."
        }
      ],
      "strategic_advice": "After filling in a blank, always **read the three words before and the three words after** it aloud in your head. Check for clues like 'a' vs 'an', missing prepositions like 'of', or nouns that belong to someone (which need 'whose').",
      "trigger_keywords": [
        "blank",
        "passage",
        "fill in",
        "choose the word",
        "who",
        "whom",
        "whose"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "Extra Subject Words",
      "what": "Sometimes gets tricked when matching subjects to their verbs, especially when there are extra phrases like 'together with' or 'as well as' in the middle.",
      "specific_examples": [
        {
          "questionRef": "[32]",
          "type": "mcq",
          "whatWentWrong": "Tylerng picked 'are' instead of 'is' because the phrase 'together with her brothers' made the subject look plural."
        },
        {
          "questionRef": "[40]",
          "type": "mcq",
          "whatWentWrong": "He chose 'is' instead of 'am' for the subject 'I', getting distracted by the extra words 'as well as my cousin'."
        },
        {
          "questionRef": "[56]",
          "type": "oeq",
          "whatWentWrong": "Tylerng wrote 'has' instead of 'have' for the plural subject 'otters'."
        }
      ],
      "strategic_advice": "When you see phrases like **'together with'**, **'as well as'**, or **'along with'**, cross them out lightly with your pencil. The true subject is the very first person or thing mentioned! For basic sentences, always double-check if the main noun is singular or plural before picking your verb.",
      "trigger_keywords": [
        "together with",
        "as well as",
        "Either ... or",
        "has / have",
        "is / are"
      ]
    },
    {
      "name": "Phrasal Verbs and Idioms",
      "what": "Occasionally mixes up common idioms and phrasal verbs that look or sound similar.",
      "specific_examples": [
        {
          "questionRef": "[45]",
          "type": "mcq",
          "whatWentWrong": "Tylerng chose 'the apple of my eye' instead of 'the cherry on top' to describe a wonderful final touch to a camp."
        },
        {
          "questionRef": "[43]",
          "type": "mcq",
          "whatWentWrong": "He picked 'taken off' instead of 'taken in' when describing being tricked by a magician."
        },
        {
          "questionRef": "[36]",
          "type": "mcq",
          "whatWentWrong": "Tylerng selected 'bitter pill to swallow' instead of 'pain in the neck' for an annoying younger brother."
        }
      ],
      "strategic_advice": "Idioms and phrasal verbs can be tricky because you cannot guess their meaning just by looking at the individual words. When you learn a new one like **'taken in'** or **'cherry on top'**, try drawing a quick silly picture of what it means, or write a sentence about someone you know using that phrase!",
      "trigger_keywords": [
        "taken in",
        "cherry on top",
        "pain in the neck",
        "told off"
      ]
    },
    {
      "name": "Contrast Word Traps",
      "what": "Tends to overlook contrast words that signal a shift in meaning, leading to answers that don't quite fit the context.",
      "specific_examples": [
        {
          "questionRef": "[61]",
          "type": "oeq",
          "whatWentWrong": "Tylerng wrote 'many' instead of 'permanent', missing the contrast word 'Unlike' which pairs with 'temporary nests'."
        },
        {
          "questionRef": "[31]",
          "type": "mcq",
          "whatWentWrong": "He chose 'so' instead of 'nevertheless', missing the contrast set up by the word 'but' earlier in the sentence."
        },
        {
          "questionRef": "[41]",
          "type": "mcq",
          "whatWentWrong": "Tylerng picked 'Although' instead of 'Except for' when the sentence contrasted Jane's absence with everyone else attending."
        }
      ],
      "strategic_advice": "When you spot contrast words like **'Unlike'**, **'but'**, or **'Although'**, treat them as a U-turn sign! They mean the second half of the sentence will be the opposite of the first half. **Highlight or circle** these words so you remember to look for an answer that shows a change in direction.",
      "trigger_keywords": [
        "Unlike",
        "but",
        "Although",
        "Despite",
        "nevertheless"
      ]
    },
    {
      "name": "Hidden Negative Words",
      "what": "Sometimes reads past negative words like 'seldom' or 'not', which completely flips the correct answer.",
      "specific_examples": [
        {
          "questionRef": "[33]",
          "type": "mcq",
          "whatWentWrong": "Tylerng picked 'doesn't he' instead of 'does he', missing that 'seldom' is a hidden negative word that requires a positive question tag."
        },
        {
          "questionRef": "[47]",
          "type": "mcq",
          "whatWentWrong": "He chose an option that was true, missing the bolded 'not' in the question."
        },
        {
          "questionRef": "[50]",
          "type": "mcq",
          "whatWentWrong": "Tylerng missed the negative phrasing 'not supported' when comparing the two visual texts."
        }
      ],
      "strategic_advice": "Negative words are small but mighty! When you see words like **'not'**, **'never'**, **'seldom'**, or **'false'**, circle them immediately. For question tags, remember that a negative word in the sentence means the tag at the end must be **positive**.",
      "trigger_keywords": [
        "seldom",
        "not true",
        "not supported",
        "never"
      ]
    }

{
  "patterns": [
    {
      "name": "Getting Tricked by Extra Nouns",
      "what": "Tylerng occasionally matches the verb to the noun closest to it, forgetting to check the actual main subject when extra phrases are added.",
      "specific_examples": [
        {
          "questionRef": "[20]",
          "type": "mcq",
          "whatWentWrong": "Tylerng was distracted by the plural noun 'brothers' and missed that the main subject 'Emily' is singular."
        },
        {
          "questionRef": "[40]",
          "type": "mcq",
          "whatWentWrong": "Tylerng looked at 'cousin' instead of the main subject 'I', which requires the verb 'am'."
        },
        {
          "questionRef": "[52]",
          "type": "mcq",
          "whatWentWrong": "He matched the verb to the plural 'cousins' instead of the singular main subject 'Jane'."
        }
      ],
      "strategic_advice": "When you see phrases like 'together with' or 'as well as', use your pencil to **bracket and cross out** that extra information. This will help you spot the true **main subject** so you can choose the correct singular or plural verb.",
      "trigger_keywords": [
        "together with",
        "as well as",
        "along with",
        "Either",
        "Neither"
      ]
    },
    {
      "name": "Missing Hidden Negative Words",
      "what": "Tylerng tends to read quickly and occasionally misses 'hidden' negative words that completely change the meaning of the sentence.",
      "specific_examples": [
        {
          "questionRef": "[2]",
          "type": "mcq",
          "whatWentWrong": "Tylerng missed that 'seldom' is a negative word, which means the question tag must be positive."
        },
        {
          "questionRef": "[47]",
          "type": "mcq",
          "whatWentWrong": "He overlooked the word 'not' in the question and chose a statement that was true instead of false."
        },
        {
          "questionRef": "[50]",
          "type": "mcq",
          "whatWentWrong": "Tylerng missed the phrase 'not supported' and chose an option that didn't answer the specific question asked."
        }
      ],
      "strategic_advice": "When you see words like 'seldom', 'rarely', or 'not', **circle them immediately**. Remember that a negative statement like 'seldom goes' needs a **positive question tag** like 'does he', and a 'not true' question means you are looking for the false statement.",
      "trigger_keywords": [
        "seldom",
        "rarely",
        "not true",
        "not supported",
        "cannot"
      ]
    },
    {
      "name": "Misaligned Answer Entries",
      "what": "Tylerng sometimes figures out the correct word but accidentally types or writes it in the wrong box, shifting his answers out of sync with the question numbers.",
      "specific_examples": [
        {
          "questionRef": "[56]",
          "type": "oeq",
          "whatWentWrong": "Tylerng correctly identified the answer for an earlier blank but accidentally typed it into the wrong question slot, causing a chain of shifted answers."
        },
        {
          "questionRef": "[61]",
          "type": "oeq",
          "whatWentWrong": "He correctly fixed 'express' to 'expressing' for blank 36, but entered it into the slot for blank 40."
        },
        {
          "questionRef": "[62]",
          "type": "oeq",
          "whatWentWrong": "Tylerng correctly fixed 'physicle' to 'physical' for blank 37, but entered it into the slot for blank 41."
        }
      ],
      "strategic_advice": "When transferring your answers, always double-check the **question number** against the **blank number** in the passage. Point to the number on your paper, then point to the same number on the screen or answer sheet before writing.",
      "trigger_keywords": [
        "passage",
        "blank",
        "Write its letter",
        "Editing"
      ]
    },
    {
      "name": "Overlooking Surrounding Context Clues",
      "what": "Tylerng sometimes picks a vocabulary word that sounds okay on its own, but might not fit the specific clues hidden in the surrounding sentences.",
      "specific_examples": [
        {
          "questionRef": "[26]",
          "type": "mcq",
          "whatWentWrong": "Tylerng chose 'burden', but 'drawback' is the better vocabulary word to describe a disadvantage of public transport."
        },
        {
          "questionRef": "[53]",
          "type": "mcq",
          "whatWentWrong": "Tylerng chose 'anything', but the clue 'wanted others to have a chance' means she didn't say 'everything'."
        },
        {
          "questionRef": "[67]",
          "type": "oeq",
          "whatWentWrong": "He missed the contrast word 'Unlike' and the clue 'temporary', which point to 'permanent' as the correct answer."
        }
      ],
      "strategic_advice": "Before choosing a word, look for **contrast words** like 'Unlike' or **descriptive clues** in the sentence. Try plugging your chosen word into the blank and read the **whole sentence aloud** in your head to ensure it makes logical sense.",
      "trigger_keywords": [
        "Unlike",
        "because",
        "Despite",
        "However",
        "fill in each blank"
      ]
    }

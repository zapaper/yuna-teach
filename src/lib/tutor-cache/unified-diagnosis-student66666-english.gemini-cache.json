    {
      "name": "Missing Clue Words",
      "what": "Student66666 sometimes misses contrast words like 'although', which changes the tone of the sentence, leading to answers that mean the opposite of what is needed.",
      "specific_examples": [
        {
          "questionRef": "[19]",
          "type": "oeq",
          "whatWentWrong": "He missed the contrast word 'Although' and wrote 'useful' instead of a word like 'hard' or 'difficult'."
        },
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "He chose 'affect', which is neutral, instead of a positive word like 'enhance' to match the benefits described in the passage."
        },
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'first' instead of a connector like 'Hence' that shows a consequence or reason."
        }
      ],
      "strategic_advice": "When you see words like **'Although'** or **'However'**, treat them as a U-turn sign—the sentence is going to shift from positive to negative, or easy to hard. Always read the sentence before and after the blank to check if the overall tone is positive or negative.",
      "trigger_keywords": [
        "Although",
        "However",
        "Thus",
        "Hence"
      ]
    },
    {
      "name": "Pronoun Mix-Up",
      "what": "Student66666 occasionally loses track of who the passage is talking about, switching perspectives or repeating a name instead of using a pronoun.",
      "specific_examples": [
        {
          "questionRef": "[16]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'your', which changes the perspective from the collective 'our' used throughout the rest of the passage."
        },
        {
          "questionRef": "[29]",
          "type": "oeq",
          "whatWentWrong": "He repeated 'Sam' in the second half of the sentence instead of replacing it with the pronoun 'he'."
        }
      ],
      "strategic_advice": "When filling in pronouns, check the rest of the paragraph to see who is speaking. If the passage uses **'we'** and **'our'**, stick to those instead of switching to **'your'**. In synthesis questions, remember to replace a person's name with **'he'** or **'she'** in the second half of the sentence.",
      "trigger_keywords": [
        "our",
        "we",
        "he",
        "she",
        "your"
      ]
    },
    {
      "name": "Spelling and Capital Letters",
      "what": "Student66666 tends to make small typing or spelling slips, and occasionally forgets to use a capital letter when a word starts a new sentence.",
      "specific_examples": [
        {
          "questionRef": "[8]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'when' with a lowercase letter, even though it was the first word of a new sentence."

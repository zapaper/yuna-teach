{
  "patterns": [
    {
      "name": "Pollination vs Seed Dispersal",
      "what": "Mark sometimes mixes up the process of pollination (making seeds) with seed dispersal (spreading seeds to new places).",
      "specific_examples": [
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "He thought the plant spread because an animal pollinated it, rather than explaining that another animal ate the fruits and dropped the seeds elsewhere."
        },
        {
          "questionRef": "[79]",
          "type": "oeq",
          "whatWentWrong": "He mentioned pollination helping the plant reproduce, missing that the animal eating the fruits is the one spreading the seeds to a wider area."
        }
      ],
      "strategic_advice": "When you see questions about a plant **'covering a wider area'**, think about how its seeds travel.\n- **Pollination** (nectar, flowers) helps make the fruit.\n- **Seed dispersal** (eating fruits, wind, hooks) is what spreads the plant to new places.",
      "trigger_keywords": [
        "covered a wider area",
        "reproduce",
        "fruits",
        "seeds",
        "nectar"
      ]
    },
    {
      "name": "One Step Short",
      "what": "Mark often explains the science beautifully but occasionally stops one step short of stating the final consequence or outcome.",
      "specific_examples": [
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "He correctly noted that the plant couldn't make food and that bacteria respire, but missed the final steps: the plant dies, and the bacteria use up the oxygen."
        },
        {
          "questionRef": "[133]",
          "type": "oeq",
          "whatWentWrong": "He perfectly explained how the electromagnet attracts the iron bolt, but stopped just short of saying this moves the bolt away from the catch to unlock the door."
        },
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "He knew the lid gained heat and expanded, but forgot to add the final detail that the plastic lid expanded more than the glass jar."
        }
      ],
      "strategic_advice": "When you see **'explain why'** or **'give a reason'**, always ask yourself 'and then what happens?' at the end of your answer.\n- If a plant can't get light, don't just say it can't make food — add **'so it dies'**.\n- If bacteria respire, add **'so they use up oxygen'**.",
      "trigger_keywords": [
        "explain why",
        "give a reason how",
        "caused a decrease",
        "explain how"
      ]
    },
    {
      "name": "Vague Data Trends",
      "what": "When asked to describe a pattern from a table or graph, Mark tends to give a general summary instead of stating exactly how the numbers change.",
      "specific_examples": [
        {
          "questionRef": "[42]",
          "type": "oeq",
          "whatWentWrong": "Instead of detailing how hatching increases up to 28°C and then decreases, he gave a general statement about temperature affecting hatching."
        },
        {
          "questionRef": "[145]",
          "type": "oeq",
          "whatWentWrong": "He noticed the toy jumped higher with more rubber bands, but missed the second part of the trend where the height stayed the same after 4 bands."
        },
        {
          "questionRef": "[143]",
          "type": "oeq",
          "whatWentWrong": "He simply wrote 'It decreased' without using evidence from the graph or explaining the scientific reason behind the lower heart rate."
        }
      ],
      "strategic_advice": "When you see **'describe what [someone] could conclude'** or **'state the relationship'**, treat it like a map:\n- Mention the specific turning points (e.g., **'as temperature increases from 22°C to 28°C...'**).\n- State both halves of the pattern (e.g., **'it increases, but then it decreases'**).",
      "trigger_keywords": [
        "describe what",
        "conclude about the effect",
        "relationship between",
        "changes in"
      ]
    },
    {
      "name": "Skipping Question Parts",
      "what": "Mark occasionally misses a part of a question, especially when there are multiple questions grouped together under one letter.",
      "specific_examples": [
        {
          "questionRef": "[44]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified the most polluted lake for part (ii), but accidentally left part (i) about how shadows are formed completely blank."
        },
        {
          "questionRef": "[136]",
          "type": "oeq",
          "whatWentWrong": "He nailed the first part about the digestive organs, but skipped the second part asking to explain the changes in the amount of digested food."
        },
        {
          "questionRef": "[139]",
          "type": "oeq",
          "whatWentWrong": "He accurately described the heart rate changes and explained the decrease, but missed answering part (b)(ii) entirely."
        }
      ],
      "strategic_advice": "When you see a question with multiple parts like **'(a) (i)'** and **'(ii)'**, use your pencil to circle each roman numeral.\n- Before moving to the next page, do a quick check to ensure every circled part has an answer written down.",
      "trigger_keywords": [
        "(i)",
        "(ii)",
        "state how",
        "explain"
      ]
    }
  ],

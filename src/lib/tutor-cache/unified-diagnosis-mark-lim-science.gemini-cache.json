{
  "patterns": [
    {
      "name": "One Step Short",
      "what": "Often correctly identifies the first part of a scientific process but occasionally stops before stating the final consequence or comparing the two objects involved.",
      "specific_examples": [
        {
          "questionRef": "[28]",
          "type": "oeq",
          "whatWentWrong": "He correctly noted there would be less food for the birds, but stopped before stating that the birds would then move away or die."
        },
        {
          "questionRef": "[47]",
          "type": "oeq",
          "whatWentWrong": "He explained that the electromagnet attracts the iron bolt, but missed the final step that the bolt moves away from the catch to unlock the door."
        },
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "He mentioned that the lid expanded when heated, but forgot to compare it by stating it expanded more than the glass jar."
        }
      ],
      "strategic_advice": "When you see **'explain why'** or **'describe how'**, ask yourself 'And then what happens?' until you reach the final result. If there are two materials or animals, always **compare both** in your answer.",
      "trigger_keywords": [
        "explain why",
        "describe how",
        "explain how"
      ]
    },
    {
      "name": "Energy Conversion Mix-Up",
      "what": "Sometimes confuses forces with energy, or misses the specific energy changes when explaining how things move or make a sound.",
      "specific_examples": [
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "He tried to explain the block dropping using forces and gravity, instead of describing how gravitational potential energy converts to kinetic energy."
        },
        {
          "questionRef": "[16]",
          "type": "oeq",
          "whatWentWrong": "He correctly knew the marble would take a shorter time with less friction, but missed explaining it using the conversion of potential energy to kinetic energy."
        }
      ],
      "strategic_advice": "When a question asks you to explain **'in terms of energy changes'** or involves objects dropping or rolling, always use the energy keywords:\n- **Gravitational potential energy** (for height)\n- **Kinetic energy** (for movement)\n- **Heat or sound energy** (for impact or friction)",
      "trigger_keywords": [
        "in terms of energy",
        "energy changes",
        "dropped",
        "rolled down"
      ]
    },
    {
      "name": "Reading Data Trends",
      "what": "Tends to describe only the first half of the pattern when looking at graphs or tables, or occasionally misreads the direction of the line.",
      "specific_examples": [
        {
          "questionRef": "[42]",
          "type": "oeq",
          "whatWentWrong": "He gave a vague answer about temperature instead of clearly stating that hatching increases up to 28°C and then decreases."
        },
        {
          "questionRef": "[59]",
          "type": "oeq",
          "whatWentWrong": "He noticed that the jump height increased with more rubber bands, but missed the second part of the data where the height stayed the same from 4 to 6 bands."
        },
        {
          "questionRef": "[33]",
          "type": "oeq",
          "whatWentWrong": "He incorrectly stated that the population decreases, when the graph line was actually going up."
        }
      ],
      "strategic_advice": "When you see a graph or table, trace the line with your finger. If the line changes direction or goes flat, your answer must have **two parts** (e.g., 'It increases until X, and then it decreases or stays the same').",
      "trigger_keywords": [
        "based on the graph",
        "describe the changes",
        "relationship between"
      ]
    },
    {
      "name": "Circuit Cycle Confusion",
      "what": "Occasionally misses the exact sequence of events in an electromagnet circuit, especially how the circuit opening and closing affects other components like bulbs.",
      "specific_examples": [
        {
          "questionRef": "[25]",
          "type": "oeq",
          "whatWentWrong": "He described the electromagnet attracting the bar, but missed that this causes the circuit to open and the bulb to turn off."
        },
        {
          "questionRef": "[39]",
          "type": "oeq",
          "whatWentWrong": "He explained the iron bar moving, but forgot to mention that the bulb stops lighting up when the bar touches the other contacts."
        }
      ],
      "strategic_advice": "For electromagnet questions with moving parts, trace the path of electricity step-by-step:\n- Step 1: Switch closes → **closed circuit**\n- Step 2: Electromagnet turns on → **attracts iron**\n- Step 3: Iron moves → **opens circuit** (mention which bulbs turn off!)\n- Step 4: Electromagnet turns off → iron drops back.",
      "trigger_keywords": [
        "iron bar moves",
        "turns on and off repeatedly",
        "electromagnet"
      ]
    }
  ],

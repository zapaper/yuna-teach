{
  "patterns": [
    {
      "name": "Stopping One Step Short",
      "what": "Sometimes explains the first part of a science process perfectly, but occasionally forgets to state the final result or consequence.",
      "specific_examples": [
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "He correctly noted that the plant couldn't get light to make food, but forgot to state the final consequence that the plant died."
        },
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "He correctly explained that fewer algae meant less food for tadpoles, but stopped short of saying the fish would starve."
        },
        {
          "questionRef": "[116]",
          "type": "oeq",
          "whatWentWrong": "He beautifully described how the electromagnet attracts the iron bolt, but missed the final step that this unlocks the door."
        }
      ],
      "strategic_advice": "When you see prompts asking for an explanation, treat them as a chain reaction:\n- **'explain why'** → ask yourself **'What happens next?'** until you reach the final outcome.\n- **'describe how'** → use a **'so that...'** or **'which means...'** clause to connect your thoughts all the way to the end of the story.",
      "trigger_keywords": [
        "Explain why",
        "Give a reason",
        "Describe how",
        "What happens"
      ]
    },
    {
      "name": "Missing Specific Details",
      "what": "Tends to give general answers and occasionally misses out on specific data trends, exact numbers, or key context facts provided in the question.",
      "specific_examples": [
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "Instead of describing the exact temperature trend from the data table, he gave a general statement about temperature affecting hatching."
        },
        {
          "questionRef": "[17]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified who eats whom, but forgot to include the specific habitat details like which animals live on land versus in water."
        },
        {
          "questionRef": "[6]",
          "type": "oeq",
          "whatWentWrong": "He suggested to 'record the data' instead of giving the specific measurement to 'count the number of mosquitoes'."
        }
      ],
      "strategic_advice": "When a question gives you specific information, make sure to use it in your answer:\n- **'Based on the graph'** → always quote the **exact numbers** or **trends** (e.g., 'increases from 22°C to 28°C').\n- **'Describe what'** → use specific evidence from the question rather than general knowledge.",
      "trigger_keywords": [
        "Describe what",
        "Based on the graph",
        "State the relationship",
        "Based on the results"
      ]
    },
    {
      "name": "Skipping Question Parts",
      "what": "Occasionally leaves parts of a question blank, especially when a single question has multiple small sub-parts to answer.",
      "specific_examples": [
        {
          "questionRef": "[47]",
          "type": "oeq",
          "whatWentWrong": "He correctly answered part (a)(ii) about the polluted lake, but accidentally left part (a)(i) about shadow formation completely blank."
        },
        {
          "questionRef": "[119]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified the organs in part (a), but skipped the explanation required for part (b)(ii)."
        },
        {
          "questionRef": "[122]",
          "type": "oeq",
          "whatWentWrong": "He correctly described the heart rate increase in part (a), but left the explanation for part (b) blank."
        }
      ],
      "strategic_advice": "When questions have multiple parts, it's easy to accidentally skip one:\n- Do a quick **finger-point check** on every sub-letter like **(a)(i)** and **(b)(ii)** to make sure nothing is empty.\n- If you are unsure, write down your **best guess** using the science keywords you know—a partial answer can still earn marks!",
      "trigger_keywords": [
        "(a) (i)",
        "(b) (ii)",
        "Explain your answer",
        "In the diagram"
      ]
    },
    {
      "name": "Misreading the Question",
      "what": "Sometimes mixes up the roles of different items in the question or misreads the specific scenario being asked about.",
      "specific_examples": [
        {
          "questionRef": "[44]",
          "type": "oeq",
          "whatWentWrong": "He explained how Animal G pollinates the plant, but the question was actually testing how Animal H eats the fruits and disperses the seeds."
        },
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "He ordered the surfaces from roughest to smoothest, accidentally reversing the question's instruction to order from smoothest to roughest."
        },
        {
          "questionRef": "[27]",
          "type": "oeq",
          "whatWentWrong": "He explained how transparency helps the animal catch prey, missing that the question was about how it helps the animal survive by hiding from predators."
        }
      ],
      "strategic_advice": "To make sure you are answering exactly what the question is asking:\n- Use your pencil to **underline or circle** key roles and instructions in the question stem before you start writing.\n- When you see prompts like **'Which organism'** or **'Order from'**, double-check that your answer matches the exact direction or role requested.",
      "trigger_keywords": [
        "Which organism",
        "Explain why",
        "Based on the diagram",
        "Order from"
      ]
    }
  ],

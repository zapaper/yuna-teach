{
  "patterns": [
    {
      "name": "Stopping Short of Final Consequence",
      "what": "Mark sometimes explains the immediate scientific effect beautifully, but occasionally stops one step short of stating the final outcome or consequence required by the question.",
      "specific_examples": [
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "Mark correctly explained that the plant couldn't photosynthesise and that bacteria respire, but he occasionally forgets to state the final outcomes, like the plant dying and oxygen being used up."
        },
        {
          "questionRef": "[101]",
          "type": "oeq",
          "whatWentWrong": "He beautifully described how the electromagnet attracts the bolt, but stopped just short of stating the final result: that the door unlocks."
        },
        {
          "questionRef": "[25]",
          "type": "oeq",
          "whatWentWrong": "Mark correctly noted there would be less food for the birds, but he missed stating the final consequence that the birds would move away or die."
        }
      ],
      "strategic_advice": "When you see trigger words like **explain why** or **explain how**, always ask yourself 'What happens next?' Add a **so that...** or **which means...** clause to show the final consequence, such as an organism dying or a door unlocking. This ensures you get the full marks for your excellent scientific reasoning.",
      "trigger_keywords": [
        "Explain why",
        "Explain how",
        "Give a reason"
      ]
    },
    {
      "name": "Describing Trends Too Broadly",
      "what": "When asked to describe a pattern or conclude from data, Mark tends to give a general summary rather than breaking down the specific changes or measurements shown in the results.",
      "specific_examples": [
        {
          "questionRef": "[39]",
          "type": "oeq",
          "whatWentWrong": "When describing the graph's trend, Mark gave a general summary instead of pointing out the specific temperatures where the hatching increased and then decreased."
        },
        {
          "questionRef": "[6]",
          "type": "oeq",
          "whatWentWrong": "He suggested to 'record the data', which is a bit too broad, rather than specifying exactly what to measure, like 'count the number of mosquitoes'."
        },
        {
          "questionRef": "[111]",
          "type": "oeq",
          "whatWentWrong": "Mark correctly noticed the heart rate decreased, but he didn't use specific evidence from the graph or explain the specific reason why."
        }
      ],
      "strategic_advice": "When a question asks you to **describe what you can conclude** or **based on the graph**, look for turning points in the data. Instead of giving a general summary, specify the exact points, like **increases from 22°C to 28°C, then decreases**. Being specific with your data points will make your answers much stronger.",
      "trigger_keywords": [
        "Describe what",
        "Based on the graph",
        "Suggest a way",
        "What can you conclude"
      ]
    },
    {
      "name": "Leaving Out Contextual Details",
      "what": "Mark occasionally leaves out the specific structural details or comparative facts provided in the question stem that are needed to make his explanation complete.",
      "specific_examples": [
        {
          "questionRef": "[17]",
          "type": "oeq",
          "whatWentWrong": "Mark correctly identified the advantages of the nest, but he left out the specific details from the question that predator G lives on land while B and C live in water."
        },
        {
          "questionRef": "[9]",
          "type": "oeq",
          "whatWentWrong": "He understood that the lid expanded, but missed the crucial comparative detail that the plastic lid expanded more than the glass jar."
        },
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "Mark correctly concluded the spring would decrease in length, but he forgot to explicitly state the key property that wood is a non-magnetic material."
        }
      ],
      "strategic_advice": "When you see **explain your answer** or **suggest two advantages**, re-read the question stem for clues. If the question mentions 'plastic and glass' or 'land and water', make sure to include those **specific comparative words** in your answer. Tying your explanation back to the specific details in the prompt is key.",
      "trigger_keywords": [
        "Suggest two advantages",
        "Explain your answer",
        "State the property",
        "Give two reasons"
      ]
    },
    {
      "name": "Mixing Up Roles in Systems",
      "what": "In questions with multiple parts or organisms, Mark sometimes mixes up which specific organism or component is responsible for a particular action.",
      "specific_examples": [
        {
          "questionRef": "[38]",
          "type": "oeq",
          "whatWentWrong": "Mark mixed up the roles of the animals, suggesting animal G pollinates the plant to spread it, rather than animal H eating the fruits and dispersing the seeds."
        },
        {
          "questionRef": "[27]",
          "type": "oeq",
          "whatWentWrong": "He correctly identified camouflage, but slightly misread the context, suggesting it helps catch prey rather than hide from predators."
        },
        {
          "questionRef": "[34]",
          "type": "oeq",
          "whatWentWrong": "Mark placed the switch 'X' in the main circuit wire instead of specifically in the loop with the sound box, mixing up the roles of the circuit paths."
        }
      ],
      "strategic_advice": "For questions involving food webs or circuits, trace the path with your finger first. When asked to **explain why** a population changes or to **complete the circuit**, double-check the specific role of each part before writing your answer. Taking a moment to **verify each organism's or component's job** will help prevent mix-ups.",
      "trigger_keywords": [
        "Explain why",
        "How does",
        "Complete the circuit",
        "Draw a food web"
      ]
    }
  ],

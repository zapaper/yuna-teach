{
  "patterns": [
    {
      "name": "Stopping Too Early",
      "what": "Mark often does the hard work of identifying the correct scientific process, but occasionally stops one step short of stating the final consequence the question asks for.",
      "specific_examples": [
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "He correctly noted that bacteria respire, but forgot to add the final consequence that this uses up oxygen in the water."
        },
        {
          "questionRef": "[9]",
          "type": "oeq",
          "whatWentWrong": "He correctly explained that the plastic lid expanded, but missed the crucial detail that it expanded more than the glass jar."
        },
        {
          "questionRef": "[25]",
          "type": "oeq",
          "whatWentWrong": "He correctly deduced there would be fewer grasshoppers, but stopped short of stating that the birds would then die or move away."
        }
      ],
      "strategic_advice": "When you see **'explain why'** or **'give a reason'**, always ask yourself 'And then what happens?' Add a **'so that...'** or **'which means...'** clause to show the final result.",
      "trigger_keywords": [
        "explain why",
        "give a reason",
        "describe how"
      ]
    },
    {
      "name": "Pollination vs Seed Dispersal Mix-Up",
      "what": "Mark sometimes confuses the process of pollination (which helps flowers make fruits) with seed dispersal (which spreads seeds to new places so they can grow).",
      "specific_examples": [
        {
          "questionRef": "[44]",
          "type": "oeq",
          "whatWentWrong": "He attributed the plant covering a wider area to pollination, instead of explaining that the animal eats the fruits and disperses the seeds."
        },
        {
          "questionRef": "[48]",
          "type": "oeq",
          "whatWentWrong": "When asked why the plant spread to other parts of the garden, he again mentioned pollination instead of seed dispersal."
        }
      ],
      "strategic_advice": "When a question mentions a plant **'covering a wider area'** or being found in **'other parts of the garden'**, it is almost always about **seed dispersal**, not pollination. Remember: pollination makes the fruit, dispersal moves the seed!",
      "trigger_keywords": [
        "covered a wider area",
        "reproduce",
        "dispersed",
        "other parts"
      ]
    },
    {
      "name": "Missing the Turning Point",
      "what": "When describing how things change in an experiment, Mark tends to give a broad summary instead of pointing out exactly where the trend changes direction or levels off.",
      "specific_examples": [
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "He gave a general statement about temperature affecting hatching, missing the specific trend that hatching increases up to 28°C and then decreases."
        },
        {
          "questionRef": "[45]",
          "type": "oeq",
          "whatWentWrong": "Similar to other attempts, he vaguely mentioned that temperature can increase or decrease hatching, without specifying the exact turning point."
        },
        {
          "questionRef": "[128]",
          "type": "oeq",
          "whatWentWrong": "He correctly stated that the jump height increases with more rubber bands, but missed that the height levels off and remains the same after 4 bands."
        }
      ],
      "strategic_advice": "When you see **'conclude about the effect'** or **'relationship between'**, trace the data with your finger. If the numbers go up and then down, or go up and then stay the same, you must mention **both parts** of the trend.",
      "trigger_keywords": [
        "conclude about the effect",
        "relationship between",
        "describe the changes"
      ]
    },
    {
      "name": "Skipping Sub-Questions",
      "what": "Mark occasionally leaves a part of a question completely blank, especially when it asks for a basic definition or is tucked away at the start of a multi-part question.",
      "specific_examples": [
        {
          "questionRef": "[47]",
          "type": "oeq",
          "whatWentWrong": "He correctly answered which lake was most polluted, but left the first part asking how shadows are formed completely blank."
        },
        {
          "questionRef": "[119]",
          "type": "oeq",
          "whatWentWrong": "He left the explanation for the changes in digested food between points Q and R completely blank."
        },
        {
          "questionRef": "[122]",
          "type": "oeq",
          "whatWentWrong": "He left the second part of the explanation for the changes in heart rate completely blank."
        }
      ],
      "strategic_advice": "Before moving to the next page, do a quick **'blank check'**. Count the number of question letters (a, b, c) and make sure you have an answer written for every single one, even if it's just your best guess!",
      "trigger_keywords": [
        "state how",
        "explain what happened",
        "(a) (i)"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "Stopping One Step Short",
      "what": "Mark sometimes does the heavy lifting to find an intermediate value, but occasionally stops one step short of the final consequence requested by the question.",
      "specific_examples": [
        {
          "questionRef": "[43]",
          "type": "mcq",
          "whatWentWrong": "He correctly found the fraction of the cake left for the two friends, but forgot to divide it by two to find what each friend got."
        },
        {
          "questionRef": "[108]",
          "type": "oeq",
          "whatWentWrong": "He successfully calculated the number of steps in the pattern, but stopped just before adding 1 to state the final Figure Number."
        },
        {
          "questionRef": "[118]",
          "type": "oeq",
          "whatWentWrong": "He correctly computed the fraction division, but left the answer as an improper fraction instead of converting it to a mixed number as requested."
        }
      ],
      "strategic_advice": "When you finish a calculation, make it a habit to re-read the very last sentence of the question. Look out for **trigger words** like 'each', 'mixed number', or 'Figure Number'. Ask yourself, 'Did I answer the specific question being asked, or just find a useful middle step?'",
      "trigger_keywords": [
        "each",
        "mixed number",
        "figure number",
        "usual price"
      ]
    },
    {
      "name": "Misidentifying the Reference Whole",
      "what": "Mark tends to calculate the correct numbers but occasionally assigns them to the wrong target, such as using the total amount instead of a specific part, or swapping answers for different parts.",
      "specific_examples": [
        {
          "questionRef": "[122]",
          "type": "mcq",
          "whatWentWrong": "When asked for the fraction of savings compared to expenditure, he compared the savings to the total amount instead."
        },
        {
          "questionRef": "[18]",
          "type": "oeq",
          "whatWentWrong": "He correctly calculated both angles, but accidentally swapped the answers for part (a) and part (b)."
        },
        {
          "questionRef": "[60]",
          "type": "oeq",
          "whatWentWrong": "He correctly understood the tray arrangement, but wrote down the total number of trays instead of the specific number of trays with 10 eggs."
        }
      ],
      "strategic_advice": "Pay close attention to the wording around fractions and ratios. When you see phrases like 'fraction of his expenditure' or 'ratio of men to women', circle the **reference words** so you don't accidentally use the total. For multi-part questions, double-check that your final numbers are written next to the correct letter!",
      "trigger_keywords": [
        "fraction of",
        "ratio of",
        "part (a)",
        "part (b)"
      ]
    },
    {
      "name": "Unit Omissions and Mix-ups",
      "what": "Mark occasionally forgets to write the final units, or mixes up units of length with units of area or angles.",
      "specific_examples": [
        {
          "questionRef": "[3]",
          "type": "oeq",
          "whatWentWrong": "He found the correct numerical area but forgot to include the 'cm²' unit in his final answer."
        },
        {
          "questionRef": "[7]",
          "type": "oeq",
          "whatWentWrong": "He correctly calculated the perimeter but accidentally used 'cm²' (which is for area) instead of 'cm' (for length)."
        },
        {
          "questionRef": "[144]",
          "type": "oeq",
          "whatWentWrong": "He successfully found the total weight in grams, but missed the instruction to give the final answer in kilograms."
        }
      ],
      "strategic_advice": "Always check if the question provides a unit. If it asks 'How many kilograms' or 'Find the area', write the unit down immediately next to your working space so you don't forget it. Remember that **perimeter is a length (cm)**, while **area is a surface (cm²)**.",
      "trigger_keywords": [
        "area",
        "perimeter",
        "kilograms",
        "cm²",
        "cm"
      ]
    },
    {
      "name": "Partial Circle Perimeter Traps",
      "what": "When finding the perimeter of semicircles or quarter-circles, Mark sometimes uses the formula for a full circle or forgets to include the straight edges.",
      "specific_examples": [
        {
          "questionRef": "[2]",
          "type": "mcq",
          "whatWentWrong": "He calculated the circumference of a full circle and added the diameter, instead of halving the circumference for a semicircle."
        },
        {
          "questionRef": "[93]",
          "type": "mcq",
          "whatWentWrong": "He correctly found the curved length of the quarter-circle, but forgot to add the two straight radius edges to complete the perimeter."
        },
        {
          "questionRef": "[97]",
          "type": "oeq",
          "whatWentWrong": "He calculated the curved parts of the figure beautifully, but overlooked the straight line segments when finding the total perimeter."
        }
      ],
      "strategic_advice": "When a question asks for the perimeter of a shape with curves, trace the entire outside edge with your pencil. This physical action will remind you to include **both the curved arcs and the straight edges**. Also, double-check if the shape is a **semicircle (divide by 2)** or a **quarter-circle (divide by 4)**.",
      "trigger_keywords": [
        "perimeter",
        "semicircle",
        "quarter-circle",
        "figure"
      ]
    }
  ],

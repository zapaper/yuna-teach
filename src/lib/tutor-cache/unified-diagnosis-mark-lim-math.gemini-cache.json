{
  "patterns": [
    {
      "name": "Stopping Too Early",
      "what": "Mark occasionally does the hard work to find an intermediate value, but stops one step short of the final answer requested.",
      "specific_examples": [
        {
          "questionRef": "[52]",
          "type": "mcq",
          "whatWentWrong": "He correctly found the remaining fraction of the cake for the two friends, but forgot to divide it by two to find what each friend got."
        },
        {
          "questionRef": "[138]",
          "type": "oeq",
          "whatWentWrong": "He successfully calculated the pattern multiplier, but forgot to add 1 at the end to find the actual Figure Number."
        },
        {
          "questionRef": "[54]",
          "type": "oeq",
          "whatWentWrong": "He found the total number of trays, but stopped there instead of calculating how many of those trays had exactly 10 eggs."
        }
      ],
      "strategic_advice": "When you finish a calculation, re-read the last sentence of the question to make sure you are answering exactly what is asked.\n- **'each friend'** → remember to divide the total by the number of friends\n- **'how many more'** → remember to subtract the two values at the end\n- **'altogether'** → check if you need to add an earlier amount to your final number",
      "trigger_keywords": [
        "each",
        "altogether",
        "how many more",
        "Figure Number"
      ]
    },
    {
      "name": "Wrong Total Used",
      "what": "Mark sometimes calculates a fraction or ratio using the original total, instead of the specific leftover or group asked for in the question.",
      "specific_examples": [
        {
          "questionRef": "[152]",
          "type": "mcq",
          "whatWentWrong": "He found the savings as a fraction of the total money, instead of finding it as a fraction of the expenditure."
        },
        {
          "questionRef": "[160]",
          "type": "mcq",
          "whatWentWrong": "He gave the ratio of women to the total number of passengers, rather than the ratio of men to women."
        }
      ],
      "strategic_advice": "When a question asks for a fraction or ratio, circle the words that come right after **'fraction of'** or **'ratio of'**.\n- **'fraction of his expenditure'** → put the expenditure at the bottom of the fraction, not the total money\n- **'ratio of men to women'** → make sure you are comparing the two groups, not a group to the total",
      "trigger_keywords": [
        "fraction of",
        "ratio of",
        "remainder",
        "expenditure"
      ]
    },
    {
      "name": "Wrong or Missing Units",
      "what": "Mark tends to leave out units in his final answer, or accidentally uses a unit for area when the question asks for length.",
      "specific_examples": [
        {
          "questionRef": "[7]",
          "type": "oeq",
          "whatWentWrong": "He calculated the perimeter perfectly, but wrote 'cm²' (which is for area) instead of 'cm'."
        },
        {
          "questionRef": "[12]",
          "type": "oeq",
          "whatWentWrong": "He found the correct area of the shaded part, but accidentally used the degree symbol '°' instead of 'cm²'."
        },
        {
          "questionRef": "[133]",
          "type": "oeq",
          "whatWentWrong": "He found the correct amount of money Tim was paid, but forgot to include the '$' sign."
        }
      ],
      "strategic_advice": "Always double-check what the question is measuring before writing your final answer.\n- **'perimeter'** or **'length'** → use cm or m\n- **'area'** → use cm² or m²\n- **'how much'** → remember the $ sign",
      "trigger_keywords": [
        "perimeter",
        "area",
        "how much",
        "diameter"
      ]
    },
    {
      "name": "Arc vs Perimeter Mix-Up",
      "what": "Mark occasionally confuses the length of a curved arc with the total perimeter of a shape, forgetting to add the straight edges.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "mcq",
          "whatWentWrong": "He found the length of the curved part of the quarter-circle, but forgot to add the two straight sides to get the full perimeter."
        },
        {
          "questionRef": "[127]",
          "type": "oeq",
          "whatWentWrong": "He correctly calculated the curved lengths of the semicircles, but left out the straight line segments when finding the total perimeter."
        }
      ],
      "strategic_advice": "When finding the perimeter of a shape with curves, trace the entire outside edge with your pencil.\n- **'perimeter of the figure'** → add the curved arc **and** all the straight edges that make up the border",
      "trigger_keywords": [
        "perimeter",
        "semicircle",
        "quarter-circle",
        "figure"
      ]
    }
  ],

{
  "patterns": [
    {
      "name": "Premature Final Answer",
      "what": "Sometimes stops one step short of the final answer, such as finding an intermediate value but forgetting the final operation.",
      "specific_examples": [
        {
          "questionRef": "[47]",
          "type": "mcq",
          "whatWentWrong": "Mark correctly found the remaining fraction of the cake but forgot the final step of dividing it equally between the two friends."
        },
        {
          "questionRef": "[135]",
          "type": "mcq",
          "whatWentWrong": "He successfully calculated the amount of paint used, but stopped one step short of subtracting it to find the amount left."
        },
        {
          "questionRef": "[120]",
          "type": "oeq",
          "whatWentWrong": "Mark accurately calculated the discount amount, but forgot that the question asked for the usual price."
        }
      ],
      "strategic_advice": "When you see prompts like **'left with'** or **'shared equally'**, treat them as stop signs to double-check your final step.\n- **'left with'** → remember to subtract the amount used from the total\n- **'shared equally'** → remember to divide your remaining fraction by the number of people\n- **'usual price'** → ensure you are finding the original 100%, not just the discount amount",
      "trigger_keywords": [
        "shared equally",
        "left with",
        "usual price",
        "how many more"
      ]
    },
    {
      "name": "Reference Whole Confusion",
      "what": "Occasionally uses the overall total as the denominator when finding a fraction or ratio, instead of the specific group requested by the question.",
      "specific_examples": [
        {
          "questionRef": "[123]",
          "type": "mcq",
          "whatWentWrong": "When asked for the fraction of savings, Mark used the total money as the denominator instead of just the savings amount."
        },
        {
          "questionRef": "[140]",
          "type": "mcq",
          "whatWentWrong": "He found the ratio of women to the total number of passengers, rather than comparing men to women as requested."
        },
        {
          "questionRef": "[95]",
          "type": "oeq",
          "whatWentWrong": "Mark calculated the correct number of sold pens, but used the remaining pens as the denominator instead of the total red pens."
        }
      ],
      "strategic_advice": "When a question asks for a **'fraction of'** or **'ratio of'** something, the words immediately following tell you what your reference whole should be.\n- **'fraction of his savings'** → use the savings amount as the denominator, not the total money\n- **'ratio of men to women'** → compare the two specific groups, excluding the total\n- Always circle the words right after **'fraction of'** or **'ratio of'** to lock in your reference whole.",
      "trigger_keywords": [
        "fraction of his savings",
        "fraction of his expenditure",
        "fraction of the red pens",
        "ratio of the number"
      ]
    },
    {
      "name": "Incomplete Perimeter",
      "what": "Tends to calculate the curved parts of a shape accurately but occasionally forgets to add the straight edges, or forgets to halve the full circumference for a semicircle.",
      "specific_examples": [
        {
          "questionRef": "[103]",
          "type": "mcq",
          "whatWentWrong": "Mark correctly calculated the length of the curved arc but forgot to add the two straight edges to close the shape."
        },
        {
          "questionRef": "[104]",
          "type": "mcq",
          "whatWentWrong": "He calculated the full circumference of the circle but forgot to halve it for the semicircle."
        },
        {
          "questionRef": "[107]",
          "type": "oeq",
          "whatWentWrong": "Mark did the heavy lifting to find the curved lengths but omitted the straight line segments from the final perimeter."
        }
      ],
      "strategic_advice": "When finding the **'perimeter of the figure'**, trace the entire outside edge with your pencil.\n- If the shape includes a **'semicircle'**, remember to divide the full circle's circumference by 2.\n- Always check if there are straight lines (like the diameter or the sides of a rectangle) that need to be added to the curved parts to close the shape.",
      "trigger_keywords": [
        "perimeter of the figure",
        "perimeter of the semicircle",
        "quarter-circle"
      ]
    },
    {
      "name": "Units of Measurement",
      "what": "Sometimes omits the units in the final answer or mixes up units of length (cm) with units of area (cm²).",
      "specific_examples": [
        {
          "questionRef": "[3]",
          "type": "oeq",
          "whatWentWrong": "Mark found the correct numerical area but forgot to include the 'cm²' unit in his final answer."
        },
        {
          "questionRef": "[7]",
          "type": "oeq",
          "whatWentWrong": "He calculated the perimeter perfectly but accidentally wrote 'cm²' (used for area) instead of 'cm'."
        },
        {
          "questionRef": "[154]",
          "type": "oeq",
          "whatWentWrong": "Mark correctly found the total weight in grams but forgot to convert it to kilograms as requested by the question."
        }
      ],
      "strategic_advice": "Get into the habit of writing the unit next to your final number immediately.\n- For **'perimeter'** or length, use plain units like **cm** or **m**.\n- For **'area'**, always use square units like **cm²** or **m²**.\n- If the question asks for **'kilograms'**, make sure you convert from grams before writing your final answer.",
      "trigger_keywords": [
        "area",
        "perimeter",
        "kilograms",
        "cm²"
      ]
    }
  ],

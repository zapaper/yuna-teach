{
  "patterns": [
    {
      "name": "Reported Speech Mix-Up",
      "what": "Kaiyangnggg sometimes forgets to shift tenses backwards, change pronouns, or update time words when changing direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[13]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg missed changing the pronoun and the word order for the reported question."
        },
        {
          "questionRef": "[31]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg forgot to shift the past tense 'saw' back to the past perfect 'had seen' and missed the time word change."
        },
        {
          "questionRef": "[32]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg missed changing the time word 'now' to 'then' and used the wrong pronoun."
        }
      ],
      "strategic_advice": "When you see quotes being removed, treat it as a checklist:\n- **Tense**: Shift it one step back in time (e.g., present to past).\n- **Pronouns**: Change 'I' or 'you' to match the speaker.\n- **Time words**: Change words like 'now' to 'then', or 'yesterday' to 'the previous day'.",
      "trigger_keywords": [
        "asked",
        "wanted to know",
        "said"
      ]
    },
    {
      "name": "Subject-Verb Agreement Mix-Up",
      "what": "Kaiyangnggg occasionally gets tricked by extra phrases like 'as well as' or 'together with' and matches the verb to the wrong noun.",
      "specific_examples": [
        {
          "questionRef": "[15]",
          "type": "mcq",
          "whatWentWrong": "Kaiyangnggg matched the verb to the plural 'cousins' instead of the singular main subject 'My sister'."
        },
        {
          "questionRef": "[25]",
          "type": "mcq",
          "whatWentWrong": "Kaiyangnggg was tricked by the phrase 'together with his friends' and chose a plural verb for a singular subject."
        }
      ],
      "strategic_advice": "When you see phrases like **'together with'** or **'as well as'**, try crossing them out lightly with your pencil. This helps you spot the true main subject so you can pick the correct singular or plural verb.",
      "trigger_keywords": [
        "as well as",
        "together with",
        "along with"
      ]
    },
    {
      "name": "Leaving Out Small Details",
      "what": "Kaiyangnggg tends to drop descriptive words or short phrases from the original sentence during Synthesis, which slightly changes the meaning of the final answer.",
      "specific_examples": [
        {
          "questionRef": "[45]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg dropped the word 'sudden', which slightly changed the meaning of the original sentence."
        },
        {
          "questionRef": "[50]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg missed out the word 'quickly', leaving the final answer incomplete."
        },
        {
          "questionRef": "[52]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg forgot to include the word 'can', which changed the capability described in the sentence."
        }
      ],
      "strategic_advice": "After writing your new sentence, do a quick **word-matching check**. Make sure every key detail from the original sentence—like **'sudden'**, **'quickly'**, or **'can'**—has made its way into your final answer.",
      "trigger_keywords": [
        "Rewrite the sentence",
        "Synthesis"
      ]
    },
    {
      "name": "One Step Short",
      "what": "Kaiyangnggg often finds the right part of the passage but occasionally stops one step short of giving the complete explanation required for full marks.",
      "specific_examples": [
        {
          "questionRef": "[5]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg correctly noted that someone had to stay home, but stopped short of explaining the financial burden involved."
        },
        {
          "questionRef": "[9]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg identified the qualities gained, but missed explaining how they specifically helped in the job as a counsellor."
        },
        {
          "questionRef": "[96]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg gave a general reason about being worried, but missed the specific fear of not being chosen as a partner."
        }
      ],
      "strategic_advice": "When you see prompts like **'explain clearly why'**, always ask yourself if there is a **'so that...'** or **'because...'** consequence you can add. Make sure to include both the action and the final result.",
      "trigger_keywords": [
        "Explain clearly why",
        "In what ways",
        "Fill in the table"
      ]
    }
  ],

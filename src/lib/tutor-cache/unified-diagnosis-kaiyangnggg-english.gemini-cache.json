  "patterns": [
    {
      "name": "Missing Small Details",
      "what": "Sometimes leaves out small but important words from the original sentence or passage, which changes the exact meaning of the answer.",
      "specific_examples": [
        {
          "questionRef": "[34]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg left out the word 'sudden' when rewriting the sentence about the heavy downpour."
        },
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "He missed out the word 'can', which changed the meaning of what the blender is able to do."
        },
        {
          "questionRef": "[85]",
          "type": "oeq",
          "whatWentWrong": "He gave a general answer about being worried, instead of the specific detail about fearing not being chosen."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs:\n- **'rewrite'** → use a pencil to **tick off every word** from the original sentence as you write it in your new sentence.\n- **'based on the passage'** → always check if your answer includes the **specific action or reason** mentioned in the text, rather than a general summary.",
      "trigger_keywords": [
        "rewrite",
        "based on the passage",
        "explain why"
      ]
    },
    {
      "name": "Reported Speech Slips",
      "what": "Occasionally forgets to shift the tense backwards or change the pronouns when turning spoken quotes into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg kept the past tense 'saw' instead of shifting it back to the past perfect 'had seen'."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "He forgot to change the time word 'now' to 'then', and used the wrong pronoun 'he' instead of 'she'."
        },
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "He used 'they' and 'their' instead of 'he' and 'his' when referring to a single student."
        }
      ],
      "strategic_advice": "When you see quotation marks, remember the **'3 Changes Rule'**:\n- Check the **Tense**: if the reporting verb is in the past tense (like **'asked'**), always shift the action one step back in time.\n- Check the **Pronouns**: make sure they match the person speaking.\n- Check the **Time/Place words**: change words like 'now' to 'then'.",
      "trigger_keywords": [
        "asked",
        "wanted to know",
        "said"
      ]
    },
    {
      "name": "Capitals and Spelling",
      "what": "Tends to lose marks on small spelling slips or by forgetting to use capital letters for proper nouns and the start of sentences.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg forgot to capitalise the name 'Henry'."
        },
        {
          "questionRef": "[44]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'for' with a small letter even though it was the first word of a new sentence."
        },
        {
          "questionRef": "[59]",
          "type": "oeq",
          "whatWentWrong": "He spelled the word correctly but forgot that it needed a capital letter at the start of the sentence."
        }
      ],
      "strategic_advice": "After writing your answer, do a quick **'Capital Check'**:\n- Look at the **very first letter** of your sentence to make sure it is capitalised.\n- Check any **names of people or places**.\n- For Editing and Cloze, always check if the blank is right after a **full stop**.",
      "trigger_keywords": [
        "rewrite",
        "fill in the blank",
        "correct the word"
      ]
    },
    {
      "name": "Prefer and Would Rather",
      "what": "Occasionally mixes up the pairing words for expressing choices, using 'than' with 'prefer' instead of 'to'.",
      "specific_examples": [
        {
          "questionRef": "[5]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg wrote 'prefers to eat sushi than pizza' instead of 'prefers eating sushi to pizza'."
        },
        {
          "questionRef": "[9]",
          "type": "oeq",
          "whatWentWrong": "He used 'preference of... than' instead of 'preference for... over'."
        },
        {
          "questionRef": "[78]",
          "type": "oeq",
          "whatWentWrong": "He added an extra 'rather' in the sentence, writing 'would rather go out rather than'."
        }
      ],
      "strategic_advice": "Memorise these fixed pairs for expressing choices:\n- **'prefer'** pairs with **'to'** (e.g., prefer sushi to pizza).\n- **'would rather'** pairs with **'than'** (e.g., would rather go out than play).\n- **'preference'** pairs with **'for'** and **'over'** (e.g., a preference for X over Y).",
      "trigger_keywords": [
        "prefers",
        "would rather",
        "preference"
      ]
    }

{
  "patterns": [
    {
      "name": "Subject-Verb Mix-Up",
      "what": "Occasionally gets tricked by extra phrases like 'as well as' or 'together with', matching the verb to the plural noun closest to the blank instead of the actual singular subject.",
      "specific_examples": [
        {
          "questionRef": "[14]",
          "type": "mcq",
          "whatWentWrong": "Kaiyangnggg picked 'are' instead of 'is' because he matched the verb to 'friends' instead of the main subject 'Ahmad'."
        },
        {
          "questionRef": "[15]",
          "type": "mcq",
          "whatWentWrong": "He picked 'are organising' instead of 'is organising' because he looked at 'cousins' instead of 'My sister'."
        },
        {
          "questionRef": "[43]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'are' instead of 'is' because he missed that 'Each of them' is a singular subject."
        }
      ],
      "strategic_advice": "When you see these prompts, treat them as stop signs:\n- **'together with'** or **'as well as'** → cross them out lightly with your pencil so they don't distract you.\n- Match your verb to the **main subject** at the very beginning of the sentence.\n- Remember that words like **'Each'**, **'Every'**, and **'Neither'** always take a singular verb.",
      "trigger_keywords": [
        "as well as",
        "together with",
        "Each of",
        "Neither"
      ]
    },
    {
      "name": "Reported Speech Shifts",
      "what": "Sometimes forgets to shift the tense backwards or change the pronouns to match the speaker when changing direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[20]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg kept the past tense 'saw' instead of shifting it backwards to the past perfect 'had seen'."
        },
        {
          "questionRef": "[21]",
          "type": "oeq",
          "whatWentWrong": "He forgot to change the time word 'now' to 'then' and used the wrong pronoun 'he' instead of 'she'."
        },
        {
          "questionRef": "[40]",
          "type": "oeq",
          "whatWentWrong": "He used the plural pronouns 'they' and 'their' instead of the singular 'he' and 'his' to refer to the student."
        }
      ],
      "strategic_advice": "When you see quotation marks being removed, remember the three shifts:\n- **Tense** → draw an arrow from the verb inside the quotes and write the **past tense** version above it.\n- **Pronouns** → double-check who is speaking and who they are talking to so you can choose the correct pronoun.\n- **Time/Place words** → remember to change words like 'now' to 'then' or 'today' to 'that day'.",
      "trigger_keywords": [
        "asked",
        "wanted to know",
        "said"
      ]
    },
    {
      "name": "Missing Key Details",
      "what": "Tends to leave out important descriptive words or specific details from the original text when writing out final answers, which can change the meaning or make the answer too general.",
      "specific_examples": [
        {
          "questionRef": "[34]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg left out the word 'sudden' when describing the heavy downpour, which slightly changed the meaning of the sentence."
        },
        {
          "questionRef": "[41]",
          "type": "oeq",
          "whatWentWrong": "He omitted the word 'can' when combining the sentences, losing the meaning that the blender is capable of making juices quickly."
        },
        {
          "questionRef": "[84]",
          "type": "oeq",
          "whatWentWrong": "He wrote a general answer like 'she encouraged him' instead of giving the specific action from the text, which was asking everyone to dance in socks."
        }
      ],
      "strategic_advice": "When writing out your final answers, try these steps:\n- For synthesis questions, use a pencil to **tick off every word** from the original sentences as you write them in your new sentence.\n- For comprehension questions, always ask yourself if your answer is **specific enough** for someone who hasn't read the passage to understand exactly what happened.\n- Do not drop 'small' words like **'can'**, **'sudden'**, or **'quickly'**—they often carry important meaning!",
      "trigger_keywords": [
        "explain",
        "why",
        "how",
        "which"
      ]
    },
    {
      "name": "Capital Letter Slips",
      "what": "Occasionally forgets to use capital letters for proper nouns and the start of sentences, or accidentally capitalises words in the middle of a sentence.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "oeq",
          "whatWentWrong": "Kaiyangnggg forgot to capitalise the proper noun 'Henry' in the middle of the sentence."
        },
        {
          "questionRef": "[23]",
          "type": "oeq",
          "whatWentWrong": "He capitalised the word 'If' even though it was in the middle of the reported speech sentence."
        },
        {
          "questionRef": "[59]",
          "type": "oeq",
          "whatWentWrong": "He wrote 'occasionally' with a small letter even though it was the first word of a new sentence in the editing passage."
        }
      ],
      "strategic_advice": "When checking your work, pay special attention to these areas:\n- Always double-check the **first word** of your final answer to make sure it starts with a capital letter.\n- Scan your sentence for **names of people, places, or specific days** and ensure they are capitalised.\n- When combining sentences, remember that words moving to the middle of the new sentence usually need to be changed to **lowercase**.",
      "trigger_keywords": [
        "Rewrite",
        "Fill in each blank",
        "Correct the word"
      ]
    }

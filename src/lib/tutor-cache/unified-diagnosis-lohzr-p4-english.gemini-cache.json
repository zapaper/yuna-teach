{
  "patterns": [
    {
      "name": "Subject-Verb Mix-Up",
      "what": "Sometimes mixes up singular and plural verbs, adding an 's' when it is not needed or leaving it out when it is.",
      "specific_examples": [
        {
          "questionRef": "[30]",
          "type": "oeq",
          "whatWentWrong": "He chose 'read' instead of 'reads' for a singular subject like 'Mr Tan'."
        },
        {
          "questionRef": "[67]",
          "type": "mcq",
          "whatWentWrong": "He picked 'was' instead of 'were' for the plural subject 'My cousins and I'."
        }
      ],
      "strategic_advice": "When you see a verb choice in brackets, always find the **'doer'** of the action first.\n- If the doer is **one person or thing** (like 'Mr Tan' or 'the anglerfish'), the verb usually needs an **'s'**.\n- If the doer is **more than one** (like 'they' or 'my cousins and I'), the verb does **not** need an 's'.",
      "trigger_keywords": [
        "is / are",
        "was / were",
        "read / reads",
        "repair / repairs"
      ]
    },
    {
      "name": "Word Meaning Mix-Up",
      "what": "Occasionally picks a word that is related to the topic but does not quite match the specific action or intensity described in the sentence.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "mcq",
          "whatWentWrong": "He chose 'swell' instead of 'slosh' to describe the big, noisy splash of water when children jump into a pool."
        },
        {
          "questionRef": "[69]",
          "type": "mcq",
          "whatWentWrong": "He picked 'manage' instead of 'handle' when talking about holding a delicate physical object like a vase."
        }
      ],
      "strategic_advice": "When choosing a vocabulary word, look for **hidden clues** in the sentence that tell you exactly how an action happens.\n- For example, if the sentence mentions a 'leaking tap' and a 'slow stream', look for a gentle word like **'trickling'** rather than 'pouring'.\n- Try plugging your chosen word into the sentence and imagine the action in your head to see if it fits perfectly.",
      "trigger_keywords": [
        "Vocabulary MCQ",
        "Fill each blank with a suitable word"
      ]
    },
    {
      "name": "Tricky Spelling Slips",
      "what": "Tends to misspell longer words in the editing section, sometimes swapping letters or adding extra vowels.",
      "specific_examples": [
        {
          "questionRef": "[33]",
          "type": "oeq",
          "whatWentWrong": "He spelled 'interesting' as 'intresting', missing the 'e' in the middle."
        },
        {
          "questionRef": "[34]",
          "type": "oeq",
          "whatWentWrong": "He spelled 'beautiful' as 'bueatyful', mixing up the order of the vowels."
        },
        {
          "questionRef": "[32]",
          "type": "oeq",
          "whatWentWrong": "He spelled the plural of 'storey' as 'storees' or 'storeyes' instead of 'storeys'."
        }
      ],
      "strategic_advice": "When you spot a spelling mistake in the editing passage, break the word down into **smaller syllables** before writing it out.\n- For example, say 'in-ter-est-ing' or 'beau-ti-ful' quietly to yourself to make sure you don't miss any letters.\n- Double-check words that end in 'y' to see if you need to change the 'y' to 'i' or just add an 's'.",
      "trigger_keywords": [
        "Editing",
        "spelling"
      ]
    },
    {
      "name": "Pronoun Mix-Up",
      "what": "Sometimes confuses which pointing word or pronoun to use when referring back to an object, person, or group.",
      "specific_examples": [
        {
          "questionRef": "[14]",
          "type": "oeq",
          "whatWentWrong": "He used 'his' instead of 'it' to refer to a football flying through the air."
        },
        {
          "questionRef": "[48]",
          "type": "mcq",
          "whatWentWrong": "He chose 'Those' instead of 'That' when pointing to a single bird flying high in the sky."
        }
      ],
      "strategic_advice": "When you need to fill in a pronoun, draw a line back to the **exact noun** it is replacing.\n- Ask yourself: Is it a person or an object? Is it **singular** (one) or **plural** (more than one)?\n- If it is a single object like a ball, use **'it'**. If it is a single object far away, use **'that'**.",
      "trigger_keywords": [
        "Grammar Cloze",
        "this / that / these / those",
        "he / she / it / they"
      ]
    }
  ],

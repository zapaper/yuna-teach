{
  "patterns": [
    {
      "name": "Reported Speech Mix-Up",
      "what": "Mark sometimes forgets to shift tenses backwards or change time words when converting direct speech into reported speech.",
      "specific_examples": [
        {
          "questionRef": "[376]",
          "type": "oeq",
          "whatWentWrong": "He kept the past tense 'wrote' instead of shifting it back to the past perfect 'had written'."
        },
        {
          "questionRef": "[316]",
          "type": "oeq",
          "whatWentWrong": "He changed 'last weekend' to 'the following week' instead of 'the previous weekend'."
        }
      ],
      "strategic_advice": "When you see quotes turning into reported speech, remember the 'Step Back' rule:\n- **Tense**: Step one tense back in time (e.g., Present becomes Past, Past becomes Past Perfect).\n- **Time/Place Words**: Change words like 'now' to **'then'**, 'yesterday' to **'the previous day'**, and 'here' to **'there'**.\n- **Pronouns**: Double-check if 'I' or 'my' needs to change to match the speaker.",
      "trigger_keywords": [
        "asked",
        "told",
        "wanted to know"
      ]
    },
    {
      "name": "Pronoun Mix-Up",
      "what": "Mark occasionally confuses subject pronouns (like 'I' or 'who') with object pronouns (like 'me' or 'whom'), especially when there are two people in the sentence.",
      "specific_examples": [
        {
          "questionRef": "[216]",
          "type": "mcq",
          "whatWentWrong": "He chose 'mine' instead of the object pronoun 'me' for the phrase 'asked Sally and me'."
        },
        {
          "questionRef": "[367]",
          "type": "mcq",
          "whatWentWrong": "He picked 'me' instead of the subject pronoun 'I' for 'Neither Jack nor I'."
        },
        {
          "questionRef": "[295]",
          "type": "oeq",
          "whatWentWrong": "He used 'whom' as a subject instead of 'who' in his Synthesis and Transformation answer."
        }
      ],
      "strategic_advice": "When you see a sentence with two people (like 'Sally and ___'), try the **Cover-Up Trick**:\n- Cover up the other person's name and read the sentence out loud. 'My teacher asked I' sounds wrong, but 'My teacher asked **me**' sounds right!\n- For 'who' vs 'whom', use the **He/Him Trick**: If you can replace the word with 'he', use **'who'**. If you can replace it with 'him', use **'whom'**.",
      "trigger_keywords": [
        "and",
        "nor",
        "who",
        "whom"
      ]
    },
    {
      "name": "Question Tag Mix-Up",
      "what": "Mark tends to get tricked by question tags when the main sentence has a hidden negative word or a contracted helping verb.",
      "specific_examples": [
        {
          "questionRef": "[240]",
          "type": "mcq",
          "whatWentWrong": "He missed that 'seldom' is a negative word, so the tag should be the positive 'does she' instead of 'doesn't she'."
        },
        {
          "questionRef": "[334]",
          "type": "mcq",
          "whatWentWrong": "He didn't spot that 'Ahmad's cleaned' means 'Ahmad has cleaned', so the tag needs to be 'hasn't he'."
        }
      ],
      "strategic_advice": "When you see a comma followed by a blank at the end of a sentence, treat it as a Question Tag puzzle:\n- **Hidden Negatives**: Words like **'seldom'**, **'rarely'**, and **'never'** make the sentence negative, so the tag must be **positive**.\n- **Unpack Contractions**: Always expand words like **'Ahmad's'** or **'You've'** to find the true helping verb (is, has, or have) before choosing your tag.",
      "trigger_keywords": [
        "seldom",
        "rarely",
        "never",
        "didn't",
        "hasn't",
        "doesn't"
      ]
    },
    {
      "name": "Missing Small Details",
      "what": "Mark sometimes leaves out small but important descriptive words from the original sentence when rewriting it, which slightly changes the meaning.",
      "specific_examples": [
        {
          "questionRef": "[359]",
          "type": "oeq",
          "whatWentWrong": "He successfully combined the sentences but accidentally left out the word 'screen'."
        },
        {
          "questionRef": "[362]",
          "type": "oeq",
          "whatWentWrong": "He missed out the word 'sudden' when describing Sam's illness."
        },
        {
          "questionRef": "[344]",
          "type": "oeq",
          "whatWentWrong": "He forgot to include the phrase 'during recess' at the end of his answer."
        }
      ],
      "strategic_advice": "When you finish writing a Synthesis and Transformation answer, do a quick **Word Match Check**:\n- Read the original sentences and your new sentence side-by-side.\n- Tick off the key details (like adjectives, time phrases, and specific objects) to make sure nothing got left behind.",
      "trigger_keywords": [
        "because of",
        "in",
        "would rather",
        "preference"
      ]
    }
  ],

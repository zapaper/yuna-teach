{
  "patterns": [
    {
      "name": "Tricky Subject Mix-Up",
      "what": "Tends to choose plural verbs when the subject is actually an uncountable noun or a singular group.",
      "specific_examples": [
        {
          "questionRef": "[5]",
          "type": "mcq",
          "whatWentWrong": "Ryan_Kho saw 'furniture' but picked the plural 'have been' instead of the singular 'was'."
        },
        {
          "questionRef": "[16]",
          "type": "mcq",
          "whatWentWrong": "He saw 'cars' and 'motorcycles' and picked 'were', missing that the main subject 'lineup' is singular."
        },
        {
          "questionRef": "[42]",
          "type": "mcq",
          "whatWentWrong": "He picked 'were' for 'laundry', forgetting that it is an uncountable noun that needs a singular verb."
        }
      ],
      "strategic_advice": "When you see words like **'All of the'** or phrases with **'as well as'**, find the true subject first.\n- **Uncountable nouns** (like furniture, laundry) always take a singular verb.\n- **Group words** (like lineup, stack) are singular, even if they contain plural items.",
      "trigger_keywords": [
        "All of the",
        "as well as",
        "furniture",
        "laundry",
        "lineup"
      ]
    },
    {
      "name": "Group Word Mix-Up",
      "what": "Sometimes looks at the plural item at the end of a phrase instead of the singular group word at the front when choosing 'this' or 'that'.",
      "specific_examples": [
        {
          "questionRef": "[28]",
          "type": "mcq",
          "whatWentWrong": "Ryan_Kho picked 'those' because of 'trousers', missing the singular word 'pair'."
        },
        {
          "questionRef": "[41]",
          "type": "mcq",
          "whatWentWrong": "He picked 'those' because of 'books', missing the singular word 'stack'."
        }
      ],
      "strategic_advice": "When pointing out objects, check if they are grouped together.\n- If you see **'pair of'** or **'stack of'**, the group itself is singular.\n- Use **'this'** or **'that'** for a single group, no matter how many items are inside it!",
      "trigger_keywords": [
        "pair of",
        "stack of",
        "this",
        "that",
        "these",
        "those"
      ]
    },
    {
      "name": "Partner Word Mix-Up",
      "what": "Occasionally mixes up the specific prepositions that must follow certain verbs or adjectives.",
      "specific_examples": [
        {
          "questionRef": "[1]",
          "type": "mcq",
          "whatWentWrong": "Ryan_Kho picked 'keen of' instead of the correct pairing 'keen on'."
        },
        {
          "questionRef": "[27]",
          "type": "mcq",
          "whatWentWrong": "He picked 'confided with' instead of the correct phrase 'confided in'."
        },
        {
          "questionRef": "[34]",
          "type": "mcq",
          "whatWentWrong": "He picked 'congratulated over' instead of the correct pairing 'congratulated on'."
        }
      ],
      "strategic_advice": "When you see a blank right after a strong verb or adjective, it is usually testing a fixed pairing.\n- Read the whole phrase aloud to see if it sounds right.\n- Memorise common pairings like **'keen on'**, **'confide in'**, and **'congratulate on'** as single chunks of meaning.",
      "trigger_keywords": [
        "keen",
        "confided",
        "congratulated",
        "revel",
        "fell"
      ]
    }
  ],
